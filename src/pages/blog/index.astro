---
import Layout from "../../layouts/Layout.astro";
import { slugify } from "../../utils/slugify";

import { getCollection } from "astro:content";

const rawBaseURL = import.meta.env.BASE_URL;

const baseURL = rawBaseURL.endsWith("/")
  ? rawBaseURL
  : `${rawBaseURL}/`;

const posts = (
  await getCollection("blog", ({ data }) => !data.draft)
).sort(
  (a, b) =>
    b.data.publishDate.getTime() -
    a.data.publishDate.getTime()
);

const formattedDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<Layout
  title="Weight Loss Blog | Practical Healthy Weight Loss Advice"
  description="Read practical articles about sustainable weight loss, nutrition, healthy habits, motivation, exercise, and beginner-friendly healthy eating."
>

  <main class="blog-page">
    <section class="blog-hero">
      <div class="blog-hero-container">
        <span class="blog-label">WEIGHT LOSS BLOG</span>

        <h1>
          Practical Advice for
          <span>Healthy Weight Loss</span>
        </h1>

        <p>
          Explore clear, realistic articles about nutrition,
          habits, motivation, exercise, and sustainable weight loss.
        </p>
      </div>
    </section>

    <section class="articles-section">
      <div class="articles-container">
        <div class="articles-heading">
          <div>
            <span>LATEST ARTICLES</span>
            <h2>Browse All Guides</h2>
          </div>

          <p>
            {posts.length}
            {posts.length === 1 ? " article" : " articles"}
          </p>
        </div>

        {
          posts.length > 0 ? (
            <div class="articles-grid">
              {posts.map((post, index) => (
                <article class="article-card">
                  <div class="article-card-top">
                    <a
                      class="article-category"
                      href={`${baseURL}category/${slugify(
                        post.data.category
                      )}/`}
                    >
                      {post.data.category}
                    </a>

                    <span class="article-number">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                  </div>

                  <h2>
                    <a href={`${baseURL}blog/${post.id}/`}>
                      {post.data.title}
                    </a>
                  </h2>

                  <p class="article-description">
                    {post.data.description}
                  </p>

                  {
                    post.data.tags.length > 0 && (
                      <div
                        class="article-tags"
                        aria-label="Article topics"
                      >
                        {post.data.tags
                          .slice(0, 3)
                          .map((tag) => (
                            <a
                              href={`${baseURL}tag/${slugify(
                                tag
                              )}/`}
                            >
                              {tag}
                            </a>
                          ))}
                      </div>
                    )
                  }

                  <div class="article-footer">
                    <div class="article-meta">
                      <span>
                        {formattedDate(post.data.publishDate)}
                      </span>

                      <span aria-hidden="true">•</span>

                      <span>{post.data.readingTime}</span>
                    </div>

                    <a
                      class="read-more"
                      href={`${baseURL}blog/${post.id}/`}
                    >
                      Read article
                      <span aria-hidden="true">→</span>
                    </a>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <h2>No articles published yet</h2>

              <p>
                New practical weight loss articles will be
                added soon.
              </p>
            </div>
          )
        }
      </div>
    </section>

    <section class="blog-cta">
      <div class="blog-cta-container">
        <div>
          <span>COMPLETE BEGINNER'S GUIDE</span>

          <h2>
            Want Everything
            <strong>in One Practical Ebook?</strong>
          </h2>

          <p>
            Get 68 practical pages, 15 beginner-friendly
            chapters, simple recipes, and sustainable advice
            designed for real life.
          </p>
        </div>

        <div class="blog-cta-actions">
          <strong>$19.99</strong>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the Ebook
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

</Layout>

<style>
  .blog-page {
    background: #ffffff;
  }

  .blog-hero {
    padding: 100px 0;
    background:
      radial-gradient(
        circle at top left,
        rgba(34, 197, 94, 0.14),
        transparent 36%
      ),
      linear-gradient(
        180deg,
        #f0fdf4 0%,
        #ffffff 100%
      );
  }

  .blog-hero-container {
    width: min(900px, calc(100% - 40px));
    margin: 0 auto;
    text-align: center;
  }

  .blog-label {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    background: #dcfce7;
    color: #15803d;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  .blog-hero h1 {
    margin: 24px 0 0;
    color: #0f172a;
    font-size: clamp(44px, 7vw, 72px);
    line-height: 1.03;
    letter-spacing: -0.05em;
  }

  .blog-hero h1 span {
    display: block;
    color: #22c55e;
  }

  .blog-hero p {
    max-width: 680px;
    margin: 26px auto 0;
    color: #64748b;
    font-size: 19px;
    line-height: 1.75;
  }

  .articles-section {
    padding: 100px 0 120px;
  }

  .articles-container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .articles-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 42px;
  }

  .articles-heading span {
    color: #16a34a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .articles-heading h2 {
    margin: 10px 0 0;
    color: #0f172a;
    font-size: clamp(34px, 5vw, 48px);
    letter-spacing: -0.04em;
  }

  .articles-heading > p {
    margin: 0;
    color: #94a3b8;
    font-weight: 700;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .article-card {
    position: relative;
    display: flex;
    min-height: 420px;
    padding: 30px;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 22px 50px rgba(15, 23, 42, 0.07);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .article-card::before {
    content: "";
    position: absolute;
    top: -55px;
    right: -55px;
    width: 155px;
    height: 155px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.08);
  }

  .article-card:hover {
    transform: translateY(-8px);
    border-color: rgba(34, 197, 94, 0.3);
    box-shadow: 0 30px 66px rgba(15, 23, 42, 0.11);
  }

  .article-card-top {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .article-category {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    padding: 0 11px;
    border-radius: 999px;
    background: #ecfdf3;
    color: #15803d;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .article-category:hover {
    transform: translateY(-2px);
    background: #22c55e;
    color: #ffffff;
  }

  .article-number {
    color: rgba(15, 23, 42, 0.13);
    font-size: 42px;
    font-weight: 900;
    line-height: 1;
  }

  .article-card h2 {
    position: relative;
    z-index: 1;
    margin: 34px 0 16px;
    font-size: 25px;
    line-height: 1.28;
    letter-spacing: -0.025em;
  }

  .article-card h2 a {
    color: #0f172a;
    text-decoration: none;
  }

  .article-card h2 a:hover {
    color: #16a34a;
  }

  .article-description {
    position: relative;
    z-index: 1;
    margin: 0;
    color: #64748b;
    line-height: 1.7;
  }

  .article-tags {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 22px;
  }

  .article-tags a {
    display: inline-flex;
    min-height: 29px;
    align-items: center;
    padding: 0 9px;
    border: 1px solid transparent;
    border-radius: 999px;
    background: #f8fafc;
    color: #64748b;
    font-size: 11px;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .article-tags a:hover {
    transform: translateY(-2px);
    border-color: #22c55e;
    background: #22c55e;
    color: #ffffff;
  }

  .article-footer {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 15px;
    margin-top: auto;
    padding-top: 28px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
    color: #94a3b8;
    font-size: 13px;
    font-weight: 700;
  }

  .read-more {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 9px;
    color: #16a34a;
    font-size: 14px;
    font-weight: 900;
    text-decoration: none;
  }

  .read-more:hover {
    text-decoration: underline;
  }

  .empty-state {
    padding: 50px;
    border-radius: 24px;
    background: #f8fafc;
    text-align: center;
  }

  .empty-state h2 {
    margin: 0 0 10px;
    color: #0f172a;
  }

  .empty-state p {
    margin: 0;
    color: #64748b;
  }

  .blog-cta {
    padding: 82px 0;
    background: #0f172a;
  }

  .blog-cta-container {
    display: grid;
    width: min(1040px, calc(100% - 40px));
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 70px;
    margin: 0 auto;
  }

  .blog-cta-container > div > span {
    color: #4ade80;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .blog-cta h2 {
    margin: 15px 0;
    color: #ffffff;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .blog-cta h2 strong {
    display: block;
    color: #4ade80;
  }

  .blog-cta p {
    max-width: 650px;
    margin: 0;
    color: #cbd5e1;
    font-size: 17px;
    line-height: 1.7;
  }

  .blog-cta-actions {
    min-width: 230px;
    padding: 28px;
    border-radius: 22px;
    background: #ffffff;
    text-align: center;
  }

  .blog-cta-actions > strong {
    display: block;
    margin-bottom: 18px;
    color: #0f172a;
    font-size: 34px;
  }

  .blog-cta-actions a {
    display: flex;
    min-height: 52px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 0 17px;
    border-radius: 13px;
    background: #22c55e;
    color: #ffffff;
    font-weight: 900;
    text-decoration: none;
  }

  .blog-cta-actions a:hover {
    background: #16a34a;
  }

  @media (max-width: 940px) {
    .articles-grid {
      max-width: 720px;
      grid-template-columns: 1fr;
      margin: 0 auto;
    }

    .article-card {
      min-height: 350px;
    }

    .blog-cta-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .blog-cta-actions {
      width: 100%;
      max-width: 500px;
    }
  }

  @media (max-width: 620px) {
    .blog-hero {
      padding: 76px 0;
    }

    .blog-hero-container,
    .articles-container,
    .blog-cta-container {
      width: min(100% - 24px, 1180px);
    }

    .articles-section {
      padding: 76px 0 90px;
    }

    .articles-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .article-card {
      min-height: 370px;
      padding: 24px;
      border-radius: 20px;
    }

    .blog-cta {
      padding: 68px 0;
    }
  }
</style>