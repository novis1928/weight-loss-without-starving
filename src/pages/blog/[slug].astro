---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import RelatedArticles from "../../components/RelatedArticles.astro";

import { getCollection, render } from "astro:content";
import { slugify } from "../../utils/slugify";

export async function getStaticPaths() {
  const posts = await getCollection(
    "blog",
    ({ data }) => !data.draft
  );

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const baseURL = import.meta.env.BASE_URL;

const formattedDate =
  post.data.publishDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const articleURL = new URL(
  `${baseURL}blog/${post.id}/`,
  Astro.site
).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description:
    post.data.seoDescription ?? post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  dateModified:
    post.data.updatedDate?.toISOString() ??
    post.data.publishDate.toISOString(),
  author: {
    "@type": "Person",
    name: post.data.author,
  },
  publisher: {
    "@type": "Person",
    name: "George Novák",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleURL,
  },
  url: articleURL,
  inLanguage: "en",
  articleSection: post.data.category,
  keywords: post.data.tags.join(", "),
};
---

<Layout
  title={post.data.seoTitle ?? post.data.title}
  description={
    post.data.seoDescription ?? post.data.description
  }
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(articleSchema)}
  />

  <Header />

  <main class="article-page">
    <section class="article-hero">
      <div class="article-hero-container">
        <nav
          class="breadcrumbs"
          aria-label="Breadcrumb"
        >
          <a href={baseURL}>Home</a>

          <span>/</span>

          <a href={`${baseURL}blog/`}>
            Blog
          </a>

          <span>/</span>

          <span aria-current="page">
            {post.data.title}
          </span>
        </nav>

        <a
          class="article-label"
          href={`${baseURL}category/${slugify(
            post.data.category
          )}/`}
        >
          {post.data.category}
        </a>

        <h1>{post.data.title}</h1>

        <p class="article-description">
          {post.data.description}
        </p>

        {
          post.data.tags.length > 0 && (
            <div
              class="article-tags"
              aria-label="Article topics"
            >
              {post.data.tags.map((tag) => (
                <a
                  class="article-tag"
                  href={`${baseURL}tag/${slugify(tag)}/`}
                >
                  {tag}
                </a>
              ))}
            </div>
          )
        }

        <div class="article-meta">
          <div
            class="author-avatar"
            aria-hidden="true"
          >
            GN
          </div>

          <div class="author-copy">
            <strong>{post.data.author}</strong>

            <div class="meta-details">
              <span>{formattedDate}</span>

              <span class="meta-separator">
                •
              </span>

              <span>{post.data.readingTime}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="article-body-section">
      <div class="article-layout">
        <aside class="article-sidebar">
          <div class="toc-card">
            <span class="toc-label">
              IN THIS ARTICLE
            </span>

            <nav aria-label="Table of contents">
              {
                headings
                  .filter(
                    (heading) =>
                      heading.depth === 2
                  )
                  .map((heading) => (
                    <a
                      href={`#${heading.slug}`}
                    >
                      {heading.text}
                    </a>
                  ))
              }
            </nav>
          </div>

          <div class="sidebar-ebook">
            <span>COMPLETE GUIDE</span>

            <h2>
              Weight Loss Without Starving
            </h2>

            <p>
              Get the full beginner-friendly
              ebook with practical guidance,
              simple recipes, and sustainable
              habits.
            </p>

            <strong>$19.99</strong>

            <a
              href="https://payhip.com/b/eW3MA"
              target="_blank"
              rel="noopener noreferrer"
            >
              Get the Ebook
              <span>→</span>
            </a>
          </div>
        </aside>

        <article class="article-content">
          <Content />

          <div class="article-disclaimer">
            <strong>Important note</strong>

            <p>
              This article is for general
              educational purposes only and
              does not replace individual
              medical or nutritional advice.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="article-cta">
      <div class="article-cta-container">
        <div class="cta-copy">
          <span class="cta-label">
            READY TO START?
          </span>

          <h2>
            Build Better Habits
            <span>Without Extreme Diets</span>
          </h2>

          <p>
            Learn healthy weight loss step by
            step with practical advice,
            beginner-friendly explanations,
            simple recipes, and habits that fit
            real life.
          </p>

          <ul>
            <li>68 practical pages</li>
            <li>
              15 easy-to-understand chapters
            </li>
            <li>Instant PDF access</li>
          </ul>
        </div>

        <div class="cta-card">
          <span>DIGITAL EBOOK</span>

          <h3>
            Weight Loss Without Starving
          </h3>

          <p>
            One-time payment. No subscription.
          </p>

          <strong>$19.99</strong>

          <a
            class="cta-primary"
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Buy on Payhip
            <span>→</span>
          </a>

          <a
            class="cta-secondary"
            href="https://novis4.gumroad.com/l/lcuop"
            target="_blank"
            rel="noopener noreferrer"
          >
            Buy on Gumroad
            <span>→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <RelatedArticles currentPost={post} />

  <Footer />
</Layout>

<style>
  .article-page {
    background: #ffffff;
  }

  .article-hero {
    padding: 82px 0 92px;
    background:
      radial-gradient(
        circle at top left,
        rgba(34, 197, 94, 0.14),
        transparent 35%
      ),
      linear-gradient(
        180deg,
        #f0fdf4 0%,
        #ffffff 100%
      );
  }

  .article-hero-container {
    width: min(900px, calc(100% - 40px));
    margin: 0 auto;
    text-align: center;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    margin-bottom: 34px;
    color: #94a3b8;
    font-size: 14px;
    flex-wrap: wrap;
  }

  .breadcrumbs a {
    color: #64748b;
    font-weight: 700;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #16a34a;
  }

  .article-label {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    background: #dcfce7;
    color: #15803d;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .article-label:hover {
    transform: translateY(-2px);
    background: #22c55e;
    color: #ffffff;
  }

  .article-hero h1 {
    max-width: 880px;
    margin: 24px auto 0;
    color: #0f172a;
    font-size: clamp(42px, 7vw, 72px);
    line-height: 1.03;
    letter-spacing: -0.05em;
  }

  .article-description {
    max-width: 720px;
    margin: 26px auto 0;
    color: #64748b;
    font-size: 20px;
    line-height: 1.75;
  }

  .article-tags {
    display: flex;
    justify-content: center;
    gap: 9px;
    flex-wrap: wrap;
    max-width: 760px;
    margin: 24px auto 0;
  }

  .article-tag {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 11px;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: #64748b;
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .article-tag:hover {
    transform: translateY(-2px);
    border-color: #22c55e;
    background: #22c55e;
    color: #ffffff;
  }

  .article-meta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-top: 34px;
    text-align: left;
  }

  .author-avatar {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 50%;
    background:
      linear-gradient(
        135deg,
        #22c55e,
        #15803d
      );
    color: #ffffff;
    font-size: 15px;
    font-weight: 900;
    box-shadow:
      0 12px 24px
      rgba(34, 197, 94, 0.25);
  }

  .author-copy {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .author-copy strong {
    color: #0f172a;
    font-size: 15px;
  }

  .meta-details {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #94a3b8;
    font-size: 14px;
  }

  .meta-separator {
    color: #cbd5e1;
  }

  .article-body-section {
    padding: 90px 0 110px;
  }

  .article-layout {
    display: grid;
    width: min(1180px, calc(100% - 40px));
    grid-template-columns:
      260px minmax(0, 760px);
    align-items: start;
    justify-content: center;
    gap: 64px;
    margin: 0 auto;
  }

  .article-sidebar {
    position: sticky;
    top: 110px;
    display: grid;
    gap: 24px;
  }

  .toc-card {
    padding: 24px;
    border:
      1px solid rgba(15, 23, 42, 0.08);
    border-radius: 20px;
    background: #ffffff;
    box-shadow:
      0 18px 44px
      rgba(15, 23, 42, 0.06);
  }

  .toc-label {
    display: block;
    margin-bottom: 18px;
    color: #16a34a;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .toc-card nav {
    display: grid;
    gap: 12px;
  }

  .toc-card a {
    color: #64748b;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.45;
    text-decoration: none;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .toc-card a:hover {
    transform: translateX(3px);
    color: #16a34a;
  }

  .sidebar-ebook {
    padding: 26px;
    border-radius: 22px;
    background: #0f172a;
    color: #ffffff;
    box-shadow:
      0 24px 55px
      rgba(15, 23, 42, 0.16);
  }

  .sidebar-ebook > span {
    color: #4ade80;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .sidebar-ebook h2 {
    margin: 14px 0 12px;
    color: #ffffff;
    font-size: 24px;
    line-height: 1.25;
  }

  .sidebar-ebook p {
    margin: 0;
    color: #cbd5e1;
    font-size: 14px;
    line-height: 1.65;
  }

  .sidebar-ebook strong {
    display: block;
    margin-top: 20px;
    color: #ffffff;
    font-size: 25px;
  }

  .sidebar-ebook a {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: space-between;
    margin-top: 18px;
    padding: 0 16px;
    border-radius: 12px;
    background: #22c55e;
    color: #ffffff;
    font-size: 14px;
    font-weight: 900;
    text-decoration: none;
  }

  .article-content {
    color: #334155;
    font-size: 18px;
    line-height: 1.85;
  }

  .article-content :global(h2) {
    margin: 58px 0 20px;
    color: #0f172a;
    font-size: clamp(30px, 4vw, 40px);
    line-height: 1.2;
    letter-spacing: -0.035em;
    scroll-margin-top: 120px;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(h3) {
    margin: 38px 0 14px;
    color: #0f172a;
    font-size: 25px;
    line-height: 1.3;
    letter-spacing: -0.025em;
    scroll-margin-top: 120px;
  }

  .article-content :global(p) {
    margin: 0 0 24px;
  }

  .article-content :global(strong) {
    color: #0f172a;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0 0 28px;
    padding-left: 26px;
  }

  .article-content :global(li) {
    margin-bottom: 10px;
    padding-left: 5px;
  }

  .article-content :global(li::marker) {
    color: #22c55e;
    font-weight: 900;
  }

  .article-content :global(a) {
    color: #16a34a;
    font-weight: 700;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  .article-content :global(blockquote) {
    margin: 38px 0;
    padding: 24px 28px;
    border-left: 4px solid #22c55e;
    border-radius: 0 16px 16px 0;
    background: #f0fdf4;
    color: #334155;
    font-size: 20px;
    font-style: italic;
    line-height: 1.7;
  }

  .article-content :global(hr) {
    height: 1px;
    margin: 44px 0;
    border: 0;
    background: #e2e8f0;
  }

  .article-content :global(img) {
    width: 100%;
    height: auto;
    margin: 34px 0;
    border-radius: 20px;
    box-shadow:
      0 20px 48px
      rgba(15, 23, 42, 0.1);
  }

  .article-disclaimer {
    margin-top: 58px;
    padding: 24px;
    border:
      1px solid rgba(34, 197, 94, 0.18);
    border-radius: 18px;
    background: #f0fdf4;
  }

  .article-disclaimer strong {
    display: block;
    margin-bottom: 7px;
    color: #166534;
  }

  .article-disclaimer p {
    margin: 0;
    color: #64748b;
    font-size: 15px;
    line-height: 1.7;
  }

  .article-cta {
    padding: 90px 0;
    background:
      linear-gradient(
        135deg,
        #15803d,
        #22c55e
      );
  }

  .article-cta-container {
    display: grid;
    width: min(1040px, calc(100% - 40px));
    grid-template-columns:
      minmax(0, 1.15fr)
      minmax(300px, 0.85fr);
    align-items: center;
    gap: 72px;
    margin: 0 auto;
  }

  .cta-label {
    color: #bbf7d0;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.13em;
  }

  .cta-copy h2 {
    margin: 18px 0;
    color: #ffffff;
    font-size: clamp(38px, 5vw, 58px);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .cta-copy h2 span {
    display: block;
    color: #bbf7d0;
  }

  .cta-copy > p {
    max-width: 620px;
    margin: 0;
    color: #dcfce7;
    font-size: 17px;
    line-height: 1.75;
  }

  .cta-copy ul {
    display: grid;
    grid-template-columns:
      repeat(2, minmax(0, 1fr));
    gap: 13px 26px;
    margin: 30px 0 0;
    padding: 0;
    list-style: none;
  }

  .cta-copy li {
    color: #ffffff;
    font-weight: 700;
  }

  .cta-copy li::before {
    content: "✓";
    margin-right: 9px;
    color: #bbf7d0;
  }

  .cta-card {
    padding: 34px;
    border-radius: 26px;
    background: #ffffff;
    text-align: center;
    box-shadow:
      0 30px 70px
      rgba(15, 23, 42, 0.2);
  }

  .cta-card > span {
    color: #16a34a;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .cta-card h3 {
    margin: 13px 0 10px;
    color: #0f172a;
    font-size: 28px;
    line-height: 1.25;
  }

  .cta-card p {
    margin: 0;
    color: #64748b;
  }

  .cta-card > strong {
    display: block;
    margin: 24px 0;
    color: #0f172a;
    font-size: 38px;
  }

  .cta-card a {
    display: flex;
    min-height: 54px;
    align-items: center;
    justify-content: space-between;
    padding: 0 18px;
    border-radius: 13px;
    font-weight: 900;
    text-decoration: none;
  }

  .cta-primary {
    background: #22c55e;
    color: #ffffff;
  }

  .cta-secondary {
    margin-top: 12px;
    border: 2px solid #22c55e;
    color: #15803d;
  }

  @media (max-width: 940px) {
    .article-layout {
      max-width: 780px;
      grid-template-columns: 1fr;
    }

    .article-sidebar {
      position: static;
      order: 2;
      grid-template-columns: 1fr 1fr;
    }

    .article-content {
      order: 1;
    }

    .article-cta-container {
      grid-template-columns: 1fr;
      gap: 46px;
    }

    .cta-card {
      width: 100%;
      max-width: 600px;
      margin: 0 auto;
    }
  }

  @media (max-width: 680px) {
    .article-hero {
      padding: 62px 0 70px;
    }

    .article-hero-container,
    .article-layout,
    .article-cta-container {
      width: min(100% - 24px, 1180px);
    }

    .article-description {
      font-size: 17px;
    }

    .article-tags {
      gap: 7px;
      margin-top: 20px;
    }

    .article-tag {
      min-height: 28px;
      padding: 0 9px;
      font-size: 11px;
    }

    .article-meta {
      align-items: flex-start;
    }

    .article-body-section {
      padding: 68px 0 82px;
    }

    .article-sidebar {
      grid-template-columns: 1fr;
    }

    .article-content {
      font-size: 17px;
      line-height: 1.8;
    }

    .article-content :global(h2) {
      margin-top: 46px;
    }

    .article-cta {
      padding: 72px 0;
    }

    .cta-copy ul {
      grid-template-columns: 1fr;
    }

    .cta-card {
      padding: 28px 22px;
      border-radius: 21px;
    }
  }
</style>