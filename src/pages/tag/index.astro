---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

import { getCollection } from "astro:content";
import { slugify } from "../../utils/slugify";

const rawBaseURL = import.meta.env.BASE_URL;

const baseURL = rawBaseURL.endsWith("/")
  ? rawBaseURL
  : `${rawBaseURL}/`;

const posts = await getCollection(
  "blog",
  ({ data }) => !data.draft
);

const tagMap = new Map<
  string,
  {
    name: string;
    count: number;
  }
>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    const tagSlug = slugify(tag);
    const existingTag = tagMap.get(tagSlug);

    if (existingTag) {
      existingTag.count += 1;
    } else {
      tagMap.set(tagSlug, {
        name: tag,
        count: 1,
      });
    }
  }
}

const tags = Array.from(tagMap.entries())
  .map(([slug, tag]) => ({
    slug,
    ...tag,
  }))
  .sort((a, b) => {
    if (b.count !== a.count) {
      return b.count - a.count;
    }

    return a.name.localeCompare(b.name);
  });
---

<Layout
  title="Weight Loss Tags | Browse All Topics"
  description="Browse all weight loss topics, including calories, nutrition, exercise, healthy habits, motivation, metabolism, meal planning, and sustainable weight loss."
>
  <Header />

  <main class="tag-page">
    <section class="tag-hero">
      <div class="tag-hero-container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={baseURL}>Home</a>

          <span aria-hidden="true">/</span>

          <span aria-current="page">Tags</span>
        </nav>

        <span class="page-label">
          EXPLORE BY TOPIC
        </span>

        <h1>
          Browse All
          <span>Tags</span>
        </h1>

        <p>
          Discover practical weight loss articles by topic,
          including nutrition, calories, exercise, metabolism,
          meal planning, healthy habits, and motivation.
        </p>
      </div>
    </section>

    <section class="tag-section">
      <div class="tag-container">
        <div class="section-heading">
          <div>
            <span>ALL TAGS</span>

            <h2>Choose a Topic</h2>
          </div>

          <p>
            {tags.length}
            {tags.length === 1 ? " tag" : " tags"}
          </p>
        </div>

        {
          tags.length > 0 ? (
            <div class="tag-grid">
              {tags.map((tag, index) => (
                <a
                  class="tag-card"
                  href={`${baseURL}tag/${tag.slug}/`}
                  aria-label={`View articles tagged ${tag.name}`}
                >
                  <div class="tag-card-top">
                    <span class="tag-number">
                      {String(index + 1).padStart(2, "0")}
                    </span>

                    <span
                      class="tag-arrow"
                      aria-hidden="true"
                    >
                      →
                    </span>
                  </div>

                  <h2>{tag.name}</h2>

                  <p>
                    Browse all published articles connected
                    with this topic.
                  </p>

                  <div class="tag-footer">
                    <span>
                      {tag.count}
                      {tag.count === 1
                        ? " article"
                        : " articles"}
                    </span>

                    <strong>View topic</strong>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <h2>No tags found</h2>

              <p>
                Tags will appear here after articles are
                published.
              </p>
            </div>
          )
        }
      </div>
    </section>

    <section class="tag-cta">
      <div class="tag-cta-container">
        <div>
          <span>COMPLETE BEGINNER'S GUIDE</span>

          <h2>
            Healthy Weight Loss
            <strong>Made Practical</strong>
          </h2>

          <p>
            Get simple explanations, practical recipes, and
            sustainable advice designed for everyday life.
          </p>
        </div>

        <div class="cta-actions">
          <strong>$19.99</strong>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the Ebook
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .tag-page {
    background: #ffffff;
  }

  .tag-hero {
    padding: 92px 0 100px;
    background:
      radial-gradient(
        circle at top left,
        rgba(34, 197, 94, 0.14),
        transparent 36%
      ),
      linear-gradient(
        180deg,
        #f0fdf4 0%,
        #ffffff 100%
      );
  }

  .tag-hero-container {
    width: min(900px, calc(100% - 40px));
    margin: 0 auto;
    text-align: center;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    margin-bottom: 32px;
    color: #94a3b8;
    font-size: 14px;
    flex-wrap: wrap;
  }

  .breadcrumbs a {
    color: #64748b;
    font-weight: 700;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #16a34a;
  }

  .page-label {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    background: #dcfce7;
    color: #15803d;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  .tag-hero h1 {
    margin: 24px 0 0;
    color: #0f172a;
    font-size: clamp(44px, 7vw, 72px);
    line-height: 1.03;
    letter-spacing: -0.05em;
  }

  .tag-hero h1 span {
    display: block;
    color: #22c55e;
  }

  .tag-hero p {
    max-width: 700px;
    margin: 26px auto 0;
    color: #64748b;
    font-size: 19px;
    line-height: 1.75;
  }

  .tag-section {
    padding: 100px 0 120px;
  }

  .tag-container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .section-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 42px;
  }

  .section-heading div > span {
    color: #16a34a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .section-heading h2 {
    margin: 10px 0 0;
    color: #0f172a;
    font-size: clamp(34px, 5vw, 48px);
    letter-spacing: -0.04em;
  }

  .section-heading > p {
    margin: 0;
    color: #94a3b8;
    font-weight: 700;
  }

  .tag-grid {
    display: grid;
    grid-template-columns:
      repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .tag-card {
    position: relative;
    display: flex;
    min-height: 310px;
    padding: 30px;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    box-shadow:
      0 22px 50px
      rgba(15, 23, 42, 0.07);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .tag-card::before {
    content: "";
    position: absolute;
    top: -60px;
    right: -60px;
    width: 170px;
    height: 170px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.08);
  }

  .tag-card:hover {
    transform: translateY(-8px);
    border-color: rgba(34, 197, 94, 0.4);
    box-shadow:
      0 30px 66px
      rgba(15, 23, 42, 0.11);
  }

  .tag-card-top {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .tag-number {
    color: rgba(15, 23, 42, 0.13);
    font-size: 42px;
    font-weight: 900;
    line-height: 1;
  }

  .tag-arrow {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f0fdf4;
    color: #16a34a;
    font-size: 19px;
    font-weight: 900;
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .tag-card:hover .tag-arrow {
    transform: translateX(4px);
    background: #22c55e;
    color: #ffffff;
  }

  .tag-card h2 {
    position: relative;
    z-index: 1;
    margin: 36px 0 14px;
    color: #0f172a;
    font-size: 27px;
    line-height: 1.25;
    letter-spacing: -0.03em;
    transition: color 0.2s ease;
  }

  .tag-card:hover h2 {
    color: #16a34a;
  }

  .tag-card > p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: #64748b;
    font-size: 15px;
    line-height: 1.7;
  }

  .tag-footer {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: auto;
    padding-top: 28px;
  }

  .tag-footer span {
    color: #94a3b8;
    font-size: 13px;
    font-weight: 700;
  }

  .tag-footer strong {
    color: #16a34a;
    font-size: 13px;
    font-weight: 900;
  }

  .empty-state {
    padding: 50px;
    border-radius: 24px;
    background: #f8fafc;
    text-align: center;
  }

  .empty-state h2 {
    margin: 0 0 10px;
    color: #0f172a;
  }

  .empty-state p {
    margin: 0;
    color: #64748b;
  }

  .tag-cta {
    padding: 82px 0;
    background: #0f172a;
  }

  .tag-cta-container {
    display: grid;
    width: min(1040px, calc(100% - 40px));
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 70px;
    margin: 0 auto;
  }

  .tag-cta-container > div > span {
    color: #4ade80;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .tag-cta h2 {
    margin: 15px 0;
    color: #ffffff;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .tag-cta h2 strong {
    display: block;
    color: #4ade80;
  }

  .tag-cta p {
    max-width: 650px;
    margin: 0;
    color: #cbd5e1;
    font-size: 17px;
    line-height: 1.7;
  }

  .cta-actions {
    min-width: 230px;
    padding: 28px;
    border-radius: 22px;
    background: #ffffff;
    text-align: center;
  }

  .cta-actions > strong {
    display: block;
    margin-bottom: 18px;
    color: #0f172a;
    font-size: 34px;
  }

  .cta-actions a {
    display: flex;
    min-height: 52px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 0 17px;
    border-radius: 13px;
    background: #22c55e;
    color: #ffffff;
    font-weight: 900;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .cta-actions a:hover {
    background: #16a34a;
  }

  @media (max-width: 940px) {
    .tag-grid {
      grid-template-columns:
        repeat(2, minmax(0, 1fr));
    }

    .tag-cta-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .cta-actions {
      width: 100%;
      max-width: 500px;
    }
  }

  @media (max-width: 650px) {
    .tag-hero {
      padding: 72px 0;
    }

    .tag-hero-container,
    .tag-container,
    .tag-cta-container {
      width: min(100% - 24px, 1180px);
    }

    .tag-section {
      padding: 76px 0 90px;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .tag-grid {
      grid-template-columns: 1fr;
    }

    .tag-card {
      min-height: 290px;
      padding: 24px;
      border-radius: 20px;
    }

    .tag-cta {
      padding: 68px 0;
    }
  }
</style>