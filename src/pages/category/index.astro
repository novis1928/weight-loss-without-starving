---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

import { getCollection } from "astro:content";
import { slugify } from "../../utils/slugify";

const baseURL = import.meta.env.BASE_URL;

const posts = await getCollection(
  "blog",
  ({ data }) => !data.draft
);

const categoryMap = new Map<
  string,
  {
    name: string;
    count: number;
  }
>();

for (const post of posts) {
  const category = post.data.category;
  const categorySlug = slugify(category);

  const existingCategory = categoryMap.get(categorySlug);

  if (existingCategory) {
    existingCategory.count += 1;
  } else {
    categoryMap.set(categorySlug, {
      name: category,
      count: 1,
    });
  }
}

const categories = Array.from(categoryMap.entries())
  .map(([slug, category]) => ({
    slug,
    ...category,
  }))
  .sort((a, b) => {
    if (b.count !== a.count) {
      return b.count - a.count;
    }

    return a.name.localeCompare(b.name);
  });
---

<Layout
  title="Weight Loss Categories | Browse All Topics"
  description="Browse all weight loss blog categories, including nutrition, healthy habits, exercise, motivation, and beginner weight loss advice."
>
  <Header />

  <main class="categories-page">
    <section class="categories-hero">
      <div class="categories-hero-container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={baseURL}>Home</a>

          <span>/</span>

          <span aria-current="page">
            Categories
          </span>
        </nav>

        <span class="page-label">
          EXPLORE THE BLOG
        </span>

        <h1>
          Browse All
          <span>Categories</span>
        </h1>

        <p>
          Find practical weight loss articles organized by
          subject, from nutrition and healthy habits to exercise,
          motivation, and sustainable lifestyle changes.
        </p>
      </div>
    </section>

    <section class="categories-section">
      <div class="categories-container">
        <div class="section-heading">
          <div>
            <span>ALL CATEGORIES</span>

            <h2>
              Choose a Topic
            </h2>
          </div>

          <p>
            {categories.length}
            {
              categories.length === 1
                ? " category"
                : " categories"
            }
          </p>
        </div>

        {
          categories.length > 0 ? (
            <div class="categories-grid">
              {categories.map((category, index) => (
                <a
                  class="category-card"
                  href={`${baseURL}category/${category.slug}/`}
                >
                  <div class="category-card-top">
                    <span class="category-number">
                      {String(index + 1).padStart(2, "0")}
                    </span>

                    <span
                      class="category-arrow"
                      aria-hidden="true"
                    >
                      →
                    </span>
                  </div>

                  <h2>
                    {category.name}
                  </h2>

                  <p>
                    Browse all practical articles published in
                    this category.
                  </p>

                  <div class="category-footer">
                    <span>
                      {category.count}
                      {
                        category.count === 1
                          ? " article"
                          : " articles"
                      }
                    </span>

                    <strong>
                      View category
                    </strong>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <h2>No categories found</h2>

              <p>
                Categories will appear here after articles are
                published.
              </p>
            </div>
          )
        }
      </div>
    </section>

    <section class="categories-cta">
      <div class="categories-cta-container">
        <div>
          <span>COMPLETE BEGINNER'S GUIDE</span>

          <h2>
            Healthy Weight Loss
            <strong>in One Practical Ebook</strong>
          </h2>

          <p>
            Get 68 practical pages, simple recipes, clear
            explanations, and sustainable advice designed for
            everyday life.
          </p>
        </div>

        <div class="cta-actions">
          <strong>$19.99</strong>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the Ebook
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .categories-page {
    background: #ffffff;
  }

  .categories-hero {
    padding: 92px 0 100px;
    background:
      radial-gradient(
        circle at top left,
        rgba(34, 197, 94, 0.14),
        transparent 36%
      ),
      linear-gradient(
        180deg,
        #f0fdf4 0%,
        #ffffff 100%
      );
  }

  .categories-hero-container {
    width: min(900px, calc(100% - 40px));
    margin: 0 auto;
    text-align: center;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    margin-bottom: 32px;
    color: #94a3b8;
    font-size: 14px;
    flex-wrap: wrap;
  }

  .breadcrumbs a {
    color: #64748b;
    font-weight: 700;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #16a34a;
  }

  .page-label {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    background: #dcfce7;
    color: #15803d;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  .categories-hero h1 {
    margin: 24px 0 0;
    color: #0f172a;
    font-size: clamp(44px, 7vw, 72px);
    line-height: 1.03;
    letter-spacing: -0.05em;
  }

  .categories-hero h1 span {
    display: block;
    color: #22c55e;
  }

  .categories-hero p {
    max-width: 700px;
    margin: 26px auto 0;
    color: #64748b;
    font-size: 19px;
    line-height: 1.75;
  }

  .categories-section {
    padding: 100px 0 120px;
  }

  .categories-container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .section-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 42px;
  }

  .section-heading span {
    color: #16a34a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .section-heading h2 {
    margin: 10px 0 0;
    color: #0f172a;
    font-size: clamp(34px, 5vw, 48px);
    letter-spacing: -0.04em;
  }

  .section-heading > p {
    margin: 0;
    color: #94a3b8;
    font-weight: 700;
  }

  .categories-grid {
    display: grid;
    grid-template-columns:
      repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .category-card {
    position: relative;
    display: flex;
    min-height: 310px;
    padding: 30px;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    box-shadow:
      0 22px 50px
      rgba(15, 23, 42, 0.07);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .category-card::before {
    content: "";
    position: absolute;
    top: -60px;
    right: -60px;
    width: 170px;
    height: 170px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.08);
  }

  .category-card:hover {
    transform: translateY(-8px);
    border-color: rgba(34, 197, 94, 0.4);
    box-shadow:
      0 30px 66px
      rgba(15, 23, 42, 0.11);
  }

  .category-card-top {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .category-number {
    color: rgba(15, 23, 42, 0.13);
    font-size: 42px;
    font-weight: 900;
    line-height: 1;
  }

  .category-arrow {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f0fdf4;
    color: #16a34a;
    font-size: 19px;
    font-weight: 900;
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .category-card:hover .category-arrow {
    transform: translateX(4px);
    background: #22c55e;
    color: #ffffff;
  }

  .category-card h2 {
    position: relative;
    z-index: 1;
    margin: 36px 0 14px;
    color: #0f172a;
    font-size: 27px;
    line-height: 1.25;
    letter-spacing: -0.03em;
    transition: color 0.2s ease;
  }

  .category-card:hover h2 {
    color: #16a34a;
  }

  .category-card > p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: #64748b;
    font-size: 15px;
    line-height: 1.7;
  }

  .category-footer {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: auto;
    padding-top: 28px;
  }

  .category-footer span {
    color: #94a3b8;
    font-size: 13px;
    font-weight: 700;
  }

  .category-footer strong {
    color: #16a34a;
    font-size: 13px;
    font-weight: 900;
  }

  .empty-state {
    padding: 50px;
    border-radius: 24px;
    background: #f8fafc;
    text-align: center;
  }

  .empty-state h2 {
    margin: 0 0 10px;
    color: #0f172a;
  }

  .empty-state p {
    margin: 0;
    color: #64748b;
  }

  .categories-cta {
    padding: 82px 0;
    background: #0f172a;
  }

  .categories-cta-container {
    display: grid;
    width: min(1040px, calc(100% - 40px));
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 70px;
    margin: 0 auto;
  }

  .categories-cta-container > div > span {
    color: #4ade80;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .categories-cta h2 {
    margin: 15px 0;
    color: #ffffff;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .categories-cta h2 strong {
    display: block;
    color: #4ade80;
  }

  .categories-cta p {
    max-width: 650px;
    margin: 0;
    color: #cbd5e1;
    font-size: 17px;
    line-height: 1.7;
  }

  .cta-actions {
    min-width: 230px;
    padding: 28px;
    border-radius: 22px;
    background: #ffffff;
    text-align: center;
  }

  .cta-actions > strong {
    display: block;
    margin-bottom: 18px;
    color: #0f172a;
    font-size: 34px;
  }

  .cta-actions a {
    display: flex;
    min-height: 52px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 0 17px;
    border-radius: 13px;
    background: #22c55e;
    color: #ffffff;
    font-weight: 900;
    text-decoration: none;
  }

  .cta-actions a:hover {
    background: #16a34a;
  }

  @media (max-width: 940px) {
    .categories-grid {
      grid-template-columns:
        repeat(2, minmax(0, 1fr));
    }

    .categories-cta-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .cta-actions {
      width: 100%;
      max-width: 500px;
    }
  }

  @media (max-width: 650px) {
    .categories-hero {
      padding: 72px 0;
    }

    .categories-hero-container,
    .categories-container,
    .categories-cta-container {
      width: min(100% - 24px, 1180px);
    }

    .categories-section {
      padding: 76px 0 90px;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }

    .category-card {
      min-height: 290px;
      padding: 24px;
      border-radius: 20px;
    }

    .categories-cta {
      padding: 68px 0;
    }
  }
</style>