---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { slugify } from "../../utils/slugify";

import { getCollection } from "astro:content";

const rawBaseURL = import.meta.env.BASE_URL;

const baseURL = rawBaseURL.endsWith("/")
  ? rawBaseURL
  : `${rawBaseURL}/`;

export async function getStaticPaths() {
  const slugify = (value: string) =>
    value
      .toLowerCase()
      .trim()
      .replace(/&/g, "and")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");

  const posts = await getCollection(
    "blog",
    ({ data }) => !data.draft
  );

  const categories = [
    ...new Set(posts.map((post) => post.data.category)),
  ];

  return categories.map((category) => ({
    params: {
      category: slugify(category),
    },
    props: {
      category,
      posts: posts
        .filter((post) => post.data.category === category)
        .sort(
          (a, b) =>
            b.data.publishDate.getTime() -
            a.data.publishDate.getTime()
        ),
    },
  }));
}

const { category, posts } = Astro.props;

const formattedDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<Layout
  title={`${category} Articles | Weight Loss Without Starving`}
  description={`Browse practical ${category.toLowerCase()} articles about healthy, realistic, and sustainable weight loss.`}
>

  <main class="category-page">
    <section class="category-hero">
      <div class="category-hero-container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={baseURL}>Home</a>
          <span>/</span>
          <a href={`${baseURL}blog/`}>Blog</a>
          <span>/</span>
          <span>{category}</span>
        </nav>

        <span class="category-label">ARTICLE CATEGORY</span>

        <h1>{category}</h1>

        <p>
          Explore practical, beginner-friendly articles designed to help
          you build healthier habits and make sustainable progress.
        </p>

        <div class="article-count">
          {posts.length}
          {posts.length === 1 ? " article" : " articles"}
        </div>
      </div>
    </section>

    <section class="articles-section">
      <div class="articles-container">
        <div class="articles-grid">
          {posts.map((post) => (
            <article class="article-card">
              <a
                class="article-link"
                href={`${baseURL}blog/${post.id}/`}
              >
                <div class="article-top">
                  <span class="article-category">
                    {post.data.category}
                  </span>

                  <span class="article-arrow" aria-hidden="true">
                    →
                  </span>
                </div>

                <h2>{post.data.title}</h2>

                <p>{post.data.description}</p>

                <div class="article-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>

                <div class="article-footer">
                  <div class="article-meta">
                    <span>
                      {formattedDate(post.data.publishDate)}
                    </span>
                    <span>•</span>
                    <span>{post.data.readingTime}</span>
                  </div>

                  <span class="read-more">
                    Read article
                    <span aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

</Layout>

<style>
  .category-page {
    background: #ffffff;
  }

  .category-hero {
    padding: 86px 0 92px;
    background:
      radial-gradient(
        circle at top left,
        rgba(34, 197, 94, 0.14),
        transparent 36%
      ),
      linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%);
  }

  .category-hero-container {
    width: min(900px, calc(100% - 40px));
    margin: 0 auto;
    text-align: center;
  }

  .breadcrumbs {
    display: flex;
    justify-content: center;
    gap: 9px;
    margin-bottom: 30px;
    flex-wrap: wrap;
    color: #94a3b8;
    font-size: 13px;
    font-weight: 700;
  }

  .breadcrumbs a {
    color: #64748b;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #16a34a;
  }

  .category-label {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    background: #dcfce7;
    color: #15803d;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  .category-hero h1 {
    margin: 22px 0 0;
    color: #0f172a;
    font-size: clamp(44px, 7vw, 70px);
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .category-hero p {
    max-width: 680px;
    margin: 24px auto 0;
    color: #64748b;
    font-size: 18px;
    line-height: 1.75;
  }

  .article-count {
    display: inline-flex;
    margin-top: 24px;
    padding: 9px 14px;
    border-radius: 999px;
    background: #ffffff;
    color: #15803d;
    font-size: 13px;
    font-weight: 800;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
  }

  .articles-section {
    padding: 80px 0 110px;
  }

  .articles-container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .article-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.07);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .article-card:hover {
    transform: translateY(-7px);
    border-color: rgba(34, 197, 94, 0.5);
    box-shadow: 0 28px 58px rgba(15, 23, 42, 0.11);
  }

  .article-link {
    display: flex;
    min-height: 410px;
    padding: 30px;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
  }

  .article-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .article-category {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    background: #ecfdf3;
    color: #15803d;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .article-arrow {
    display: inline-flex;
    width: 34px;
    height: 34px;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f0fdf4;
    color: #16a34a;
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .article-card:hover .article-arrow {
    transform: translateX(3px);
    background: #22c55e;
    color: #ffffff;
  }

  .article-card h2 {
    margin: 30px 0 15px;
    color: #0f172a;
    font-size: 24px;
    line-height: 1.3;
    letter-spacing: -0.025em;
  }

  .article-card p {
    margin: 0;
    color: #64748b;
    font-size: 15px;
    line-height: 1.75;
  }

  .article-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 22px;
  }

  .article-tags span {
    padding: 6px 9px;
    border-radius: 999px;
    background: #f8fafc;
    color: #64748b;
    font-size: 11px;
    font-weight: 700;
  }

  .article-footer {
    display: grid;
    gap: 14px;
    margin-top: auto;
    padding-top: 27px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
    color: #94a3b8;
    font-size: 12px;
    font-weight: 700;
  }

  .read-more {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 8px;
    color: #16a34a;
    font-size: 13px;
    font-weight: 900;
  }

  .article-card:hover .read-more {
    text-decoration: underline;
  }

  @media (max-width: 940px) {
    .articles-grid {
      grid-template-columns: 1fr;
      max-width: 720px;
      margin: 0 auto;
    }

    .article-link {
      min-height: 350px;
    }
  }

  @media (max-width: 620px) {
    .category-hero {
      padding: 70px 0 76px;
    }

    .category-hero-container,
    .articles-container {
      width: min(100% - 24px, 1180px);
    }

    .articles-section {
      padding: 66px 0 86px;
    }

    .article-link {
      min-height: 360px;
      padding: 24px;
    }

    .article-card h2 {
      margin-top: 24px;
      font-size: 21px;
    }
  }
</style>