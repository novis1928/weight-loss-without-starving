---
import "../styles/global.css";

import Layout from "../layouts/Layout.astro";

import Hero from "../components/Hero.astro";
import Benefits from "../components/Benefits.astro";
import WhatsInside from "../components/WhatsInside.astro";
import PeekInside from "../components/PeekInside.astro";
import ToolsPreview from "../components/ToolsPreview.astro";
import BlogSection from "../components/BlogSection.astro";
import WhoIsItFor from "../components/WhoIsItFor.astro";
import AboutSection from "../components/AboutSection.astro";
import Testimonials from "../components/Testimonials.astro";
import PurchaseCTA from "../components/PurchaseCTA.astro";
import FAQ from "../components/FAQ.astro";
import ContactSection from "../components/ContactSection.astro";

const pageTitle =
  "Weight Loss Without Starving | Practical Weight Loss Ebook";

const pageDescription =
  "Learn how to lose weight in a healthy and sustainable way without extreme diets or constant hunger. Explore 8 free health and nutrition calculators, practical guidance, simple recipes, and sustainable weight-loss strategies.";

const canonicalURL =
  "https://novis1928.github.io/weight-loss-without-starving/";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
>
  <main>
    <Hero />

    <Benefits />

    <WhatsInside />

    <PeekInside />

    <ToolsPreview />

    <BlogSection />

    <WhoIsItFor />

    <AboutSection />

    <Testimonials />

    <PurchaseCTA />

    <FAQ />

    <ContactSection />
  </main>
</Layout>