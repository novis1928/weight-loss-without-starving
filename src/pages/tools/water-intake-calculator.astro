---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;

const pageTitle = 'Water Intake Calculator | Daily Hydration Estimate';
const pageDescription = 'Use our free Water Intake Calculator to estimate a practical daily hydration target based on body weight, activity, and climate.';
const canonicalURL = new URL(`${baseURL}tools/water-intake-calculator/`, Astro.site).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: 'Water Intake Calculator',
      url: canonicalURL,
      applicationCategory: "HealthApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript",
      description: pageDescription,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: 'How much water should I drink?',
          acceptedAnswer: { "@type": "Answer", text: 'Needs vary with body size, activity, climate, diet, pregnancy, health, and other factors.' },
        },
        {
          "@type": "Question",
          name: 'Does food count toward water intake?',
          acceptedAnswer: { "@type": "Answer", text: 'Yes. Total water includes drinking water, other beverages, and moisture from food.' },
        },
        {
          "@type": "Question",
          name: 'Can I drink too much water?',
          acceptedAnswer: { "@type": "Answer", text: 'Yes. Excessive fluid intake can be harmful, especially over a short period.' },
        }
      ],
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <main class="calculator-page">
    <section class="hero"><div class="page-container"><nav class="breadcrumbs" aria-label="Breadcrumb"><a href={baseURL}>Home</a><span>/</span><a href={`${baseURL}tools/`}>Tools</a><span>/</span><span>Water Intake Calculator</span></nav><div class="hero-content"><span class="eyebrow">FREE HYDRATION TOOL</span><h1>Water Intake Calculator</h1><p>Estimate a practical starting target for daily fluids based on body weight, exercise time, and climate.</p><div class="badges"><span>Daily fluid estimate</span><span>Exercise adjustment</span><span>Climate adjustment</span><span>Metric and imperial</span></div></div></div></section>

    <section class="calculator-section"><div class="page-container"><div class="calculator-layout">
      <div class="calculator-card"><div class="card-heading"><div><span class="eyebrow">STEP 1</span><h2>Enter your information</h2></div><div class="calculator-icon">💧</div></div>
        <form id="water-form" novalidate>
          <fieldset class="form-group"><legend>Unit system</legend><div class="toggle-grid"><label><input type="radio" name="unit" value="metric" checked /><span>Metric</span></label><label><input type="radio" name="unit" value="imperial" /><span>Imperial</span></label></div></fieldset>
          <div id="metric-weight" class="form-group"><label for="weight-kg">Weight</label><div class="input-with-unit"><input id="weight-kg" type="number" min="35" max="300" step="0.1" value="75" /><span>kg</span></div></div>
          <div id="imperial-weight" class="form-group" hidden><label for="weight-lb">Weight</label><div class="input-with-unit"><input id="weight-lb" type="number" min="77" max="661" step="0.1" value="165" /><span>lb</span></div></div>
          <div class="field-grid"><div class="form-group"><label for="exercise">Daily exercise</label><div class="input-with-unit"><input id="exercise" type="number" min="0" max="300" step="5" value="30" /><span>min</span></div></div><div class="form-group"><label for="climate">Climate</label><select id="climate"><option value="0" selected>Temperate / mostly indoors</option><option value="350">Warm or humid</option><option value="600">Very hot / prolonged outdoor time</option></select></div></div>
          <div class="form-group"><label for="special">Additional situation</label><select id="special"><option value="0" selected>None</option><option value="300">Pregnancy</option><option value="700">Breastfeeding</option></select></div>
          <div id="form-error" class="form-error" role="alert" hidden></div><button class="calculate-button" type="submit"><span>Calculate hydration target</span><span>→</span></button>
        </form><p class="privacy-note">Your information is processed only in your browser and is not stored.</p>
      </div>
      <aside class="info-card"><span class="info-label">WHAT YOU WILL GET</span><h2>A practical hydration starting point</h2><p>The calculator uses a body-weight estimate and adds modest adjustments for exercise, climate, and selected circumstances.</p><ul><li><span>✓</span> Total water estimate</li><li><span>✓</span> Approximate beverage target</li><li><span>✓</span> Glasses and bottle equivalents</li><li><span>✓</span> Safety reminders</li></ul><div class="warning-box"><strong>Important</strong><p>People with heart, kidney, liver, or fluid-balance conditions should follow their clinician’s fluid guidance rather than a general calculator.</p></div></aside>
    </div>

    <section id="results" class="results-section" aria-live="polite" hidden><div class="results-heading"><div><span class="eyebrow">YOUR RESULTS</span><h2>Estimated daily hydration target</h2><p id="results-summary">A practical estimate, not a medical prescription.</p></div><button id="recalculate-button" type="button">Edit information</button></div>
      <div class="primary-result"><div><span>ESTIMATED TOTAL WATER</span><div class="result-value"><strong id="liters-result">—</strong><small>liters/day</small></div><p>This includes water from beverages and moisture in food.</p></div><div class="result-side"><span>FROM BEVERAGES</span><strong id="beverage-result">— L</strong><small>Approximate starting point</small></div></div>
      <div class="result-grid"><article class="result-card"><span>250 ML GLASSES</span><h3><strong id="glasses-result">—</strong> glasses</h3><p>Approximate beverage portion.</p></article><article class="result-card"><span>750 ML BOTTLES</span><h3><strong id="bottles-result">—</strong> bottles</h3><p>Approximate beverage portion.</p></article><article class="result-card"><span>EXTRA FOR ACTIVITY</span><h3><strong id="activity-extra">—</strong> ml</h3><p>Added from reported exercise time.</p></article></div>
      <div id="high-water-warning" class="result-warning" hidden><strong>Your estimate is high.</strong><p>Do not force large amounts of water quickly. Heavy sweating may also require sodium and other electrolytes, and individual medical advice can override general estimates.</p></div>
    </section></div></section>

    <section class="content-section shaded"><div class="content-container"><div class="section-heading"><span class="eyebrow">HYDRATION BASICS</span><h2>What affects fluid needs?</h2></div><div class="content-grid"><article><div>🏃</div><h3>Exercise and sweat</h3><p>Longer or harder activity usually increases fluid losses.</p></article><article><div>☀️</div><h3>Heat and humidity</h3><p>Warm conditions can increase sweating even at lower exercise intensity.</p></article><article><div>🥣</div><h3>Food and beverages</h3><p>Soup, fruit, vegetables, milk, tea, and other drinks all contribute water.</p></article></div></div></section>

    <section class="content-section"><div class="content-container narrow"><div class="section-heading"><span class="eyebrow">HOW IT WORKS</span><h2>How the hydration estimate is calculated</h2></div><div class="steps"><article><span>01</span><div><h3>Start with body weight</h3><p>The calculator begins with 35 milliliters per kilogram as a simple adult starting estimate.</p></div></article><article><span>02</span><div><h3>Add activity fluid</h3><p>Exercise adds 12 milliliters per reported minute, capped to keep the general estimate reasonable.</p></div></article><article><span>03</span><div><h3>Add climate and situation</h3><p>Modest preset amounts are added for warmer conditions, pregnancy, or breastfeeding.</p></div></article><article><span>04</span><div><h3>Separate total water and beverages</h3><p>The page estimates that roughly 80% may come from beverages, with the rest coming from food.</p></div></article></div></div></section>

    <section class="content-section shaded"><div class="page-container"><div class="section-heading"><span class="eyebrow">RELATED TOOLS</span><h2>Explore our other free calculators</h2></div>
        <div class="related-grid">
          <a href={`${baseURL}tools/bmi-calculator/`}><span>⚖️</span><div><h3>BMI Calculator</h3><p>Calculate BMI and view a healthy weight range.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/calorie-calculator/`}><span>🔥</span><div><h3>Calorie Calculator</h3><p>Estimate daily calories for maintenance or weight change.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/macro-calculator/`}><span>🥗</span><div><h3>Macro Calculator</h3><p>Estimate protein, carbohydrate, and fat targets.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/body-fat-calculator/`}><span>📏</span><div><h3>Body Fat Calculator</h3><p>Estimate body fat using circumference measurements.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/ideal-weight-calculator/`}><span>🎯</span><div><h3>Ideal Weight Calculator</h3><p>Compare four commonly used ideal-weight formulas.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/tdee-calculator/`}><span>📊</span><div><h3>TDEE Calculator</h3><p>Estimate total daily calorie expenditure.</p><strong>Open calculator →</strong></div></a>
        </div>
</div></section>

    <section class="content-section"><div class="content-container narrow"><div class="section-heading"><span class="eyebrow">COMMON QUESTIONS</span><h2>Water Intake Calculator FAQ</h2></div><div class="faq-list"><details><summary>Does coffee or tea count?</summary><p>Most non-alcoholic beverages contribute to fluid intake. Water remains a simple low-calorie choice.</p></details><details><summary>Does food count toward hydration?</summary><p>Yes. Total water includes moisture from foods as well as beverages.</p></details><details><summary>How can I tell whether I am hydrated?</summary><p>Thirst, urine color, exercise conditions, and individual medical guidance can all help. Pale yellow urine is a common general sign, but it is not a diagnostic test.</p></details><details><summary>Can drinking too much be dangerous?</summary><p>Yes. Excessive intake over a short period can dilute blood sodium. Do not force fluids beyond thirst or medical guidance.</p></details><details><summary>Who should not use a general target?</summary><p>People with heart, kidney, liver, endocrine, or fluid-balance conditions should follow individualized professional advice.</p></details></div></div></section>

    <section class="ebook-cta"><div class="page-container"><div class="ebook-card"><div><span class="eyebrow">BUILD BETTER HABITS</span><h2>Make healthy choices easier to repeat</h2><p>Discover practical nutrition, meal-planning, and sustainable weight-loss guidance.</p></div><a href={`${baseURL}#purchase`}>Discover the ebook →</a></div></div></section>
  </main>

  <script is:inline>
    (() => {
      const form = document.getElementById("water-form"), metricWeight = document.getElementById("metric-weight"), imperialWeight = document.getElementById("imperial-weight"), errorBox = document.getElementById("form-error"), results = document.getElementById("results"), warning = document.getElementById("high-water-warning");
      if (!form || !metricWeight || !imperialWeight || !errorBox || !results) return;
      const selected = (name) => form.querySelector(`input[name="${name}"]:checked`)?.value || "";
      const num = (id) => Number.parseFloat(document.getElementById(id)?.value || "");
      const text = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value; };
      const showError = (message) => { errorBox.textContent = message; errorBox.hidden = false; };
      const clearError = () => { errorBox.textContent = ""; errorBox.hidden = true; };
      const updateUnits = () => { const metric = selected("unit") === "metric"; metricWeight.hidden = !metric; imperialWeight.hidden = metric; clearError(); };
      form.querySelectorAll('input[name="unit"]').forEach((input) => input.addEventListener("change", updateUnits));
      form.addEventListener("submit", (event) => {
        event.preventDefault(); clearError();
        const unit = selected("unit"), exercise = num("exercise"), climate = num("climate"), special = num("special");
        if (!Number.isFinite(exercise) || exercise < 0 || exercise > 300) return showError("Please enter exercise time between 0 and 300 minutes.");
        let weightKg;
        if (unit === "metric") { weightKg = num("weight-kg"); if (!Number.isFinite(weightKg) || weightKg < 35 || weightKg > 300) return showError("Please enter a weight between 35 and 300 kg."); }
        else { const pounds = num("weight-lb"); if (!Number.isFinite(pounds) || pounds < 77 || pounds > 661) return showError("Please enter a weight between 77 and 661 lb."); weightKg = pounds * .45359237; }
        const exerciseExtra = Math.min(exercise * 12, 1800);
        const totalMl = weightKg * 35 + exerciseExtra + climate + special;
        const beverageMl = totalMl * .8;
        text("liters-result", (totalMl / 1000).toFixed(1)); text("beverage-result", `${(beverageMl / 1000).toFixed(1)} L`); text("glasses-result", Math.round(beverageMl / 250)); text("bottles-result", (beverageMl / 750).toFixed(1)); text("activity-extra", Math.round(exerciseExtra)); text("results-summary", "Includes a weight-based starting estimate plus the selected adjustments.");
        if (warning) warning.hidden = totalMl < 4500;
        results.hidden = false; results.scrollIntoView({ behavior:"smooth", block:"start" });
      });
      document.getElementById("recalculate-button")?.addEventListener("click", () => form.scrollIntoView({ behavior:"smooth", block:"start" }));
      updateUnits();
    })();
  </script>

<style>
  :global(*) { box-sizing:border-box; }
  :global(html) { scroll-behavior:smooth; }
  .calculator-page { color:#0f172a; background:#fff; }
  .page-container { width:min(100% - 40px,1160px); margin:0 auto; }
  .content-container { width:min(100% - 40px,1040px); margin:0 auto; }
  .content-container.narrow { max-width:820px; }
  .hero { padding:34px 0 82px; background:radial-gradient(circle at 15% 20%,rgba(34,197,94,.12),transparent 28%),linear-gradient(135deg,#f0fdf4 0%,#f8fafc 60%,#eff6ff 100%); }
  .breadcrumbs { display:flex; flex-wrap:wrap; gap:8px; color:#64748b; font-size:.82rem; }
  .breadcrumbs a { color:#475569; text-decoration:none; }
  .breadcrumbs a:hover { color:#15803d; }
  .hero-content { max-width:810px; margin:62px auto 0; text-align:center; }
  .eyebrow,.info-label { color:#15803d; font-size:.74rem; font-weight:900; letter-spacing:.12em; }
  .hero h1 { margin:13px 0 0; font-size:clamp(3rem,8vw,5.4rem); line-height:.98; letter-spacing:-.065em; }
  .hero-content>p { max-width:700px; margin:22px auto 0; color:#475569; font-size:1.06rem; line-height:1.75; }
  .badges { display:flex; flex-wrap:wrap; justify-content:center; gap:9px; margin-top:25px; }
  .badges span { padding:8px 11px; border:1px solid #bbf7d0; border-radius:999px; color:#166534; background:rgba(255,255,255,.78); font-size:.76rem; font-weight:800; }
  .calculator-section { padding:88px 0 96px; }
  .calculator-layout { display:grid; grid-template-columns:minmax(0,1.5fr) minmax(300px,.75fr); gap:28px; align-items:start; }
  .calculator-card,.info-card { border-radius:26px; box-shadow:0 24px 70px rgba(15,23,42,.1); }
  .calculator-card { padding:34px; border:1px solid #e2e8f0; background:#fff; }
  .card-heading { display:flex; justify-content:space-between; align-items:center; gap:20px; margin-bottom:32px; }
  .card-heading h2,.info-card h2 { margin:8px 0 0; font-size:clamp(1.65rem,4vw,2.25rem); line-height:1.15; letter-spacing:-.04em; }
  .calculator-icon { display:grid; place-items:center; width:64px; height:64px; flex-shrink:0; border-radius:18px; background:#dcfce7; font-size:1.9rem; }
  .form-group { min-width:0; margin:0 0 24px; padding:0; border:0; }
  .form-group>label,.form-group>legend { display:block; margin-bottom:10px; color:#1e293b; font-size:.92rem; font-weight:800; }
  .toggle-grid,.option-grid,.field-grid { display:grid; gap:12px; }
  .toggle-grid,.two-columns,.field-grid { grid-template-columns:repeat(2,1fr); }
  .toggle-grid { padding:5px; border-radius:14px; background:#f1f5f9; }
  .toggle-grid input,.option-card input { position:absolute; opacity:0; pointer-events:none; }
  .toggle-grid span { display:grid; min-height:46px; place-items:center; border-radius:10px; color:#64748b; font-weight:800; cursor:pointer; }
  .toggle-grid input:checked+span { color:#15803d; background:#fff; box-shadow:0 5px 16px rgba(15,23,42,.09); }
  .option-card { cursor:pointer; }
  .option-card>span { display:block; min-height:78px; padding:15px; border:1px solid #e2e8f0; border-radius:15px; }
  .option-card input:checked+span { border-color:#22c55e; background:#f0fdf4; box-shadow:0 0 0 3px rgba(34,197,94,.1); }
  .option-card strong,.option-card small { display:block; }
  .option-card small { margin-top:4px; color:#64748b; font-size:.75rem; }
  .input-with-unit { display:flex; align-items:center; overflow:hidden; border:1px solid #cbd5e1; border-radius:14px; background:#fff; }
  .input-with-unit:focus-within,select:focus { border-color:#22c55e; box-shadow:0 0 0 4px rgba(34,197,94,.11); }
  .input-with-unit input { width:100%; min-width:0; padding:15px 16px; border:0; outline:0; font:inherit; font-weight:700; }
  .input-with-unit span { padding:0 16px; color:#64748b; font-size:.86rem; font-weight:800; }
  select { width:100%; padding:15px 16px; border:1px solid #cbd5e1; border-radius:14px; outline:0; background:#fff; color:#0f172a; font:inherit; font-weight:700; }
  .form-error { margin-bottom:18px; padding:13px 15px; border:1px solid #fecaca; border-radius:12px; background:#fef2f2; color:#b91c1c; font-size:.88rem; font-weight:700; }
  .calculate-button { display:flex; justify-content:space-between; align-items:center; width:100%; min-height:56px; padding:0 20px; border:0; border-radius:14px; background:#22c55e; color:#fff; cursor:pointer; font:inherit; font-weight:800; box-shadow:0 15px 34px rgba(34,197,94,.25); }
  .calculate-button:hover { background:#16a34a; transform:translateY(-2px); }
  .privacy-note { margin:16px 0 0; color:#94a3b8; font-size:.76rem; text-align:center; }
  .info-card { position:sticky; top:100px; padding:30px; color:#fff; background:radial-gradient(circle at top right,rgba(34,197,94,.17),transparent 35%),#0f172a; }
  .info-card .info-label { color:#86efac; }
  .info-card h2 { color:#fff; }
  .info-card>p { margin:15px 0 0; color:#cbd5e1; line-height:1.7; }
  .info-card ul { display:grid; gap:15px; margin:26px 0 0; padding:0; list-style:none; }
  .info-card li { display:flex; gap:11px; color:#e2e8f0; }
  .info-card li span { display:grid; place-items:center; width:22px; height:22px; border-radius:50%; color:#86efac; background:rgba(34,197,94,.18); }
  .warning-box { margin-top:28px; padding:17px; border:1px solid rgba(148,163,184,.22); border-radius:15px; background:rgba(255,255,255,.06); }
  .warning-box p { margin:6px 0 0; color:#cbd5e1; font-size:.82rem; line-height:1.6; }
  .results-section { scroll-margin-top:100px; margin-top:58px; }
  .results-heading { display:flex; justify-content:space-between; align-items:flex-end; gap:22px; margin-bottom:24px; }
  .results-heading h2 { margin:6px 0 0; font-size:clamp(2rem,5vw,3rem); letter-spacing:-.045em; }
  .results-heading p { margin:9px 0 0; color:#64748b; }
  #recalculate-button { padding:11px 15px; border:1px solid #cbd5e1; border-radius:11px; background:#fff; color:#334155; cursor:pointer; font:inherit; font-size:.84rem; font-weight:800; }
  .primary-result { display:grid; grid-template-columns:minmax(0,1.3fr) minmax(240px,.7fr); gap:24px; padding:32px; border-radius:24px; color:#fff; background:radial-gradient(circle at top right,rgba(134,239,172,.17),transparent 35%),#0f172a; box-shadow:0 24px 64px rgba(15,23,42,.16); }
  .primary-result>div>span,.result-side>span { color:#86efac; font-size:.76rem; font-weight:800; letter-spacing:.08em; }
  .result-value { display:flex; align-items:baseline; gap:9px; margin-top:8px; }
  .result-value strong { font-size:clamp(3.3rem,8vw,5.8rem); line-height:1; letter-spacing:-.07em; }
  .result-value small { color:#cbd5e1; font-size:1.25rem; font-weight:700; }
  .primary-result p { margin:14px 0 0; color:#cbd5e1; }
  .result-side { display:flex; flex-direction:column; justify-content:center; padding:24px; border:1px solid rgba(148,163,184,.2); border-radius:18px; background:rgba(255,255,255,.06); }
  .result-side strong { margin-top:10px; font-size:1.35rem; }
  .result-side small { margin-top:8px; color:#94a3b8; }
  .result-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:18px; }
  .result-card { padding:23px; border:1px solid #e2e8f0; border-radius:18px; background:#fff; box-shadow:0 13px 38px rgba(15,23,42,.06); }
  .result-card>span { color:#64748b; font-size:.72rem; font-weight:900; letter-spacing:.08em; }
  .result-card h3 { margin:8px 0 0; font-size:1rem; }
  .result-card h3 strong { font-size:2rem; }
  .result-card p { margin:10px 0 0; color:#64748b; font-size:.82rem; line-height:1.55; }
  .result-warning { margin-top:18px; padding:21px 23px; border:1px solid #fde68a; border-radius:16px; background:#fffbeb; }
  .result-warning strong { color:#92400e; }
  .result-warning p { margin:6px 0 0; color:#78350f; line-height:1.65; }
  .content-section { padding:92px 0; }
  .shaded { background:#f8fafc; }
  .section-heading { max-width:750px; margin:0 auto 42px; text-align:center; }
  .section-heading h2 { margin:10px 0 0; font-size:clamp(2rem,5vw,3.25rem); line-height:1.1; letter-spacing:-.05em; }
  .content-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  .content-grid article { padding:27px; border:1px solid #e2e8f0; border-radius:20px; background:#fff; }
  .content-grid article>div { display:grid; place-items:center; width:50px; height:50px; border-radius:14px; background:#dcfce7; font-size:1.45rem; }
  .content-grid h3 { margin:20px 0 0; }
  .content-grid p { margin:10px 0 0; color:#64748b; line-height:1.7; }
  .steps { display:grid; gap:15px; }
  .steps article { display:flex; gap:20px; padding:23px; border:1px solid #e2e8f0; border-radius:17px; }
  .steps article>span { display:grid; place-items:center; width:42px; height:42px; flex-shrink:0; border-radius:12px; background:#f0fdf4; color:#15803d; font-size:.74rem; font-weight:900; }
  .steps h3 { margin:0; }
  .steps p { margin:7px 0 0; color:#64748b; line-height:1.65; }
  .related-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:20px; }
  .related-grid a { display:flex; gap:18px; padding:24px; border:1px solid #e2e8f0; border-radius:20px; background:#fff; color:inherit; text-decoration:none; box-shadow:0 14px 40px rgba(15,23,42,.06); }
  .related-grid a:hover { border-color:#22c55e; transform:translateY(-4px); }
  .related-grid>a>span { display:grid; place-items:center; width:52px; height:52px; flex-shrink:0; border-radius:15px; background:#dcfce7; font-size:1.45rem; }
  .related-grid h3 { margin:0; font-size:1.05rem; }
  .related-grid p { margin:8px 0 0; color:#64748b; line-height:1.55; font-size:.84rem; }
  .related-grid strong { display:inline-block; margin-top:13px; color:#15803d; font-size:.84rem; }
  .faq-list { display:grid; gap:13px; }
  .faq-list details { border:1px solid #e2e8f0; border-radius:15px; overflow:hidden; background:#fff; }
  .faq-list summary { padding:20px 21px; cursor:pointer; font-weight:800; }
