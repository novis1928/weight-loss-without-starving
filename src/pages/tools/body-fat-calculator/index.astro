---
import Layout from "../../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;

const pageTitle = "Body Fat Calculator | Estimate Your Body Fat Percentage";
const pageDescription =
  "Estimate your body fat percentage with the U.S. Navy circumference method. Supports metric and imperial units and shows estimated fat mass, lean mass, and a simple result category.";

const calculatorSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Body Fat Calculator",
  applicationCategory: "HealthApplication",
  operatingSystem: "Any",
  description: pageDescription,
  url: "https://novis1928.github.io/weight-loss-without-starving/tools/body-fat-calculator/",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How does this body fat calculator work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "It uses circumference measurements and the U.S. Navy body-fat estimation equations. Men enter height, waist and neck measurements. Women also enter hip circumference."
      }
    },
    {
      "@type": "Question",
      name: "Is the result exact?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. Circumference formulas provide an estimate and can differ from measurements obtained with DEXA, air-displacement plethysmography, hydrostatic weighing or professional skinfold testing."
      }
    },
    {
      "@type": "Question",
      name: "Where should I measure my waist and neck?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Measure the neck just below the larynx with the tape slightly angled downward toward the front. Measure the waist horizontally around the abdomen without pulling the tape tightly. Women should measure the hips at the widest point."
      }
    },
    {
      "@type": "Question",
      name: "Can I use this calculator to diagnose a health condition?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. The calculator is for general education only and does not diagnose disease or replace advice from a qualified healthcare professional."
      }
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(calculatorSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main>
    <section class="hero">
      <div class="container hero-content">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={baseURL}>Home</a>
          <span aria-hidden="true">/</span>
          <a href={`${baseURL}tools/`}>Tools</a>
          <span aria-hidden="true">/</span>
          <span>Body Fat Calculator</span>
        </nav>

        <span class="badge">FREE BODY COMPOSITION TOOL</span>

        <h1>Body Fat Calculator</h1>

        <p>
          Estimate your body fat percentage using simple circumference
          measurements. See your estimated fat mass, lean mass and a practical
          interpretation of the result.
        </p>

        <div class="hero-points" aria-label="Calculator benefits">
          <span>✓ Metric and imperial units</span>
          <span>✓ Instant estimate</span>
          <span>✓ No signup required</span>
        </div>
      </div>
    </section>

    <section class="calculator-section">
      <div class="container calculator-layout">
        <div class="calculator-card">
          <div class="card-heading">
            <span class="eyebrow">ENTER YOUR MEASUREMENTS</span>
            <h2>Calculate your estimated body fat</h2>
            <p>
              For the most consistent result, use a flexible tape measure and
              take each measurement twice.
            </p>
          </div>

          <form id="body-fat-form" novalidate>
            <fieldset class="choice-group">
              <legend>Units</legend>

              <div class="segmented-control" role="radiogroup" aria-label="Units">
                <label>
                  <input type="radio" name="units" value="metric" checked />
                  <span>Metric</span>
                </label>

                <label>
                  <input type="radio" name="units" value="imperial" />
                  <span>Imperial</span>
                </label>
              </div>
            </fieldset>

            <fieldset class="choice-group">
              <legend>Sex used by the formula</legend>

              <div class="segmented-control" role="radiogroup" aria-label="Sex">
                <label>
                  <input type="radio" name="sex" value="male" checked />
                  <span>Male</span>
                </label>

                <label>
                  <input type="radio" name="sex" value="female" />
                  <span>Female</span>
                </label>
              </div>

              <p class="field-note">
                The U.S. Navy equations use different circumference formulas
                for males and females.
              </p>
            </fieldset>

            <div class="form-grid">
              <div class="field full-field">
                <label for="age">Age <span class="optional">(optional)</span></label>
                <div class="input-wrap">
                  <input
                    id="age"
                    name="age"
                    type="number"
                    min="18"
                    max="100"
                    step="1"
                    inputmode="numeric"
                    placeholder="For example, 35"
                  />
                  <span class="unit-label">years</span>
                </div>
              </div>

              <div class="field metric-field">
                <label for="height-cm">Height</label>
                <div class="input-wrap">
                  <input
                    id="height-cm"
                    name="heightCm"
                    type="number"
                    min="120"
                    max="230"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 175"
                  />
                  <span class="unit-label">cm</span>
                </div>
              </div>

              <div class="field imperial-field" hidden>
                <label for="height-ft">Height</label>
                <div class="split-inputs">
                  <div class="input-wrap">
                    <input
                      id="height-ft"
                      name="heightFt"
                      type="number"
                      min="3"
                      max="7"
                      step="1"
                      inputmode="numeric"
                      placeholder="5"
                    />
                    <span class="unit-label">ft</span>
                  </div>

                  <div class="input-wrap">
                    <input
                      id="height-in"
                      name="heightIn"
                      type="number"
                      min="0"
                      max="11.9"
                      step="0.1"
                      inputmode="decimal"
                      placeholder="9"
                    />
                    <span class="unit-label">in</span>
                  </div>
                </div>
              </div>

              <div class="field metric-field">
                <label for="weight-kg">
                  Weight <span class="optional">(optional)</span>
                </label>
                <div class="input-wrap">
                  <input
                    id="weight-kg"
                    name="weightKg"
                    type="number"
                    min="30"
                    max="350"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 80"
                  />
                  <span class="unit-label">kg</span>
                </div>
              </div>

              <div class="field imperial-field" hidden>
                <label for="weight-lb">
                  Weight <span class="optional">(optional)</span>
                </label>
                <div class="input-wrap">
                  <input
                    id="weight-lb"
                    name="weightLb"
                    type="number"
                    min="66"
                    max="770"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 176"
                  />
                  <span class="unit-label">lb</span>
                </div>
              </div>

              <div class="field metric-field">
                <label for="neck-cm">Neck circumference</label>
                <div class="input-wrap">
                  <input
                    id="neck-cm"
                    name="neckCm"
                    type="number"
                    min="20"
                    max="70"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 38"
                  />
                  <span class="unit-label">cm</span>
                </div>
                <p class="field-note">Measure just below the larynx.</p>
              </div>

              <div class="field imperial-field" hidden>
                <label for="neck-in">Neck circumference</label>
                <div class="input-wrap">
                  <input
                    id="neck-in"
                    name="neckIn"
                    type="number"
                    min="8"
                    max="28"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 15"
                  />
                  <span class="unit-label">in</span>
                </div>
                <p class="field-note">Measure just below the larynx.</p>
              </div>

              <div class="field metric-field">
                <label for="waist-cm">Waist circumference</label>
                <div class="input-wrap">
                  <input
                    id="waist-cm"
                    name="waistCm"
                    type="number"
                    min="40"
                    max="220"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 90"
                  />
                  <span class="unit-label">cm</span>
                </div>
                <p class="field-note">
                  Measure horizontally around the abdomen without pulling the
                  tape tight.
                </p>
              </div>

              <div class="field imperial-field" hidden>
                <label for="waist-in">Waist circumference</label>
                <div class="input-wrap">
                  <input
                    id="waist-in"
                    name="waistIn"
                    type="number"
                    min="16"
                    max="87"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 35.5"
                  />
                  <span class="unit-label">in</span>
                </div>
                <p class="field-note">
                  Measure horizontally around the abdomen without pulling the
                  tape tight.
                </p>
              </div>

              <div class="field metric-field female-only" hidden>
                <label for="hip-cm">Hip circumference</label>
                <div class="input-wrap">
                  <input
                    id="hip-cm"
                    name="hipCm"
                    type="number"
                    min="50"
                    max="220"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 100"
                  />
                  <span class="unit-label">cm</span>
                </div>
                <p class="field-note">Measure at the widest point of the hips.</p>
              </div>

              <div class="field imperial-field female-only" hidden>
                <label for="hip-in">Hip circumference</label>
                <div class="input-wrap">
                  <input
                    id="hip-in"
                    name="hipIn"
                    type="number"
                    min="20"
                    max="87"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="For example, 39.5"
                  />
                  <span class="unit-label">in</span>
                </div>
                <p class="field-note">Measure at the widest point of the hips.</p>
              </div>
            </div>

            <div id="form-error" class="form-error" role="alert" hidden></div>

            <div class="form-actions">
              <button class="primary-button" type="submit">
                Calculate body fat
              </button>

              <button class="secondary-button" type="reset">
                Reset
              </button>
            </div>
          </form>
        </div>

        <aside class="measurement-card" aria-labelledby="measurement-title">
          <span class="eyebrow">MEASUREMENT GUIDE</span>
          <h2 id="measurement-title">How to measure correctly</h2>

          <div class="measurement-list">
            <article>
              <span aria-hidden="true">1</span>
              <div>
                <h3>Use a flexible tape</h3>
                <p>
                  Keep it flat against the skin or light clothing without
                  compressing the body.
                </p>
              </div>
            </article>

            <article>
              <span aria-hidden="true">2</span>
              <div>
                <h3>Stand naturally</h3>
                <p>
                  Keep your shoulders relaxed and breathe normally. Do not hold
                  your stomach in.
                </p>
              </div>
            </article>

            <article>
              <span aria-hidden="true">3</span>
              <div>
                <h3>Measure consistently</h3>
                <p>
                  Repeat each measurement twice and use the average if the
                  readings differ.
                </p>
              </div>
            </article>

            <article>
              <span aria-hidden="true">4</span>
              <div>
                <h3>Track the trend</h3>
                <p>
                  When monitoring progress, measure at a similar time of day
                  under similar conditions.
                </p>
              </div>
            </article>
          </div>
        </aside>
      </div>
    </section>

    <section id="results-section" class="results-section" hidden aria-live="polite">
      <div class="container">
        <div class="results-card">
          <div class="result-heading">
            <div>
              <span class="eyebrow">YOUR ESTIMATED RESULT</span>
              <h2>Body fat estimate</h2>
            </div>

            <button id="recalculate-button" class="text-button" type="button">
              Edit measurements
            </button>
          </div>

          <div class="result-main">
            <div class="result-score">
              <span id="body-fat-value">—</span>
              <small>% body fat</small>
            </div>

            <div class="result-summary">
              <span id="result-category" class="category-badge">—</span>
              <h3 id="result-title">Your result will appear here</h3>
              <p id="result-explanation">
                Enter your measurements to receive an estimate.
              </p>
            </div>
          </div>

          <div class="scale-wrap">
            <div class="scale-labels" aria-hidden="true">
              <span>Lower</span>
              <span>Typical fitness range</span>
              <span>Higher</span>
            </div>

            <div class="body-fat-scale" aria-hidden="true">
              <span class="scale-part essential"></span>
              <span class="scale-part athletic"></span>
              <span class="scale-part fitness"></span>
              <span class="scale-part average"></span>
              <span class="scale-part high"></span>
              <span id="scale-marker" class="scale-marker"></span>
            </div>

            <p class="scale-note">
              Categories are broad educational reference ranges, not medical
              diagnoses. Appropriate body-fat levels vary with age, genetics,
              health, training and measurement method.
            </p>
          </div>

          <div class="result-details">
            <article>
              <span>Estimated fat mass</span>
              <strong id="fat-mass-value">Add weight to calculate</strong>
            </article>

            <article>
              <span>Estimated lean mass</span>
              <strong id="lean-mass-value">Add weight to calculate</strong>
            </article>

            <article>
              <span>Method</span>
              <strong>U.S. Navy circumference estimate</strong>
            </article>
          </div>

          <div class="result-callout">
            <strong>Remember:</strong>
            <p>
              A single estimate is less useful than a consistent trend. Use the
              same tape placement and measuring conditions when checking again.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="container content-grid">
        <article class="article-content">
          <span class="eyebrow">UNDERSTANDING THE RESULT</span>
          <h2>What body fat percentage means</h2>

          <p>
            Body fat percentage estimates how much of your total body weight is
            fat tissue. The remainder includes muscle, bone, organs, water and
            other lean tissue.
          </p>

          <p>
            Unlike BMI, body fat percentage attempts to describe body
            composition rather than only the relationship between weight and
            height. However, a circumference calculator is still an indirect
            estimate and should not be treated as a precise laboratory
            measurement.
          </p>

          <h3>How the calculator estimates body fat</h3>

          <p>
            This calculator uses sex-specific circumference equations commonly
            known as the U.S. Navy method. For men, the calculation uses height,
            waist and neck circumference. For women, it also uses hip
            circumference.
          </p>

          <p>
            The equations were designed for measurements in inches. Metric
            values are converted internally before the calculation.
          </p>

          <h3>Why your result may differ from another method</h3>

          <p>
            Different methods estimate different physical properties and have
            their own sources of error. Hydration, tape placement, posture,
            recent meals and the person taking the measurement can all influence
            a circumference-based result.
          </p>

          <ul>
            <li>DEXA uses low-dose X-rays to estimate body composition.</li>
            <li>
              Bioelectrical impedance scales estimate composition from
              electrical resistance and are sensitive to hydration.
            </li>
            <li>
              Skinfold measurements depend heavily on technique and the
              prediction equation used.
            </li>
            <li>
              Circumference methods are convenient but rely on body-shape
              assumptions.
            </li>
          </ul>

          <h3>How to use the estimate responsibly</h3>

          <p>
            Avoid making aggressive diet or exercise decisions based on one
            number. Look at several indicators together, such as energy,
            strength, waist trend, eating habits, sleep, medical history and
            advice from qualified professionals.
          </p>
        </article>

        <aside class="reference-card">
          <span class="eyebrow">QUICK REFERENCE</span>
          <h2>General adult categories</h2>

          <div class="reference-table">
            <div class="table-row table-head">
              <span>Category</span>
              <span>Men</span>
              <span>Women</span>
            </div>

            <div class="table-row">
              <strong>Essential fat</strong>
              <span>2–5%</span>
              <span>10–13%</span>
            </div>

            <div class="table-row">
              <strong>Athletic</strong>
              <span>6–13%</span>
              <span>14–20%</span>
            </div>

            <div class="table-row">
              <strong>Fitness</strong>
              <span>14–17%</span>
              <span>21–24%</span>
            </div>

            <div class="table-row">
              <strong>Average</strong>
              <span>18–24%</span>
              <span>25–31%</span>
            </div>

            <div class="table-row">
              <strong>Higher range</strong>
              <span>25%+</span>
              <span>32%+</span>
            </div>
          </div>

          <p>
            These broad categories are educational reference ranges and do not
            account for age, pregnancy, medical conditions or individual
            athletic goals.
          </p>
        </aside>
      </div>
    </section>

    <section class="faq-section">
      <div class="container narrow">
        <div class="section-heading">
          <span class="eyebrow">FREQUENTLY ASKED QUESTIONS</span>
          <h2>Body Fat Calculator FAQ</h2>
        </div>

        <div class="faq-list">
          <details>
            <summary>How accurate is the U.S. Navy body fat method?</summary>
            <p>
              It is a practical estimate, not an exact measurement. Accuracy
              depends on body shape and careful tape placement. The number may
              differ from DEXA, hydrostatic weighing, air displacement,
              bioelectrical impedance or professional skinfold testing.
            </p>
          </details>

          <details>
            <summary>Should I measure my waist before or after eating?</summary>
            <p>
              For progress tracking, consistency matters most. Measuring at a
              similar time of day, under similar conditions and before a large
              meal can reduce day-to-day variation.
            </p>
          </details>

          <details>
            <summary>Why is weight optional?</summary>
            <p>
              The circumference equation does not need body weight to estimate
              body-fat percentage. Weight is only used to estimate fat mass and
              lean mass.
            </p>
          </details>

          <details>
            <summary>Can very muscular people use this calculator?</summary>
            <p>
              Yes, but the result may be less representative for people whose
              body proportions differ substantially from those assumed by the
              equation. A professional body-composition assessment may be more
              useful.
            </p>
          </details>

          <details>
            <summary>How often should I measure?</summary>
            <p>
              Body composition changes gradually. Checking every few weeks
              under consistent conditions is usually more informative than
              measuring every day.
            </p>
          </details>
        </div>
      </div>
    </section>

    <section class="related-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">RELATED FREE TOOLS</span>
          <h2>Continue exploring your health estimates</h2>
        </div>

        <div class="related-grid">
          <a class="related-card" href={`${baseURL}tools/bmi-calculator/`}>
            <div class="related-icon" aria-hidden="true">⚖️</div>
            <span class="tool-status available">Available now</span>
            <h3>BMI Calculator</h3>
            <p>
              Calculate your BMI and estimate a healthy weight range based on
              your height.
            </p>
            <strong>Open calculator →</strong>
          </a>

          <a class="related-card" href={`${baseURL}tools/calorie-calculator/`}>
            <div class="related-icon" aria-hidden="true">🔥</div>
            <span class="tool-status available">Available now</span>
            <h3>Calorie Calculator</h3>
            <p>
              Estimate BMR, TDEE, maintenance calories and goal-based calorie
              targets.
            </p>
            <strong>Open calculator →</strong>
          </a>

          <a
            class="related-card"
            href={`${baseURL}tools/ideal-weight-calculator/`}
          >
            <div class="related-icon" aria-hidden="true">🎯</div>
            <span class="tool-status available">Available now</span>
            <h3>Ideal Weight Calculator</h3>
            <p>
              Compare four common ideal-weight formulas and a healthy BMI-based
              range.
            </p>
            <strong>Open calculator →</strong>
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-card">
          <div>
            <span class="eyebrow">BUILD SUSTAINABLE HABITS</span>
            <h2>Go beyond a single number</h2>
            <p>
              Learn practical strategies for healthy, sustainable weight loss
              without crash diets or unnecessary starvation.
            </p>
          </div>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the eBook
          </a>
        </div>
      </div>
    </section>

    <section class="disclaimer-section">
      <div class="container narrow">
        <p>
          <strong>Health disclaimer:</strong> This calculator provides a general
          educational estimate only. It is not a medical diagnosis and should
          not replace evaluation or advice from a qualified healthcare
          professional. Body-composition estimates may be inappropriate during
          pregnancy, for children, or for some medical conditions.
        </p>
      </div>
    </section>
  </main>
</Layout>

<script>
  const form = document.querySelector("#body-fat-form");
  const resultsSection = document.querySelector("#results-section");
  const formError = document.querySelector("#form-error");
  const recalculateButton = document.querySelector("#recalculate-button");

  const bodyFatValue = document.querySelector("#body-fat-value");
  const resultCategory = document.querySelector("#result-category");
  const resultTitle = document.querySelector("#result-title");
  const resultExplanation = document.querySelector("#result-explanation");
  const fatMassValue = document.querySelector("#fat-mass-value");
  const leanMassValue = document.querySelector("#lean-mass-value");
  const scaleMarker = document.querySelector("#scale-marker");

  const metricFields = document.querySelectorAll(".metric-field");
  const imperialFields = document.querySelectorAll(".imperial-field");
  const femaleOnlyFields = document.querySelectorAll(".female-only");

  const getCheckedValue = (name) => {
    const checked = document.querySelector(`input[name="${name}"]:checked`);
    return checked instanceof HTMLInputElement ? checked.value : "";
  };

  const getNumber = (selector) => {
    const input = document.querySelector(selector);
    if (!(input instanceof HTMLInputElement) || input.value.trim() === "") {
      return null;
    }

    const value = Number(input.value);
    return Number.isFinite(value) ? value : null;
  };

  const setFieldVisibility = () => {
    const units = getCheckedValue("units");
    const sex = getCheckedValue("sex");
    const isMetric = units === "metric";
    const isFemale = sex === "female";

    metricFields.forEach((field) => {
      if (!(field instanceof HTMLElement)) return;
      const isFemaleField = field.classList.contains("female-only");
      field.hidden = !isMetric || (isFemaleField && !isFemale);
    });

    imperialFields.forEach((field) => {
      if (!(field instanceof HTMLElement)) return;
      const isFemaleField = field.classList.contains("female-only");
      field.hidden = isMetric || (isFemaleField && !isFemale);
    });

    femaleOnlyFields.forEach((field) => {
      if (!(field instanceof HTMLElement)) return;

      if (!isFemale) {
        field.hidden = true;
      } else if (field.classList.contains("metric-field")) {
        field.hidden = !isMetric;
      } else {
        field.hidden = isMetric;
      }
    });
  };

  const showError = (message) => {
    if (!(formError instanceof HTMLElement)) return;
    formError.textContent = message;
    formError.hidden = false;
  };

  const clearError = () => {
    if (!(formError instanceof HTMLElement)) return;
    formError.textContent = "";
    formError.hidden = true;
  };

  const isWithin = (value, min, max) =>
    value !== null && value >= min && value <= max;

  const classifyResult = (bodyFat, sex) => {
    if (sex === "male") {
      if (bodyFat < 2) {
        return {
          category: "Below essential range",
          title: "The estimate is unusually low",
          explanation:
            "This result is below the broad essential-fat reference range. Recheck your tape placement and measurements. Very low body-fat levels can carry health risks.",
          className: "category-warning"
        };
      }

      if (bodyFat <= 5) {
        return {
          category: "Essential fat",
          title: "Your estimate is in the essential-fat range",
          explanation:
            "This is a very low body-fat range. It is not a general target for most people and may be difficult or unsafe to maintain.",
          className: "category-warning"
        };
      }

      if (bodyFat <= 13) {
        return {
          category: "Athletic range",
          title: "Your estimate is in a broad athletic range",
          explanation:
            "This range is often associated with lean, athletic body composition, although appropriate levels vary by person and sport.",
          className: "category-positive"
        };
      }

      if (bodyFat <= 17) {
        return {
          category: "Fitness range",
          title: "Your estimate is in a broad fitness range",
          explanation:
            "This range is commonly used as a general fitness reference. Your health cannot be determined from body-fat percentage alone.",
          className: "category-positive"
        };
      }

      if (bodyFat <= 24) {
        return {
          category: "Average range",
          title: "Your estimate is in a broad average range",
          explanation:
            "This falls within a commonly cited average adult range. Consider your overall health, habits and long-term trend rather than one measurement.",
          className: "category-neutral"
        };
      }

      return {
        category: "Higher range",
        title: "Your estimate is in a higher body-fat range",
        explanation:
          "A higher estimate may be useful as one signal to review alongside waist trend, fitness, nutrition, sleep and professional medical advice.",
        className: "category-high"
      };
    }

    if (bodyFat < 10) {
      return {
        category: "Below essential range",
        title: "The estimate is unusually low",
        explanation:
          "This result is below the broad essential-fat reference range. Recheck your measurements. Very low body-fat levels can carry health risks.",
        className: "category-warning"
      };
    }

    if (bodyFat <= 13) {
      return {
        category: "Essential fat",
        title: "Your estimate is in the essential-fat range",
        explanation:
          "This is a very low body-fat range. It is not a general target for most people and may be difficult or unsafe to maintain.",
        className: "category-warning"
      };
    }

    if (bodyFat <= 20) {
      return {
        category: "Athletic range",
        title: "Your estimate is in a broad athletic range",
        explanation:
          "This range is often associated with lean, athletic body composition, although appropriate levels vary by person and sport.",
        className: "category-positive"
      };
    }

    if (bodyFat <= 24) {
      return {
        category: "Fitness range",
        title: "Your estimate is in a broad fitness range",
        explanation:
          "This range is commonly used as a general fitness reference. Your health cannot be determined from body-fat percentage alone.",
        className: "category-positive"
      };
    }

    if (bodyFat <= 31) {
      return {
        category: "Average range",
        title: "Your estimate is in a broad average range",
        explanation:
          "This falls within a commonly cited average adult range. Consider your overall health, habits and long-term trend rather than one measurement.",
        className: "category-neutral"
      };
    }

    return {
      category: "Higher range",
      title: "Your estimate is in a higher body-fat range",
      explanation:
        "A higher estimate may be useful as one signal to review alongside waist trend, fitness, nutrition, sleep and professional medical advice.",
      className: "category-high"
    };
  };

  const markerPosition = (bodyFat, sex) => {
    const maximum = sex === "male" ? 40 : 50;
    const bounded = Math.min(Math.max(bodyFat, 0), maximum);
    return (bounded / maximum) * 100;
  };

  const formatMass = (value, units) => {
    if (!Number.isFinite(value)) return "Add weight to calculate";
    return `${value.toFixed(1)} ${units === "metric" ? "kg" : "lb"}`;
  };

  const calculate = () => {
    clearError();

    const units = getCheckedValue("units");
    const sex = getCheckedValue("sex");

    let heightInches;
    let waistInches;
    let neckInches;
    let hipInches = null;
    let weight = null;

    if (units === "metric") {
      const heightCm = getNumber("#height-cm");
      const waistCm = getNumber("#waist-cm");
      const neckCm = getNumber("#neck-cm");
      const weightKg = getNumber("#weight-kg");

      if (!isWithin(heightCm, 120, 230)) {
        showError("Enter a height between 120 and 230 cm.");
        return;
      }

      if (!isWithin(waistCm, 40, 220)) {
        showError("Enter a waist circumference between 40 and 220 cm.");
        return;
      }

      if (!isWithin(neckCm, 20, 70)) {
        showError("Enter a neck circumference between 20 and 70 cm.");
        return;
      }

      if (weightKg !== null && !isWithin(weightKg, 30, 350)) {
        showError("Enter a weight between 30 and 350 kg, or leave it blank.");
        return;
      }

      heightInches = heightCm / 2.54;
      waistInches = waistCm / 2.54;
      neckInches = neckCm / 2.54;
      weight = weightKg;

      if (sex === "female") {
        const hipCm = getNumber("#hip-cm");

        if (!isWithin(hipCm, 50, 220)) {
          showError("Enter a hip circumference between 50 and 220 cm.");
          return;
        }

        hipInches = hipCm / 2.54;
      }
    } else {
      const heightFt = getNumber("#height-ft");
      const heightIn = getNumber("#height-in");
      const waistIn = getNumber("#waist-in");
      const neckIn = getNumber("#neck-in");
      const weightLb = getNumber("#weight-lb");

      if (!isWithin(heightFt, 3, 7)) {
        showError("Enter the feet portion of your height between 3 and 7.");
        return;
      }

      if (!isWithin(heightIn, 0, 11.9)) {
        showError("Enter the inches portion of your height between 0 and 11.9.");
        return;
      }

      if (!isWithin(waistIn, 16, 87)) {
        showError("Enter a waist circumference between 16 and 87 inches.");
        return;
      }

      if (!isWithin(neckIn, 8, 28)) {
        showError("Enter a neck circumference between 8 and 28 inches.");
        return;
      }

      if (weightLb !== null && !isWithin(weightLb, 66, 770)) {
        showError("Enter a weight between 66 and 770 lb, or leave it blank.");
        return;
      }

      heightInches = heightFt * 12 + heightIn;
      waistInches = waistIn;
      neckInches = neckIn;
      weight = weightLb;

      if (sex === "female") {
        const hipIn = getNumber("#hip-in");

        if (!isWithin(hipIn, 20, 87)) {
          showError("Enter a hip circumference between 20 and 87 inches.");
          return;
        }

        hipInches = hipIn;
      }
    }

    if (waistInches <= neckInches) {
      showError("Waist circumference must be greater than neck circumference.");
      return;
    }

    let bodyFat;

    if (sex === "male") {
      bodyFat =
        86.01 * Math.log10(waistInches - neckInches) -
        70.041 * Math.log10(heightInches) +
        36.76;
    } else {
      const circumferenceValue = waistInches + hipInches - neckInches;

      if (circumferenceValue <= 0) {
        showError("Please check your waist, hip and neck measurements.");
        return;
      }

      bodyFat =
        163.205 * Math.log10(circumferenceValue) -
        97.684 * Math.log10(heightInches) -
        78.387;
    }

    if (!Number.isFinite(bodyFat) || bodyFat < 0 || bodyFat > 75) {
      showError(
        "The entered measurements produced an implausible result. Please check all values and tape placement."
      );
      return;
    }

    const classification = classifyResult(bodyFat, sex);
    const roundedBodyFat = Math.round(bodyFat * 10) / 10;

    if (bodyFatValue instanceof HTMLElement) {
      bodyFatValue.textContent = roundedBodyFat.toFixed(1);
    }

    if (resultCategory instanceof HTMLElement) {
      resultCategory.textContent = classification.category;
      resultCategory.className = `category-badge ${classification.className}`;
    }

    if (resultTitle instanceof HTMLElement) {
      resultTitle.textContent = classification.title;
    }

    if (resultExplanation instanceof HTMLElement) {
      resultExplanation.textContent = classification.explanation;
    }

    if (scaleMarker instanceof HTMLElement) {
      scaleMarker.style.left = `${markerPosition(bodyFat, sex)}%`;
    }

    if (fatMassValue instanceof HTMLElement && leanMassValue instanceof HTMLElement) {
      if (weight !== null) {
        const fatMass = weight * (bodyFat / 100);
        const leanMass = weight - fatMass;
        fatMassValue.textContent = formatMass(fatMass, units);
        leanMassValue.textContent = formatMass(leanMass, units);
      } else {
        fatMassValue.textContent = "Add weight to calculate";
        leanMassValue.textContent = "Add weight to calculate";
      }
    }

    if (resultsSection instanceof HTMLElement) {
      resultsSection.hidden = false;
      resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  };

  document.querySelectorAll('input[name="units"]').forEach((input) => {
    input.addEventListener("change", () => {
      setFieldVisibility();
      clearError();
    });
  });

  document.querySelectorAll('input[name="sex"]').forEach((input) => {
    input.addEventListener("change", () => {
      setFieldVisibility();
      clearError();
    });
  });

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    calculate();
  });

  form?.addEventListener("reset", () => {
    window.setTimeout(() => {
      setFieldVisibility();
      clearError();

      if (resultsSection instanceof HTMLElement) {
        resultsSection.hidden = true;
      }
    }, 0);
  });

  recalculateButton?.addEventListener("click", () => {
    form?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  setFieldVisibility();
</script>

