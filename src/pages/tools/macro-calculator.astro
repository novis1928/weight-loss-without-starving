---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;

const pageTitle = "Macro Calculator | Protein, Carbs and Fat";
const pageDescription =
  "Use our free Macro Calculator to estimate daily calories, protein, carbohydrates, and fat for weight loss, maintenance, or muscle gain.";

const canonicalURL = new URL(
  `${baseURL}tools/macro-calculator/`,
  Astro.site
).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "Macro Calculator",
      url: canonicalURL,
      applicationCategory: "HealthApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript",
      description: pageDescription,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "What are macros?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Macros are macronutrients: protein, carbohydrates, and fat.",
          },
        },
        {
          "@type": "Question",
          name: "How does this macro calculator work?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "It estimates BMR, adjusts for activity and goal, then divides calories between protein, fat, and carbohydrates.",
          },
        },
        {
          "@type": "Question",
          name: "Do I need to hit my macros exactly?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No. Treat the results as flexible daily targets rather than exact requirements.",
          },
        },
      ],
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main class="calculator-page">
    <section class="hero">
      <div class="page-container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={baseURL}>Home</a><span>/</span>
          <a href={`${baseURL}tools/`}>Tools</a><span>/</span>
          <span>Macro Calculator</span>
        </nav>

        <div class="hero-content">
          <span class="eyebrow">FREE NUTRITION TOOL</span>
          <h1>Macro Calculator</h1>
          <p>
            Estimate your daily calories, protein, carbohydrates, and fat for
            weight loss, maintenance, or muscle gain.
          </p>
          <div class="badges">
            <span>Protein target</span>
            <span>Carbs and fat</span>
            <span>Metric and imperial</span>
            <span>Instant results</span>
          </div>
        </div>
      </div>
    </section>

    <section class="calculator-section">
      <div class="page-container">
        <div class="calculator-layout">
          <div class="calculator-card">
            <div class="card-heading">
              <div>
                <span class="eyebrow">STEP 1</span>
                <h2>Enter your information</h2>
              </div>
              <div class="calculator-icon" aria-hidden="true">🥗</div>
            </div>

            <form id="macro-form" novalidate>
              <fieldset class="form-group">
                <legend>Unit system</legend>
                <div class="toggle-grid">
                  <label>
                    <input type="radio" name="unit" value="metric" checked />
                    <span>Metric</span>
                  </label>
                  <label>
                    <input type="radio" name="unit" value="imperial" />
                    <span>Imperial</span>
                  </label>
                </div>
              </fieldset>

              <fieldset class="form-group">
                <legend>Sex used by the formula</legend>
                <div class="option-grid two-columns">
                  <label class="option-card">
                    <input type="radio" name="sex" value="male" checked />
                    <span><strong>Male</strong><small>Male formula values</small></span>
                  </label>
                  <label class="option-card">
                    <input type="radio" name="sex" value="female" />
                    <span><strong>Female</strong><small>Female formula values</small></span>
                  </label>
                </div>
              </fieldset>

              <div class="field-grid">
                <div class="form-group">
                  <label for="age">Age</label>
                  <div class="input-with-unit">
                    <input id="age" type="number" min="18" max="100" value="30" />
                    <span>years</span>
                  </div>
                </div>

                <div id="metric-weight" class="form-group">
                  <label for="weight-kg">Weight</label>
                  <div class="input-with-unit">
                    <input id="weight-kg" type="number" min="35" max="300" step="0.1" value="75" />
                    <span>kg</span>
                  </div>
                </div>

                <div id="imperial-weight" class="form-group" hidden>
                  <label for="weight-lb">Weight</label>
                  <div class="input-with-unit">
                    <input id="weight-lb" type="number" min="77" max="661" step="0.1" value="165" />
                    <span>lb</span>
                  </div>
                </div>
              </div>

              <div id="metric-height" class="form-group">
                <label for="height-cm">Height</label>
                <div class="input-with-unit">
                  <input id="height-cm" type="number" min="120" max="230" step="0.1" value="175" />
                  <span>cm</span>
                </div>
              </div>

              <div id="imperial-height" class="form-group" hidden>
                <label>Height</label>
                <div class="field-grid">
                  <div class="input-with-unit">
                    <input id="height-feet" type="number" min="3" max="7" value="5" />
                    <span>ft</span>
                  </div>
                  <div class="input-with-unit">
                    <input id="height-inches" type="number" min="0" max="11.9" step="0.1" value="9" />
                    <span>in</span>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label for="activity">Activity level</label>
                <select id="activity">
                  <option value="1.2">Sedentary — little or no exercise</option>
                  <option value="1.375">Lightly active — 1–3 days/week</option>
                  <option value="1.55" selected>Moderately active — 3–5 days/week</option>
                  <option value="1.725">Very active — 6–7 days/week</option>
                  <option value="1.9">Extra active — hard training or physical job</option>
                </select>
              </div>

              <fieldset class="form-group">
                <legend>Your goal</legend>
                <div class="option-grid goal-grid">
                  <label class="option-card">
                    <input type="radio" name="goal" value="lose" checked />
                    <span><strong>Lose weight</strong><small>Moderate deficit</small></span>
                  </label>
                  <label class="option-card">
                    <input type="radio" name="goal" value="maintain" />
                    <span><strong>Maintain</strong><small>Maintenance calories</small></span>
                  </label>
                  <label class="option-card">
                    <input type="radio" name="goal" value="gain" />
                    <span><strong>Gain muscle</strong><small>Small surplus</small></span>
                  </label>
                </div>
              </fieldset>

              <div class="form-group">
                <label for="protein-level">Protein preference</label>
                <select id="protein-level">
                  <option value="standard">Standard</option>
                  <option value="high" selected>High — dieting and strength training</option>
                  <option value="very-high">Very high — frequent resistance training</option>
                </select>
              </div>

              <div id="form-error" class="form-error" role="alert" hidden></div>

              <button class="calculate-button" type="submit">
                <span>Calculate my macros</span><span>→</span>
              </button>
            </form>

            <p class="privacy-note">
              Your information is processed only in your browser and is not stored.
            </p>
          </div>

          <aside class="info-card">
            <span class="info-label">WHAT YOU WILL GET</span>
            <h2>Your daily nutrition targets</h2>
            <p>
              The calculator combines estimated calorie needs with a practical
              macro split for your selected goal.
            </p>
            <ul>
              <li><span>✓</span> Daily calorie target</li>
              <li><span>✓</span> Protein in grams</li>
              <li><span>✓</span> Carbohydrates in grams</li>
              <li><span>✓</span> Fat in grams</li>
              <li><span>✓</span> Macro percentages</li>
            </ul>
            <div class="warning-box">
              <strong>Important</strong>
              <p>These results are general estimates, not medical advice.</p>
            </div>
          </aside>
        </div>

        <section id="results" class="results-section" aria-live="polite" hidden>
          <div class="results-heading">
            <div>
              <span class="eyebrow">YOUR RESULTS</span>
              <h2>Your daily macro targets</h2>
              <p id="results-summary">Estimated targets based on your information.</p>
            </div>
            <button id="recalculate-button" type="button">Edit information</button>
          </div>

          <div class="calorie-card">
            <div>
              <span>DAILY CALORIE TARGET</span>
              <div class="calorie-value"><strong id="target-calories">—</strong><small>kcal</small></div>
              <p id="goal-description">Based on your goal and activity level.</p>
            </div>
            <div class="maintenance-box">
              <span>Estimated maintenance</span>
              <strong id="maintenance-calories">— kcal</strong>
              <small id="bmr-result">BMR: — kcal</small>
            </div>
          </div>

          <div class="macro-grid">
            <article class="macro-card">
              <span>PROTEIN</span>
              <h3><strong id="protein-grams">—</strong> g</h3>
              <div class="progress"><span id="protein-bar"></span></div>
              <p><span id="protein-calories">— kcal</span><strong id="protein-percent">—%</strong></p>
            </article>

            <article class="macro-card carbs">
              <span>CARBOHYDRATES</span>
              <h3><strong id="carbs-grams">—</strong> g</h3>
              <div class="progress"><span id="carbs-bar"></span></div>
              <p><span id="carbs-calories">— kcal</span><strong id="carbs-percent">—%</strong></p>
            </article>

            <article class="macro-card fat">
              <span>FAT</span>
              <h3><strong id="fat-grams">—</strong> g</h3>
              <div class="progress"><span id="fat-bar"></span></div>
              <p><span id="fat-calories">— kcal</span><strong id="fat-percent">—%</strong></p>
            </article>
          </div>

          <div id="low-calorie-warning" class="result-warning" hidden>
            <strong>Your estimated calorie target is relatively low.</strong>
            <p>
              Consider professional guidance before following a very low-calorie plan,
              especially when you have a medical condition or take medication.
            </p>
          </div>
        </section>
      </div>
    </section>

    <section class="content-section shaded">
      <div class="content-container">
        <div class="section-heading">
          <span class="eyebrow">UNDERSTANDING MACROS</span>
          <h2>What do protein, carbs, and fat do?</h2>
        </div>
        <div class="content-grid">
          <article><div>🥩</div><h3>Protein</h3><p>Supports muscle maintenance, recovery, and fullness.</p></article>
          <article><div>🍞</div><h3>Carbohydrates</h3><p>Provide energy for daily activity, training, and fiber-rich foods.</p></article>
          <article><div>🥑</div><h3>Fat</h3><p>Supports hormones, cells, and absorption of fat-soluble vitamins.</p></article>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="content-container narrow">
        <div class="section-heading">
          <span class="eyebrow">HOW IT WORKS</span>
          <h2>How the calculator estimates your macros</h2>
        </div>
        <div class="steps">
          <article><span>01</span><div><h3>Estimate BMR</h3><p>Age, sex, height, and weight are used to estimate resting calorie needs.</p></div></article>
          <article><span>02</span><div><h3>Adjust for activity</h3><p>BMR is multiplied by your selected activity factor.</p></div></article>
          <article><span>03</span><div><h3>Apply your goal</h3><p>A deficit, maintenance level, or small surplus is applied.</p></div></article>
          <article><span>04</span><div><h3>Divide calories</h3><p>Protein is based on body weight, fat gets a practical share, and carbs fill the remainder.</p></div></article>
        </div>
      </div>
    </section>

    <section class="content-section shaded">
      <div class="page-container">
        <div class="section-heading">
          <span class="eyebrow">RELATED TOOLS</span>
          <h2>Explore our other free calculators</h2>
        </div>
        <div class="related-grid">
          <a href={`${baseURL}tools/calorie-calculator/`}><span>🔥</span><div><h3>Calorie Calculator</h3><p>Estimate BMR, TDEE, and daily calorie needs.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/bmi-calculator/`}><span>⚖️</span><div><h3>BMI Calculator</h3><p>Calculate BMI and view a healthy weight range.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/body-fat-calculator/`}><span>📏</span><div><h3>Body Fat Calculator</h3><p>Estimate body fat from simple measurements.</p><strong>Open calculator →</strong></div></a>
          <a href={`${baseURL}tools/ideal-weight-calculator/`}><span>⚖️</span><div><h3>Ideal Weight Calculator</h3><p>Estimate your ideal body weight using four well-known formulas.</p><strong>Open calculator →</strong></div></a>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="content-container narrow">
        <div class="section-heading"><span class="eyebrow">COMMON QUESTIONS</span><h2>Macro Calculator FAQ</h2></div>
        <div class="faq-list">
          <details><summary>What are macros?</summary><p>Macros are protein, carbohydrates, and fat. Together they provide calories and support different body functions.</p></details>
          <details><summary>How accurate is this calculator?</summary><p>It gives a practical starting estimate. Actual needs can differ, so review progress over several weeks and adjust gradually.</p></details>
          <details><summary>Do I need to hit my macros exactly?</summary><p>No. Treat them as flexible targets. Consistency matters more than perfect daily precision.</p></details>
          <details><summary>Can I use it for weight loss?</summary><p>Yes. Select Lose weight to apply a moderate calorie deficit and a relatively high protein target.</p></details>
          <details><summary>Can I use it for muscle gain?</summary><p>Yes. Select Gain muscle to use a small calorie surplus and a high protein target.</p></details>
        </div>
      </div>
    </section>

    <section class="ebook-cta">
      <div class="page-container">
        <div class="ebook-card">
          <div>
            <span class="eyebrow">READY FOR THE NEXT STEP?</span>
            <h2>Lose weight without extreme diets or constant hunger</h2>
            <p>Get practical guidance for building sustainable eating and weight-loss habits.</p>
          </div>
          <a href={`${baseURL}#purchase`}>Discover the ebook →</a>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const form = document.getElementById("macro-form");
      const metricWeight = document.getElementById("metric-weight");
      const imperialWeight = document.getElementById("imperial-weight");
      const metricHeight = document.getElementById("metric-height");
      const imperialHeight = document.getElementById("imperial-height");
      const errorBox = document.getElementById("form-error");
      const results = document.getElementById("results");
      const warning = document.getElementById("low-calorie-warning");

      if (!form || !metricWeight || !imperialWeight || !metricHeight || !imperialHeight || !errorBox || !results) return;

      const selected = (name) => form.querySelector(`input[name="${name}"]:checked`)?.value || "";
      const num = (id) => Number.parseFloat(document.getElementById(id)?.value || "");
      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };
      const format = (value) => new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 }).format(Math.round(value));
      const showError = (message) => { errorBox.textContent = message; errorBox.hidden = false; };
      const clearError = () => { errorBox.textContent = ""; errorBox.hidden = true; };

      const updateUnits = () => {
        const metric = selected("unit") === "metric";
        metricWeight.hidden = !metric;
        imperialWeight.hidden = metric;
        metricHeight.hidden = !metric;
        imperialHeight.hidden = metric;
        clearError();
      };

      form.querySelectorAll('input[name="unit"]').forEach((input) => input.addEventListener("change", updateUnits));

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        clearError();

        const unit = selected("unit");
        const sex = selected("sex");
        const goal = selected("goal");
        const age = num("age");
        const activity = num("activity");

        if (!Number.isFinite(age) || age < 18 || age > 100) {
          showError("Please enter an age between 18 and 100.");
          return;
        }

        let weightKg;
        let heightCm;

        if (unit === "metric") {
          weightKg = num("weight-kg");
          heightCm = num("height-cm");

          if (!Number.isFinite(weightKg) || weightKg < 35 || weightKg > 300) {
            showError("Please enter a weight between 35 and 300 kg.");
            return;
          }
          if (!Number.isFinite(heightCm) || heightCm < 120 || heightCm > 230) {
            showError("Please enter a height between 120 and 230 cm.");
            return;
          }
        } else {
          const pounds = num("weight-lb");
          const feet = num("height-feet");
          const inches = num("height-inches");

          if (!Number.isFinite(pounds) || pounds < 77 || pounds > 661) {
            showError("Please enter a weight between 77 and 661 lb.");
            return;
          }
          if (!Number.isFinite(feet) || feet < 3 || feet > 7 || !Number.isFinite(inches) || inches < 0 || inches >= 12) {
            showError("Please enter a valid height in feet and inches.");
            return;
          }

          weightKg = pounds * 0.45359237;
          heightCm = (feet * 12 + inches) * 2.54;
        }

        const bmr = sex === "female"
          ? 10 * weightKg + 6.25 * heightCm - 5 * age - 161
          : 10 * weightKg + 6.25 * heightCm - 5 * age + 5;

        const maintenance = bmr * activity;
        const target = maintenance * (goal === "lose" ? 0.8 : goal === "gain" ? 1.1 : 1);

        const proteinLevel = document.getElementById("protein-level")?.value || "high";
        let proteinPerKg = proteinLevel === "standard" ? 1.4 : proteinLevel === "very-high" ? 2.2 : 1.8;
        if (goal === "gain" && proteinLevel === "standard") proteinPerKg = 1.6;
        if (goal === "lose" && proteinLevel === "high") proteinPerKg = 2.0;

        const proteinGrams = weightKg * proteinPerKg;
        const proteinCalories = proteinGrams * 4;
        const fatCalories = target * (goal === "gain" ? 0.27 : 0.25);
        const fatGrams = fatCalories / 9;
        const carbsCalories = Math.max(target - proteinCalories - fatCalories, target * 0.2);
        const carbsGrams = carbsCalories / 4;

        const proteinPercent = (proteinCalories / target) * 100;
        const carbsPercent = (carbsCalories / target) * 100;
        const fatPercent = (fatCalories / target) * 100;

        setText("target-calories", format(target));
        setText("maintenance-calories", `${format(maintenance)} kcal`);
        setText("bmr-result", `BMR: ${format(bmr)} kcal`);
        setText("protein-grams", format(proteinGrams));
        setText("carbs-grams", format(carbsGrams));
        setText("fat-grams", format(fatGrams));
        setText("protein-calories", `${format(proteinCalories)} kcal`);
        setText("carbs-calories", `${format(carbsCalories)} kcal`);
        setText("fat-calories", `${format(fatCalories)} kcal`);
        setText("protein-percent", `${Math.round(proteinPercent)}%`);
        setText("carbs-percent", `${Math.round(carbsPercent)}%`);
        setText("fat-percent", `${Math.round(fatPercent)}%`);
        setText("goal-description", goal === "lose" ? "Based on a moderate calorie deficit." : goal === "gain" ? "Based on a small calorie surplus." : "Based on estimated maintenance calories.");
        setText("results-summary", goal === "lose" ? "Estimated daily targets for weight loss." : goal === "gain" ? "Estimated daily targets for muscle gain." : "Estimated daily targets for weight maintenance.");

        const proteinBar = document.getElementById("protein-bar");
        const carbsBar = document.getElementById("carbs-bar");
        const fatBar = document.getElementById("fat-bar");
        if (proteinBar) proteinBar.style.width = `${Math.min(proteinPercent, 100)}%`;
        if (carbsBar) carbsBar.style.width = `${Math.min(carbsPercent, 100)}%`;
        if (fatBar) fatBar.style.width = `${Math.min(fatPercent, 100)}%`;

        if (warning) warning.hidden = target >= (sex === "female" ? 1200 : 1500);

        results.hidden = false;
        requestAnimationFrame(() => results.scrollIntoView({ behavior: "smooth", block: "start" }));
      });

      document.getElementById("recalculate-button")?.addEventListener("click", () => {
        form.scrollIntoView({ behavior: "smooth", block: "center" });
      });

      updateUnits();
    })();
  </script>
</Layout>

<style>
  :global(html) { scroll-behavior: smooth; }
  .calculator-page { color: #0f172a; background: #fff; }
  .page-container { width: min(1160px, calc(100% - 40px)); margin: 0 auto; }
  .content-container { width: min(1040px, calc(100% - 40px)); margin: 0 auto; }
  .narrow { max-width: 900px; }
  .hero { padding: 42px 0 82px; background: radial-gradient(circle at 12% 10%, rgba(34,197,94,.16), transparent 30%), radial-gradient(circle at 90% 20%, rgba(249,115,22,.1), transparent 28%), linear-gradient(180deg,#f8fafc 0%,#fff 100%); }
  .breadcrumbs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:56px; color:#64748b; font-size:.88rem; }
  .breadcrumbs a { color:#475569; text-decoration:none; }
  .hero-content { max-width:820px; margin:0 auto; text-align:center; }
  .eyebrow,.info-label { color:#15803d; font-size:.76rem; font-weight:800; letter-spacing:.13em; text-transform:uppercase; }
  .hero h1 { margin:12px 0 0; font-size:clamp(2.7rem,7vw,5rem); line-height:1.02; letter-spacing:-.055em; }
  .hero-content>p { max-width:720px; margin:22px auto 0; color:#64748b; font-size:1.12rem; line-height:1.75; }
  .badges { display:flex; flex-wrap:wrap; justify-content:center; gap:10px; margin-top:28px; }
  .badges span { padding:9px 13px; border:1px solid #dcfce7; border-radius:999px; color:#166534; background:rgba(255,255,255,.82); font-size:.82rem; font-weight:700; }
  .calculator-section { padding-bottom:96px; }
  .calculator-layout { display:grid; grid-template-columns:minmax(0,1.35fr) minmax(290px,.65fr); gap:28px; align-items:start; margin-top:-36px; }
  .calculator-card,.info-card { border:1px solid #e2e8f0; border-radius:26px; box-shadow:0 24px 70px rgba(15,23,42,.1); }
  .calculator-card { padding:34px; background:#fff; }
  .card-heading { display:flex; justify-content:space-between; align-items:center; gap:20px; margin-bottom:30px; }
  .card-heading h2,.info-card h2 { margin:7px 0 0; font-size:clamp(1.65rem,4vw,2.25rem); line-height:1.15; letter-spacing:-.04em; }
  .calculator-icon { display:grid; place-items:center; width:64px; height:64px; border-radius:18px; background:#dcfce7; font-size:1.9rem; }
  .form-group { min-width:0; margin:0 0 24px; padding:0; border:0; }
  .form-group>label,.form-group>legend { display:block; margin-bottom:10px; color:#1e293b; font-size:.92rem; font-weight:800; }
  .toggle-grid,.option-grid,.field-grid { display:grid; gap:12px; }
  .toggle-grid,.two-columns,.field-grid { grid-template-columns:repeat(2,1fr); }
  .goal-grid { grid-template-columns:repeat(3,1fr); }
  .toggle-grid { padding:5px; border-radius:14px; background:#f1f5f9; }
  .toggle-grid input,.option-card input { position:absolute; opacity:0; pointer-events:none; }
  .toggle-grid span { display:grid; min-height:46px; place-items:center; border-radius:10px; color:#64748b; font-weight:800; cursor:pointer; }
  .toggle-grid input:checked+span { color:#15803d; background:#fff; box-shadow:0 5px 16px rgba(15,23,42,.09); }
  .option-card { cursor:pointer; }
  .option-card>span { display:block; min-height:78px; padding:15px; border:1px solid #e2e8f0; border-radius:15px; }
  .option-card input:checked+span { border-color:#22c55e; background:#f0fdf4; box-shadow:0 0 0 3px rgba(34,197,94,.1); }
