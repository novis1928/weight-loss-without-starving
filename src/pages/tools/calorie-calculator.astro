<script is:inline>
  const form = document.getElementById("calorieForm");
  const results = document.getElementById("results");
  const error = document.getElementById("formError");
  const recalculateButton = document.getElementById("recalculateButton");

  const ageInput = document.getElementById("age");
  const heightInput = document.getElementById("height");
  const weightInput = document.getElementById("weight");
  const activityInput = document.getElementById("activity");

  const mainCalories = document.getElementById("mainCalories");
  const bmrValue = document.getElementById("bmrValue");
  const tdeeValue = document.getElementById("tdeeValue");
  const lossValue = document.getElementById("lossValue");
  const gentleLossValue = document.getElementById("gentleLossValue");
  const maintainValue = document.getElementById("maintainValue");
  const gainValue = document.getElementById("gainValue");
  const resultMessage = document.getElementById("resultMessage");

  const formatCalories = (value) =>
    `${Math.round(value / 10) * 10} kcal/day`;

  function calculateBmr(sex, age, height, weight) {
    const base = 10 * weight + 6.25 * height - 5 * age;
    return sex === "male" ? base + 5 : base - 161;
  }

  form.addEventListener("submit", (event) => {
    event.preventDefault();

    const sex =
      document.querySelector('input[name="sex"]:checked')?.value ??
      "male";

    const age = Number(ageInput.value);
    const height = Number(heightInput.value);
    const weight = Number(weightInput.value);
    const activity = Number(activityInput.value);

    error.textContent = "";

    if (!age || !height || !weight || !activity) {
      error.textContent = "Please complete all fields.";
      results.classList.add("hidden");
      return;
    }

    if (age < 18 || age > 100) {
      error.textContent = "Please enter an age between 18 and 100.";
      results.classList.add("hidden");
      return;
    }

    if (height < 120 || height > 250) {
      error.textContent = "Please enter a height between 120 and 250 cm.";
      results.classList.add("hidden");
      return;
    }

    if (weight < 35 || weight > 350) {
      error.textContent = "Please enter a weight between 35 and 350 kg.";
      results.classList.add("hidden");
      return;
    }

    const bmr = calculateBmr(sex, age, height, weight);
    const tdee = bmr * activity;
    const loss = tdee - 500;
    const gentleLoss = tdee - 250;
    const gain = tdee + 250;

    mainCalories.textContent = formatCalories(tdee);
    bmrValue.textContent = formatCalories(bmr);
    tdeeValue.textContent = formatCalories(tdee);
    lossValue.textContent = formatCalories(Math.max(loss, 0));
    gentleLossValue.textContent = formatCalories(Math.max(gentleLoss, 0));
    maintainValue.textContent = formatCalories(tdee);
    gainValue.textContent = formatCalories(gain);

    if (loss < 1200) {
      resultMessage.textContent =
        "A 500-calorie deficit would create a very low estimated intake. Consider the gentler target and seek professional guidance before making a large calorie reduction.";
    } else {
      resultMessage.textContent =
        "Start with the gentle-loss target, track your average progress for two to three weeks, and adjust gradually.";
    }

    results.classList.remove("hidden");
    results.scrollIntoView({ behavior: "smooth", block: "nearest" });
  });

  recalculateButton.addEventListener("click", () => {
    results.classList.add("hidden");
    form.scrollIntoView({ behavior: "smooth", block: "start" });
    ageInput.focus();
  });
</script>
