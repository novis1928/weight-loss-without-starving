---
import Layout from "../../layouts/Layout.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

const canonicalURL = new URL(
  `${base}tools/calorie-calculator/`,
  Astro.site ?? Astro.url
).toString();

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Calorie Calculator",
  applicationCategory: "HealthApplication",
  operatingSystem: "Any",
  url: canonicalURL,
  description:
    "Estimate BMR, TDEE, maintenance calories, and suggested calorie targets for weight loss or weight gain.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};
---

<Layout
  title="Calorie Calculator – BMR, TDEE & Daily Calories"
  description="Use this free calorie calculator to estimate your BMR, TDEE, maintenance calories, and daily calorie targets for weight loss, maintenance, or weight gain."
  canonicalURL={canonicalURL}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
  ></script>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={base}>Home</a>
          <span>›</span>
          <a href={`${base}tools/`}>Tools</a>
          <span>›</span>
          <span aria-current="page">Calorie Calculator</span>
        </nav>

        <div class="hero-copy">
          <span class="eyebrow">FREE HEALTH TOOL</span>
          <h1>Calorie Calculator</h1>
          <p>
            Estimate your daily calorie needs using your age, height, weight,
            sex, and activity level. See your BMR, TDEE, and suggested targets
            for losing, maintaining, or gaining weight.
          </p>
        </div>
      </div>
    </section>

    <section class="calculator-section">
      <div class="container calculator-layout">
        <div class="calculator-card">
          <div class="card-header">
            <div class="step-badge">1</div>
            <div>
              <h2>Enter your details</h2>
              <p>
                Complete the form below. All calculations happen directly in
                your browser.
              </p>
            </div>
          </div>

          <form id="calorieForm" novalidate>
            <fieldset class="field-group">
              <legend>Sex used in the equation</legend>

              <div class="sex-options">
                <label class="choice-card">
                  <input
                    type="radio"
                    name="sex"
                    value="male"
                    checked
                  />
                  <span>Male</span>
                </label>

                <label class="choice-card">
                  <input
                    type="radio"
                    name="sex"
                    value="female"
                  />
                  <span>Female</span>
                </label>
              </div>
            </fieldset>

            <div class="form-grid">
              <label class="input-group">
                <span>Age</span>
                <div class="input-shell">
                  <input
                    id="age"
                    type="number"
                    min="18"
                    max="100"
                    step="1"
                    inputmode="numeric"
                    placeholder="35"
                    required
                  />
                  <small>years</small>
                </div>
              </label>

              <label class="input-group">
                <span>Height</span>
                <div class="input-shell">
                  <input
                    id="height"
                    type="number"
                    min="120"
                    max="250"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="175"
                    required
                  />
                  <small>cm</small>
                </div>
              </label>

              <label class="input-group">
                <span>Weight</span>
                <div class="input-shell">
                  <input
                    id="weight"
                    type="number"
                    min="35"
                    max="350"
                    step="0.1"
                    inputmode="decimal"
                    placeholder="72"
                    required
                  />
                  <small>kg</small>
                </div>
              </label>

              <label class="input-group">
                <span>Activity level</span>
                <select id="activity" required>
                  <option value="1.2">
                    Sedentary — little or no exercise
                  </option>
                  <option value="1.375">
                    Lightly active — 1–3 days/week
                  </option>
                  <option value="1.55" selected>
                    Moderately active — 3–5 days/week
                  </option>
                  <option value="1.725">
                    Very active — 6–7 days/week
                  </option>
                  <option value="1.9">
                    Extra active — hard training or physical work
                  </option>
                </select>
              </label>
            </div>

            <p id="formError" class="form-error" role="alert"></p>

            <button type="submit" class="primary-button">
              Calculate My Calories
            </button>
          </form>

          <section
            id="results"
            class="results hidden"
            aria-live="polite"
          >
            <div class="results-heading">
              <span class="eyebrow">YOUR ESTIMATE</span>
              <h2 id="mainCalories">0 kcal/day</h2>
              <p>Estimated maintenance calories</p>
            </div>

            <div class="summary-grid">
              <article class="summary-card">
                <span>BMR</span>
                <strong id="bmrValue">0 kcal/day</strong>
                <p>Estimated energy your body uses at rest.</p>
              </article>

              <article class="summary-card highlighted">
                <span>TDEE</span>
                <strong id="tdeeValue">0 kcal/day</strong>
                <p>Estimated total daily energy expenditure.</p>
              </article>
            </div>

            <div class="target-heading">
              <h3>Suggested daily calorie targets</h3>
              <p>Use these as starting points, not exact prescriptions.</p>
            </div>

            <div class="target-grid">
              <article class="target-card">
                <span class="target-label red">Weight loss</span>
                <strong id="lossValue">0 kcal/day</strong>
                <p>About 500 calories below maintenance.</p>
              </article>

              <article class="target-card">
                <span class="target-label amber">Gentle loss</span>
                <strong id="gentleLossValue">0 kcal/day</strong>
                <p>About 250 calories below maintenance.</p>
              </article>

              <article class="target-card">
                <span class="target-label green">Maintain</span>
                <strong id="maintainValue">0 kcal/day</strong>
                <p>Estimated maintenance calories.</p>
              </article>

              <article class="target-card">
                <span class="target-label blue">Weight gain</span>
                <strong id="gainValue">0 kcal/day</strong>
                <p>About 250 calories above maintenance.</p>
              </article>
            </div>

            <div class="result-note">
              <strong>Practical tip:</strong>
              <span id="resultMessage"></span>
            </div>

            <button
              id="recalculateButton"
              type="button"
              class="secondary-button"
            >
              Recalculate
            </button>
          </section>
        </div>

        <aside class="side-card">
          <span class="eyebrow">HOW IT WORKS</span>
          <h2>Two simple calculations</h2>

          <div class="steps">
            <article>
              <span>01</span>
              <div>
                <h3>Estimate BMR</h3>
                <p>
                  BMR estimates the energy your body needs for essential
                  functions at rest.
                </p>
              </div>
            </article>

            <article>
              <span>02</span>
              <div>
                <h3>Estimate TDEE</h3>
                <p>
                  BMR is multiplied by an activity factor to estimate total
                  daily energy needs.
                </p>
              </div>
            </article>
          </div>

          <div class="side-note">
            <strong>For adults only</strong>
            <p>
              This calculator is intended for non-pregnant adults and provides
              an estimate, not individualized medical advice.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section class="content-section">
      <div class="container two-column">
        <article class="info-card">
          <span class="eyebrow">BMR EXPLAINED</span>
          <h2>What is BMR?</h2>
          <p>
            Basal metabolic rate is the estimated amount of energy your body
            uses at rest to support breathing, circulation, temperature
            regulation, and other essential functions.
          </p>
          <p>
            It does not include daily movement, work, exercise, or digestion.
          </p>
        </article>

        <article class="info-card">
          <span class="eyebrow">TDEE EXPLAINED</span>
          <h2>What is TDEE?</h2>
          <p>
            Total daily energy expenditure is an estimate of how many calories
            you use during a full day. It combines BMR with your reported
            activity level.
          </p>
          <p>
            Your real needs can differ because activity, body composition,
            sleep, health, and food tracking vary from person to person.
          </p>
        </article>
      </div>
    </section>

    <section class="formula-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">THE FORMULA</span>
          <h2>How the estimate is calculated</h2>
          <p>
            This tool uses the Mifflin–St Jeor equation and applies an activity
            multiplier.
          </p>
        </div>

        <div class="formula-grid">
          <article>
            <span>Male equation</span>
            <strong>
              BMR = 10 × weight + 6.25 × height − 5 × age + 5
            </strong>
          </article>

          <article>
            <span>Female equation</span>
            <strong>
              BMR = 10 × weight + 6.25 × height − 5 × age − 161
            </strong>
          </article>

          <article>
            <span>Daily estimate</span>
            <strong>TDEE = BMR × activity multiplier</strong>
          </article>
        </div>
      </div>
    </section>

    <section class="tips-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">USE YOUR RESULT WELL</span>
          <h2>Four practical tips</h2>
        </div>

        <div class="tips-grid">
          <article>
            <span>01</span>
            <h3>Start conservatively</h3>
            <p>
              A smaller calorie change is often easier to sustain than a very
              aggressive one.
            </p>
          </article>

          <article>
            <span>02</span>
            <h3>Track trends</h3>
            <p>
              Focus on average body-weight changes over several weeks rather
              than daily fluctuations.
            </p>
          </article>

          <article>
            <span>03</span>
            <h3>Adjust gradually</h3>
            <p>
              If progress does not match your goal, make small changes instead
              of large sudden cuts.
            </p>
          </article>

          <article>
            <span>04</span>
            <h3>Prioritize nutrition</h3>
            <p>
              Protein, fiber, food quality, movement, and sleep all matter in
              addition to calories.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="related-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">RELATED TOOLS</span>
          <h2>Continue with another calculator</h2>
        </div>

        <div class="related-grid">
          <a href={`${base}tools/bmi-calculator/`} class="tool-card">
            <span>Available now</span>
            <h3>BMI Calculator</h3>
            <p>Estimate your BMI category and healthy weight range.</p>
          </a>

          <a href={`${base}tools/ideal-weight-calculator/`} class="tool-card">
            <span>Available now</span>
            <h3>Ideal Weight Calculator</h3>
            <p>Compare four established ideal-weight formulas and view a healthy BMI-based weight range.</p>
          </a>

          <a href={`${base}tools/body-fat-calculator/`} class="tool-card">
            <span>Available now</span>
            <h3>Body Fat Calculator</h3>
            <p>Estimate your body fat percentage using simple body measurements.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-card">
          <div>
            <span class="eyebrow">READY FOR A PRACTICAL PLAN?</span>
            <h2>Lose weight without starving</h2>
            <p>
              Get straightforward guidance, simple meal ideas, and sustainable
              habits in the complete eBook.
            </p>
          </div>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the eBook
          </a>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container narrow">
        <div class="section-heading">
          <span class="eyebrow">COMMON QUESTIONS</span>
          <h2>Calorie Calculator FAQ</h2>
        </div>

        <details>
          <summary>How accurate is this calculator?</summary>
          <p>
            It provides an estimate. Real calorie needs can differ because of
            metabolism, body composition, daily movement, sleep, health, and
            food-tracking accuracy.
          </p>
        </details>

        <details>
          <summary>What calorie deficit should I use?</summary>
          <p>
            A moderate deficit is generally easier to sustain than an extreme
            one. The gentle-loss estimate is often a reasonable place to start.
          </p>
        </details>

        <details>
          <summary>Should I eat below my BMR?</summary>
          <p>
            BMR is not a personal minimum-intake prescription. Your intake
            should account for nutrition, activity, health, and professional
            guidance when needed.
          </p>
        </details>

        <details>
          <summary>Why does my weight change from day to day?</summary>
          <p>
            Water, sodium, carbohydrate intake, digestion, hormones, and
            activity can all cause short-term fluctuations.
          </p>
        </details>

        <details>
          <summary>Who should not rely on this calculator?</summary>
          <p>
            Children, teenagers, pregnant people, people with medical
            conditions, and anyone with a history of disordered eating should
            seek individualized professional guidance.
          </p>
        </details>
      </div>
    </section>

    <section class="disclaimer-section">
      <div class="container narrow">
        <p>
          <strong>Medical disclaimer:</strong> This calculator provides general
          educational estimates only. It is not medical advice, diagnosis, or
          treatment. Consult a qualified healthcare professional before making
          major dietary changes, especially if you have a medical condition,
          take medication, are pregnant, or have a history of disordered eating.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  .container {
    width: min(1120px, calc(100% - 40px));
    margin-inline: auto;
  }

  .narrow {
    max-width: 820px;
  }

  .hero {
    padding: 74px 0 68px;
    background:
      radial-gradient(circle at 12% 0%, rgba(34, 197, 94, 0.18), transparent 35%),
      linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%);
  }

  .hero-inner {
    text-align: center;
  }

  .breadcrumbs {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 28px;
    color: #64748b;
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    color: #475569;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #16a34a;
  }

  .eyebrow {
    display: inline-block;
    color: #15803d;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-copy {
    max-width: 820px;
    margin-inline: auto;
  }

  .hero h1 {
    margin: 14px 0 0;
    color: #0f172a;
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .hero p {
    max-width: 720px;
    margin: 24px auto 0;
    color: #475569;
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .calculator-section {
    padding: 72px 0;
    background: #f8fafc;
  }

  .calculator-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.75fr);
    gap: 28px;
    align-items: start;
  }

  .calculator-card,
  .side-card,
  .info-card,
  .formula-grid article,
  .tips-grid article,
  .tool-card,
  details {
    border: 1px solid #e2e8f0;
    background: #ffffff;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
  }

  .calculator-card {
    padding: 38px;
    border-radius: 26px;
  }

  .card-header {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 30px;
  }

  .step-badge {
    display: grid;
    width: 44px;
    height: 44px;
    flex: 0 0 44px;
    place-items: center;
    border-radius: 14px;
    background: #22c55e;
    color: #ffffff;
    font-weight: 800;
  }

  .card-header h2,
  .side-card h2,
  .info-card h2,
  .section-heading h2,
  .cta-card h2 {
    margin: 0;
    color: #0f172a;
    letter-spacing: -0.035em;
  }

  .card-header h2 {
    font-size: 1.75rem;
  }

  .card-header p,
  .section-heading p {
    margin: 7px 0 0;
    color: #64748b;
    line-height: 1.65;
  }

  .field-group {
    margin: 0 0 24px;
    padding: 0;
    border: 0;
  }

  .field-group legend {
    margin-bottom: 10px;
    color: #334155;
    font-weight: 700;
  }

  .sex-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .choice-card {
    position: relative;
    display: grid;
    min-height: 54px;
    place-items: center;
    border: 1px solid #cbd5e1;
    border-radius: 14px;
    background: #ffffff;
    color: #334155;
    font-weight: 800;
    cursor: pointer;
  }

  .choice-card input {
    position: absolute;
    opacity: 0;
  }

  .choice-card:has(input:checked) {
    border-color: #22c55e;
    background: #f0fdf4;
    color: #166534;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .input-group > span {
    display: block;
    margin-bottom: 9px;
    color: #334155;
    font-weight: 700;
  }

  .input-shell {
    position: relative;
  }

  input,
  select {
    width: 100%;
    min-height: 58px;
    border: 1px solid #cbd5e1;
    border-radius: 14px;
    background: #ffffff;
    color: #0f172a;
    font: inherit;
    outline: none;
  }

  input {
    padding: 0 70px 0 16px;
  }

  select {
    padding: 0 44px 0 16px;
  }

  input:focus,
  select:focus {
    border-color: #22c55e;
    box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.14);
  }

  .input-shell small {
    position: absolute;
    top: 50%;
    right: 16px;
    color: #64748b;
    font-weight: 700;
    transform: translateY(-50%);
  }

  .form-error {
    min-height: 24px;
    margin: 13px 0 0;
    color: #dc2626;
    font-weight: 700;
  }

  .primary-button,
  .secondary-button {
    width: 100%;
    min-height: 58px;
    border-radius: 14px;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .primary-button {
    border: 0;
    background: #22c55e;
    color: #ffffff;
    box-shadow: 0 12px 24px rgba(34, 197, 94, 0.22);
  }

  .primary-button:hover {
    background: #16a34a;
  }

  .secondary-button {
    margin-top: 20px;
    border: 1px solid #cbd5e1;
    background: #ffffff;
    color: #334155;
  }

  .results {
    margin-top: 36px;
    padding-top: 34px;
    border-top: 1px solid #e2e8f0;
  }

  .hidden {
    display: none;
  }

  .results-heading {
    text-align: center;
  }

  .results-heading h2 {
    margin: 10px 0 0;
    color: #16a34a;
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .results-heading p {
    margin: 10px 0 0;
    color: #64748b;
  }

  .summary-grid,
  .target-grid {
    display: grid;
    gap: 14px;
  }

  .summary-grid {
    grid-template-columns: 1fr 1fr;
    margin-top: 30px;
  }

  .summary-card,
  .target-card {
    padding: 20px;
    border: 1px solid #e2e8f0;
    border-radius: 17px;
    background: #f8fafc;
  }

  .summary-card.highlighted {
    border-color: #bbf7d0;
    background: #f0fdf4;
  }

  .summary-card span,
  .summary-card strong {
    display: block;
  }

  .summary-card span {
    color: #64748b;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .summary-card strong,
  .target-card strong {
    display: block;
    margin-top: 8px;
    color: #0f172a;
    font-size: 1.45rem;
  }

  .summary-card p,
  .target-card p {
    margin: 8px 0 0;
    color: #64748b;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .target-heading {
    margin-top: 32px;
  }

  .target-heading h3 {
    margin: 0;
    color: #0f172a;
  }

  .target-heading p {
    margin: 6px 0 0;
    color: #64748b;
  }

  .target-grid {
    grid-template-columns: 1fr 1fr;
    margin-top: 16px;
  }

  .target-card {
    background: #ffffff;
  }

  .target-label {
    display: inline-flex;
    padding: 6px 9px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .red {
    background: #fee2e2;
    color: #991b1b;
  }

  .amber {
    background: #fef3c7;
    color: #92400e;
  }

  .green {
    background: #dcfce7;
    color: #166534;
  }

  .blue {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .result-note {
    margin-top: 20px;
    padding: 19px;
    border-left: 4px solid #22c55e;
    border-radius: 15px;
    background: #f0fdf4;
    color: #166534;
    line-height: 1.65;
  }

  .side-card {
    position: sticky;
    top: 100px;
    padding: 30px;
    border-radius: 24px;
  }

  .side-card h2 {
    margin-top: 10px;
    font-size: 1.55rem;
  }

  .steps {
    display: grid;
    gap: 20px;
    margin-top: 26px;
  }

  .steps article {
    display: flex;
    gap: 14px;
  }

  .steps article > span {
    display: grid;
    width: 40px;
    height: 40px;
    flex: 0 0 40px;
    place-items: center;
    border-radius: 12px;
    background: #dcfce7;
    color: #166534;
    font-weight: 900;
  }

  .steps h3 {
    margin: 0;
    color: #0f172a;
    font-size: 1rem;
  }

  .steps p {
    margin: 6px 0 0;
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .side-note {
    margin-top: 24px;
    padding: 18px;
    border-radius: 15px;
    background: #f8fafc;
  }

  .side-note p {
    margin: 7px 0 0;
    color: #64748b;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .content-section,
  .related-section {
