---
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;
---

<Layout
  title="Free Weight Loss Tools | BMI, Calories, BMR and More"
  description="Free weight loss tools including BMI Calculator, Calorie Calculator and Ideal Weight Calculator. More health calculators coming soon."
>
  <main>
    <section class="hero">
      <div class="container hero-content">
        <span class="badge">FREE HEALTH TOOLS</span>

        <h1>Simple tools for smarter weight-loss decisions</h1>

        <p>
          Use our free calculators to understand your body, estimate healthy
          targets, and make more informed choices without crash diets or
          unrealistic promises.
        </p>

        <div class="stats">
          <div>
            <strong>4</strong>
            <span>Tools available</span>
          </div>

          <div>
            <strong>4</strong>
            <span>More coming soon</span>
          </div>

          <div>
            <strong>100%</strong>
            <span>Free to use</span>
          </div>
        </div>
      </div>
    </section>

    <section class="tools-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">AVAILABLE NOW</span>
          <h2>Choose one of our free calculators</h2>
          <p>
            Get clear estimates and practical explanations with our BMI, calorie,
ideal weight and body fat calculators to support your weight-loss journey.
          </p>
        </div>

        <div class="available-tools-grid">
          <a
            class="featured-tool"
            href={`${baseURL}tools/bmi-calculator/`}
          >
            <div class="tool-icon" aria-hidden="true">⚖️</div>

            <div class="tool-content">
              <div class="tool-topline">
                <span class="tool-status available">Available now</span>
                <span class="tool-label">Free tool</span>
              </div>

              <h2>BMI Calculator</h2>

              <p>
                Calculate your Body Mass Index in seconds and estimate a healthy
                weight range based on your height.
              </p>

              <div class="tool-features">
                <span>Instant result</span>
                <span>Healthy weight range</span>
                <span>Visual BMI scale</span>
              </div>
            </div>

            <div class="tool-action">
              <span>Open calculator</span>
              <strong aria-hidden="true">→</strong>
            </div>
          </a>

          <a
            class="featured-tool"
            href={`${baseURL}tools/calorie-calculator/`}
          >
            <div class="tool-icon" aria-hidden="true">🔥</div>

            <div class="tool-content">
              <div class="tool-topline">
                <span class="tool-status available">Available now</span>
                <span class="tool-label">Free tool</span>
              </div>

              <h2>Calorie Calculator</h2>

              <p>
                Estimate your BMR, TDEE, maintenance calories, and suggested
                calorie targets for weight loss or weight gain.
              </p>

              <div class="tool-features">
                <span>BMR estimate</span>
                <span>TDEE estimate</span>
                <span>Goal-based targets</span>
              </div>
            </div>

            <div class="tool-action">
              <span>Open calculator</span>
              <strong aria-hidden="true">→</strong>
            </div>
          </a>

          <a
  class="featured-tool"
  href={`${baseURL}tools/ideal-weight-calculator/`}
>
  <div class="tool-icon" aria-hidden="true">🎯</div>

  <div class="tool-content">
    <div class="tool-topline">
      <span class="tool-status available">Available now</span>
      <span class="tool-label">Free tool</span>
    </div>

    <h2>Ideal Weight Calculator</h2>

    <p>
      Estimate your ideal body weight using the Devine, Robinson, Miller and
      Hamwi formulas, compare the results, and view your healthy BMI-based
      weight range.
    </p>

    <div class="tool-features">
      <span>4 formulas</span>
      <span>Healthy range</span>
      <span>Instant results</span>
    </div>
  </div>

  <div class="tool-action">
    <span>Open calculator</span>
    <strong aria-hidden="true">→</strong>
  </div>
</a>

<a
  class="featured-tool"
  href={`${baseURL}tools/body-fat-calculator/`}
>
  <div class="tool-icon" aria-hidden="true">📏</div>

  <div class="tool-content">
    <div class="tool-topline">
      <span class="tool-status available">Available now</span>
      <span class="tool-label">Free tool</span>
    </div>

    <h2>Body Fat Calculator</h2>

    <p>
      Estimate your body fat percentage using simple circumference
      measurements and view your estimated fat mass and lean mass.
    </p>

    <div class="tool-features">
      <span>Male and female formulas</span>
      <span>Metric and imperial</span>
      <span>Instant estimate</span>
    </div>
  </div>

  <div class="tool-action">
    <span>Open calculator</span>
    <strong aria-hidden="true">→</strong>
  </div>
</a>
        </div>
      </div>
    </section>

    <section class="coming-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">COMING SOON</span>
          <h2>More free calculators are on the way</h2>
          <p>
            We are building a complete collection of practical weight-loss and
            nutrition tools.
          </p>
        </div>

        <div class="tools-grid">
          <article class="tool-card">
            <div class="card-icon">⚡</div>
            <span class="tool-status soon">Coming soon</span>
            <h3>BMR Calculator</h3>
            <p>
              Estimate how much energy your body uses at rest for essential
              functions.
            </p>
          </article>

          <article class="tool-card">
            <div class="card-icon">📊</div>
            <span class="tool-status soon">Coming soon</span>
            <h3>TDEE Calculator</h3>
            <p>
              Estimate your total daily energy expenditure based on your
              activity level.
            </p>
          </article>

          <article class="tool-card">
            <div class="card-icon">💧</div>
            <span class="tool-status soon">Coming soon</span>
            <h3>Water Intake Calculator</h3>
            <p>
              Estimate a useful daily hydration target based on your body and
              routine.
            </p>
          </article>

          <article class="tool-card">
            <div class="card-icon">🥗</div>
            <span class="tool-status soon">Coming soon</span>
            <h3>Macro Calculator</h3>
            <p>
              Estimate daily protein, carbohydrate, and fat targets for your
              goal.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="why-section">
      <div class="container">
        <div class="why-card">
          <div>
            <span class="eyebrow">WHY USE OUR TOOLS?</span>
            <h2>Clear answers without unnecessary complexity</h2>
          </div>

          <div class="why-grid">
            <article>
              <span>01</span>
              <h3>Easy to use</h3>
              <p>
                Enter a few details and get a clear result in seconds.
              </p>
            </article>

            <article>
              <span>02</span>
              <h3>Practical guidance</h3>
              <p>
                Each tool explains what the result means in plain language.
              </p>
            </article>

            <article>
              <span>03</span>
              <h3>Free access</h3>
              <p>
                Our calculators are available without signup or payment.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-card">
          <div>
            <span class="eyebrow">GO BEYOND THE NUMBERS</span>
            <h2>Build habits you can actually sustain</h2>
            <p>
              Discover practical strategies, simple recipes, and realistic
              weight-loss guidance in the complete Weight Loss Without Starving
              eBook.
            </p>
          </div>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the eBook
          </a>
        </div>
      </div>
    </section>

    <section class="disclaimer-section">
      <div class="container narrow">
        <p>
          <strong>Health disclaimer:</strong> These tools provide general
          educational estimates only. They are not medical diagnoses and should
          not replace advice from a qualified healthcare professional.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  .container {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .narrow {
    max-width: 860px;
  }

  .hero {
    padding: 82px 0 72px;
    background:
      radial-gradient(circle at top left, rgba(34, 197, 94, 0.16), transparent 34%),
      radial-gradient(circle at top right, rgba(59, 130, 246, 0.08), transparent 31%),
      linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%);
    text-align: center;
  }

  .hero-content {
    max-width: 850px;
  }

  .badge,
  .eyebrow {
    display: inline-block;
    color: #15803d;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .badge {
    margin-bottom: 22px;
    padding: 9px 16px;
    border-radius: 999px;
    background: #dcfce7;
  }

  .hero h1 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2.7rem, 7vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .hero p {
    max-width: 760px;
    margin: 24px auto 0;
    color: #475569;
    font-size: 1.14rem;
    line-height: 1.75;
  }

  .stats {
    display: grid;
    max-width: 680px;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: 38px auto 0;
  }

  .stats div {
    padding: 18px;
    border: 1px solid rgba(34, 197, 94, 0.18);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.05);
  }

  .stats strong,
  .stats span {
    display: block;
  }

  .stats strong {
    color: #16a34a;
    font-size: 1.55rem;
  }

  .stats span {
    margin-top: 4px;
    color: #64748b;
    font-size: 0.88rem;
  }

  .tools-section,
  .coming-section,
  .why-section,
  .cta-section {
    padding: 78px 0;
  }

  .tools-section,
  .why-section {
    background: #ffffff;
  }

  .coming-section {
    background: #f8fafc;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 34px;
  }

  .section-heading h2,
  .why-card h2,
  .cta-card h2 {
    margin: 9px 0 0;
    color: #0f172a;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.04em;
  }

  .section-heading p {
    margin: 12px 0 0;
    color: #64748b;
    line-height: 1.7;
  }

  .available-tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .featured-tool {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 26px;
    align-items: center;
    padding: 34px;
    border: 1px solid #bbf7d0;
    border-radius: 26px;
    background:
      radial-gradient(circle at top right, rgba(34, 197, 94, 0.13), transparent 38%),
      #ffffff;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 22px 60px rgba(15, 23, 42, 0.08);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .featured-tool:hover {
    border-color: #22c55e;
    box-shadow: 0 28px 70px rgba(15, 23, 42, 0.12);
    transform: translateY(-4px);
  }

  .tool-icon {
    display: grid;
    width: 76px;
    height: 76px;
    place-items: center;
    border-radius: 22px;
    background: #dcfce7;
    font-size: 2.2rem;
  }

  .tool-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tool-status,
  .tool-label {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 11px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .available {
    background: #dcfce7;
    color: #166534;
  }

  .soon {
    background: #f1f5f9;
    color: #64748b;
  }

  .tool-label {
    background: #ecfeff;
    color: #0f766e;
  }

  .tool-content h2 {
    margin: 12px 0 0;
    color: #0f172a;
    font-size: 2rem;
    letter-spacing: -0.04em;
  }

  .tool-content p {
    max-width: 700px;
    margin: 10px 0 0;
    color: #475569;
    line-height: 1.7;
  }

  .tool-features {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .tool-features span {
    padding: 8px 11px;
    border-radius: 10px;
    background: #f8fafc;
    color: #475569;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .tool-action {
    display: flex;
    flex-shrink: 0;
    gap: 10px;
    align-items: center;
    padding: 14px 18px;
    border-radius: 14px;
    background: #22c55e;
    color: #ffffff;
    font-weight: 800;
  }

  .tool-action strong {
    font-size: 1.25rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .tool-card {
    position: relative;
    min-height: 260px;
    padding: 25px;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 16px 45px rgba(15, 23, 42, 0.06);
  }

  .card-icon {
    display: grid;
    width: 50px;
    height: 50px;
    place-items: center;
    margin-bottom: 18px;
    border-radius: 15px;
    background: #f0fdf4;
    font-size: 1.5rem;
  }

  .tool-card h3 {
    margin: 16px 0 8px;
    color: #0f172a;
    font-size: 1.16rem;
  }

  .tool-card p {
    margin: 0;
    color: #64748b;
    line-height: 1.65;
  }

  .why-card {
    padding: 42px;
    border-radius: 28px;
    background: #0f172a;
  }

  .why-card h2 {
    max-width: 760px;
    color: #ffffff;
  }

  .why-card .eyebrow {
    color: #4ade80;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 34px;
  }

  .why-grid article {
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.05);
  }

  .why-grid article > span {
    color: #4ade80;
    font-weight: 900;
  }

  .why-grid h3 {
    margin: 13px 0 8px;
    color: #ffffff;
  }

  .why-grid p {
    margin: 0;
    color: #cbd5e1;
    line-height: 1.65;
  }

  .cta-section {
    padding-top: 20px;
    background: #ffffff;
  }

  .cta-card {
    display: flex;
    justify-content: space-between;
    gap: 30px;
    align-items: center;
    padding: 40px;
    border: 1px solid #dcfce7;
    border-radius: 26px;
    background: #f0fdf4;
  }

  .cta-card p {
    max-width: 720px;
    margin: 12px 0 0;
    color: #475569;
    line-height: 1.7;
  }

  .cta-card a {
    flex-shrink: 0;
    padding: 15px 22px;
    border-radius: 13px;
    background: #22c55e;
    color: #ffffff;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 12px 28px rgba(34, 197, 94, 0.22);
  }

  .disclaimer-section {
    padding: 0 0 58px;
    background: #ffffff;
  }

  .disclaimer-section p {
    margin: 0;
    padding: 18px 20px;
    border-left: 4px solid #22c55e;
    border-radius: 10px;
    background: #f8fafc;
    color: #475569;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  @media (max-width: 960px) {
    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .featured-tool {
      grid-template-columns: auto 1fr;
    }

    .tool-action {
      grid-column: 1 / -1;
      justify-content: center;
    }
  }

  @media (max-width: 760px) {
    .stats,
    .why-grid {
      grid-template-columns: 1fr;
    }

    .cta-card {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 620px) {
    .container {
      width: min(100% - 24px, 1120px);
    }

    .hero {
      padding: 62px 0 56px;
    }

    .tools-section,
    .coming-section,
    .why-section,
    .cta-section {
      padding: 54px 0;
    }

    .stats {
      gap: 10px;
    }

    .featured-tool {
      grid-template-columns: 1fr;
      padding: 24px;
    }

    .tool-icon {
      width: 62px;
      height: 62px;
      font-size: 1.8rem;
    }

    .tools-grid {
      grid-template-columns: 1fr;
    }

    .tool-card {
      min-height: auto;
    }

    .why-card,
    .cta-card {
      padding: 26px;
    }
  }
</style>
