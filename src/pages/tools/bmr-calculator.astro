---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;

const pageTitle = 'BMR Calculator | Estimate Basal Metabolic Rate';
const pageDescription = 'Use our free BMR Calculator to estimate how many calories your body uses at rest with the Mifflin-St Jeor equation.';
const canonicalURL = new URL(`${baseURL}tools/bmr-calculator/`, Astro.site).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: 'BMR Calculator',
      url: canonicalURL,
      applicationCategory: "HealthApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript",
      description: pageDescription,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: 'What is BMR?',
          acceptedAnswer: { "@type": "Answer", text: 'Basal metabolic rate is an estimate of the energy your body uses at rest to support essential functions.' },
        },
        {
          "@type": "Question",
          name: 'Which formula does this calculator use?',
          acceptedAnswer: { "@type": "Answer", text: 'It uses the Mifflin-St Jeor equation for adults.' },
        },
        {
          "@type": "Question",
          name: 'Is BMR the same as daily calorie needs?',
          acceptedAnswer: { "@type": "Answer", text: 'No. BMR excludes most daily activity. TDEE includes activity and is usually higher.' },
        }
      ],
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <main class="calculator-page">
    <section class="hero"><div class="page-container">
      <nav class="breadcrumbs" aria-label="Breadcrumb"><a href={baseURL}>Home</a><span>/</span><a href={`${baseURL}tools/`}>Tools</a><span>/</span><span>BMR Calculator</span></nav>
      <div class="hero-content"><span class="eyebrow">FREE METABOLISM TOOL</span><h1>BMR Calculator</h1><p>Estimate the calories your body uses at rest for breathing, circulation, temperature control, and other essential functions.</p><div class="badges"><span>Mifflin-St Jeor equation</span><span>Metric and imperial</span><span>Instant result</span><span>Free to use</span></div></div>
    </div></section>

    <section class="calculator-section"><div class="page-container">
      <div class="calculator-layout">
        <div class="calculator-card">
          <div class="card-heading"><div><span class="eyebrow">STEP 1</span><h2>Enter your information</h2></div><div class="calculator-icon">⚡</div></div>
          <form id="bmr-form" novalidate>
            <fieldset class="form-group"><legend>Unit system</legend><div class="toggle-grid">
              <label><input type="radio" name="unit" value="metric" checked /><span>Metric</span></label>
              <label><input type="radio" name="unit" value="imperial" /><span>Imperial</span></label>
            </div></fieldset>
            <fieldset class="form-group"><legend>Sex used by the formula</legend><div class="option-grid two-columns">
              <label class="option-card"><input type="radio" name="sex" value="male" checked /><span><strong>Male</strong><small>Male equation constant</small></span></label>
              <label class="option-card"><input type="radio" name="sex" value="female" /><span><strong>Female</strong><small>Female equation constant</small></span></label>
            </div></fieldset>
            <div class="field-grid">
              <div class="form-group"><label for="age">Age</label><div class="input-with-unit"><input id="age" type="number" min="18" max="100" value="30" /><span>years</span></div></div>
              <div id="metric-weight" class="form-group"><label for="weight-kg">Weight</label><div class="input-with-unit"><input id="weight-kg" type="number" min="35" max="300" step="0.1" value="75" /><span>kg</span></div></div>
              <div id="imperial-weight" class="form-group" hidden><label for="weight-lb">Weight</label><div class="input-with-unit"><input id="weight-lb" type="number" min="77" max="661" step="0.1" value="165" /><span>lb</span></div></div>
            </div>
            <div id="metric-height" class="form-group"><label for="height-cm">Height</label><div class="input-with-unit"><input id="height-cm" type="number" min="120" max="230" step="0.1" value="175" /><span>cm</span></div></div>
            <div id="imperial-height" class="form-group" hidden><label>Height</label><div class="field-grid"><div class="input-with-unit"><input id="height-feet" type="number" min="3" max="7" value="5" /><span>ft</span></div><div class="input-with-unit"><input id="height-inches" type="number" min="0" max="11.9" step="0.1" value="9" /><span>in</span></div></div></div>
            <div id="form-error" class="form-error" role="alert" hidden></div>
            <button class="calculate-button" type="submit"><span>Calculate my BMR</span><span>→</span></button>
          </form>
          <p class="privacy-note">Your information is processed only in your browser and is not stored.</p>
        </div>
        <aside class="info-card"><span class="info-label">WHAT YOU WILL GET</span><h2>Your resting calorie estimate</h2><p>BMR is a useful starting point for understanding energy needs, but it is not your full daily calorie requirement.</p><ul><li><span>✓</span> Estimated daily BMR</li><li><span>✓</span> Estimated hourly resting use</li><li><span>✓</span> A simple comparison range</li><li><span>✓</span> Link to calculate TDEE</li></ul><div class="warning-box"><strong>Important</strong><p>Online equations provide estimates. Pregnancy, illness, medications, muscle mass, and other factors may change actual needs.</p></div></aside>
      </div>

      <section id="results" class="results-section" aria-live="polite" hidden>
        <div class="results-heading"><div><span class="eyebrow">YOUR RESULT</span><h2>Estimated basal metabolic rate</h2><p id="results-summary">Based on the information entered.</p></div><button id="recalculate-button" type="button">Edit information</button></div>
        <div class="primary-result"><div><span>ESTIMATED BMR</span><div class="result-value"><strong id="bmr-result">—</strong><small>kcal/day</small></div><p>This is the estimated energy used at complete rest.</p></div><div class="result-side"><span>PER HOUR</span><strong id="hourly-result">— kcal</strong><small>Average across 24 hours</small></div></div>
        <div class="result-grid"><article class="result-card"><span>LOWER ESTIMATE</span><h3><strong id="lower-result">—</strong> kcal</h3><p>About 10% below the equation result.</p></article><article class="result-card"><span>EQUATION RESULT</span><h3><strong id="center-result">—</strong> kcal</h3><p>Your Mifflin-St Jeor estimate.</p></article><article class="result-card"><span>UPPER ESTIMATE</span><h3><strong id="upper-result">—</strong> kcal</h3><p>About 10% above the equation result.</p></article></div>
      </section>
    </div></section>

    <section class="content-section shaded"><div class="content-container"><div class="section-heading"><span class="eyebrow">BMR BASICS</span><h2>What your BMR represents</h2></div><div class="content-grid"><article><div>🫁</div><h3>Essential functions</h3><p>BMR represents energy used for breathing, circulation, cell activity, and temperature regulation.</p></article><article><div>🏃</div><h3>Activity is separate</h3><p>Walking, training, work, and digestion add calories above your BMR.</p></article><article><div>📊</div><h3>An estimate, not a test</h3><p>Indirect calorimetry is more precise; an equation is a practical starting point.</p></article></div></div></section>

    <section class="content-section"><div class="content-container narrow"><div class="section-heading"><span class="eyebrow">HOW IT WORKS</span><h2>How this calculator estimates BMR</h2></div><div class="steps"><article><span>01</span><div><h3>Convert measurements</h3><p>Imperial entries are converted to kilograms and centimeters.</p></div></article><article><span>02</span><div><h3>Apply the equation</h3><p>Weight, height, age, and the selected sex constant are entered into the Mifflin-St Jeor equation.</p></div></article><article><span>03</span><div><h3>Show a practical range</h3><p>The page displays the central estimate plus a simple ±10% comparison range.</p></div></article></div></div></section>

    <section class="content-section shaded">
      <div class="page-container">
        <div class="section-heading">
          <span class="eyebrow">RELATED TOOLS</span>
          <h2>Explore our other free calculators</h2>
        </div>

        <div class="related-grid">
          <a href={`${baseURL}tools/bmi-calculator/`}>
            <span>⚖️</span>
            <div>
              <h3>BMI Calculator</h3>
              <p>Calculate BMI and view a healthy weight range.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/calorie-calculator/`}>
            <span>🔥</span>
            <div>
              <h3>Calorie Calculator</h3>
              <p>Estimate daily calories for maintenance or weight change.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/macro-calculator/`}>
            <span>🥗</span>
            <div>
              <h3>Macro Calculator</h3>
              <p>Estimate protein, carbohydrate, and fat targets.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/body-fat-calculator/`}>
            <span>📏</span>
            <div>
              <h3>Body Fat Calculator</h3>
              <p>Estimate body fat using circumference measurements.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/ideal-weight-calculator/`}>
            <span>🎯</span>
            <div>
              <h3>Ideal Weight Calculator</h3>
              <p>Compare four commonly used ideal-weight formulas.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/tdee-calculator/`}>
            <span>🏃</span>
            <div>
              <h3>TDEE Calculator</h3>
              <p>Estimate total daily calorie needs based on your activity level.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/water-intake-calculator/`}>
            <span>💧</span>
            <div>
              <h3>Water Intake Calculator</h3>
              <p>Estimate a practical daily hydration target.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>
        </div>

        <div class="related-actions">
          <a class="all-tools-button" href={`${baseURL}tools/`}>
            View all free tools →
          </a>
        </div>
      </div>
    </section>

    <section class="content-section"><div class="content-container narrow"><div class="section-heading"><span class="eyebrow">COMMON QUESTIONS</span><h2>BMR Calculator FAQ</h2></div><div class="faq-list"><details><summary>What is BMR?</summary><p>BMR is an estimate of the energy your body would use at complete rest to support essential functions.</p></details><details><summary>Is BMR the same as TDEE?</summary><p>No. TDEE includes activity and digestion, so it is normally higher than BMR.</p></details><details><summary>Why can my actual BMR differ?</summary><p>Body composition, hormones, health conditions, medication, pregnancy, and measurement error can all affect actual energy expenditure.</p></details><details><summary>Can I eat exactly my BMR?</summary><p>BMR is not a recommended calorie intake. Use TDEE and professional guidance when setting an eating target.</p></details></div></div></section>

    <section class="ebook-cta">
      <div class="page-container">
        <div class="ebook-card">
          <div>
            <span class="eyebrow">READY FOR THE NEXT STEP?</span>
            <h2>Turn estimates into sustainable daily habits</h2>
            <p>Get practical guidance for healthy weight loss without extreme dieting.</p>
          </div>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the ebook on Payhip →
          </a>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const form = document.getElementById("bmr-form");
      const metricWeight = document.getElementById("metric-weight");
      const imperialWeight = document.getElementById("imperial-weight");
      const metricHeight = document.getElementById("metric-height");
      const imperialHeight = document.getElementById("imperial-height");
      const errorBox = document.getElementById("form-error");
      const results = document.getElementById("results");
      if (!form || !metricWeight || !imperialWeight || !metricHeight || !imperialHeight || !errorBox || !results) return;
      const selected = (name) => form.querySelector(`input[name="${name}"]:checked`)?.value || "";
      const num = (id) => Number.parseFloat(document.getElementById(id)?.value || "");
      const text = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value; };
      const format = (value) => new Intl.NumberFormat("en-US", { maximumFractionDigits:0 }).format(Math.round(value));
      const showError = (message) => { errorBox.textContent = message; errorBox.hidden = false; };
      const clearError = () => { errorBox.textContent = ""; errorBox.hidden = true; };
      const updateUnits = () => { const metric = selected("unit") === "metric"; metricWeight.hidden = !metric; imperialWeight.hidden = metric; metricHeight.hidden = !metric; imperialHeight.hidden = metric; clearError(); };
      form.querySelectorAll('input[name="unit"]').forEach((input) => input.addEventListener("change", updateUnits));
      form.addEventListener("submit", (event) => {
        event.preventDefault(); clearError();
        const unit = selected("unit"); const sex = selected("sex"); const age = num("age");
        if (!Number.isFinite(age) || age < 18 || age > 100) return showError("Please enter an age between 18 and 100.");
        let weightKg, heightCm;
        if (unit === "metric") {
          weightKg = num("weight-kg"); heightCm = num("height-cm");
          if (!Number.isFinite(weightKg) || weightKg < 35 || weightKg > 300) return showError("Please enter a weight between 35 and 300 kg.");
          if (!Number.isFinite(heightCm) || heightCm < 120 || heightCm > 230) return showError("Please enter a height between 120 and 230 cm.");
        } else {
          const pounds = num("weight-lb"), feet = num("height-feet"), inches = num("height-inches");
          if (!Number.isFinite(pounds) || pounds < 77 || pounds > 661) return showError("Please enter a weight between 77 and 661 lb.");
          if (!Number.isFinite(feet) || feet < 3 || feet > 7 || !Number.isFinite(inches) || inches < 0 || inches >= 12) return showError("Please enter a valid height in feet and inches.");
          weightKg = pounds * 0.45359237; heightCm = (feet * 12 + inches) * 2.54;
        }
        const bmr = 10 * weightKg + 6.25 * heightCm - 5 * age + (sex === "male" ? 5 : -161);
        text("bmr-result", format(bmr)); text("hourly-result", `${format(bmr / 24)} kcal`);
        text("lower-result", format(bmr * .9)); text("center-result", format(bmr)); text("upper-result", format(bmr * 1.1));
        text("results-summary", `Estimate for a ${age}-year-old using the selected formula inputs.`);
        results.hidden = false; results.scrollIntoView({ behavior:"smooth", block:"start" });
      });
      document.getElementById("recalculate-button")?.addEventListener("click", () => { form.scrollIntoView({ behavior:"smooth", block:"start" }); });
      updateUnits();
    })();
  </script>

<style>
  :global(*) { box-sizing:border-box; }
  :global(html) { scroll-behavior:smooth; }
  .calculator-page { color:#0f172a; background:#fff; }
  .page-container { width:min(100% - 40px,1160px); margin:0 auto; }
  .content-container { width:min(100% - 40px,1040px); margin:0 auto; }
  .content-container.narrow { max-width:820px; }
  .hero { padding:34px 0 82px; background:radial-gradient(circle at 15% 20%,rgba(34,197,94,.12),transparent 28%),linear-gradient(135deg,#f0fdf4 0%,#f8fafc 60%,#eff6ff 100%); }
  .breadcrumbs { display:flex; flex-wrap:wrap; gap:8px; color:#64748b; font-size:.82rem; }
  .breadcrumbs a { color:#475569; text-decoration:none; }
  .breadcrumbs a:hover { color:#15803d; }
  .hero-content { max-width:810px; margin:62px auto 0; text-align:center; }
  .eyebrow,.info-label { color:#15803d; font-size:.74rem; font-weight:900; letter-spacing:.12em; }
  .hero h1 { margin:13px 0 0; font-size:clamp(3rem,8vw,5.4rem); line-height:.98; letter-spacing:-.065em; }
  .hero-content>p { max-width:700px; margin:22px auto 0; color:#475569; font-size:1.06rem; line-height:1.75; }
  .badges { display:flex; flex-wrap:wrap; justify-content:center; gap:9px; margin-top:25px; }
  .badges span { padding:8px 11px; border:1px solid #bbf7d0; border-radius:999px; color:#166534; background:rgba(255,255,255,.78); font-size:.76rem; font-weight:800; }
  .calculator-section { padding:88px 0 96px; }
  .calculator-layout { display:grid; grid-template-columns:minmax(0,1.5fr) minmax(300px,.75fr); gap:28px; align-items:start; }
  .calculator-card,.info-card { border-radius:26px; box-shadow:0 24px 70px rgba(15,23,42,.1); }
  .calculator-card { padding:34px; border:1px solid #e2e8f0; background:#fff; }
  .card-heading { display:flex; justify-content:space-between; align-items:center; gap:20px; margin-bottom:32px; }
  .card-heading h2,.info-card h2 { margin:8px 0 0; font-size:clamp(1.65rem,4vw,2.25rem); line-height:1.15; letter-spacing:-.04em; }
  .calculator-icon { display:grid; place-items:center; width:64px; height:64px; flex-shrink:0; border-radius:18px; background:#dcfce7; font-size:1.9rem; }
  .form-group { min-width:0; margin:0 0 24px; padding:0; border:0; }
  .form-group>label,.form-group>legend { display:block; margin-bottom:10px; color:#1e293b; font-size:.92rem; font-weight:800; }
  .toggle-grid,.option-grid,.field-grid { display:grid; gap:12px; }
  .toggle-grid,.two-columns,.field-grid { grid-template-columns:repeat(2,1fr); }
  .toggle-grid { padding:5px; border-radius:14px; background:#f1f5f9; }
  .toggle-grid input,.option-card input { position:absolute; opacity:0; pointer-events:none; }
  .toggle-grid span { display:grid; min-height:46px; place-items:center; border-radius:10px; color:#64748b; font-weight:800; cursor:pointer; }
  .toggle-grid input:checked+span { color:#15803d; background:#fff; box-shadow:0 5px 16px rgba(15,23,42,.09); }
  .option-card { cursor:pointer; }
  .option-card>span { display:block; min-height:78px; padding:15px; border:1px solid #e2e8f0; border-radius:15px; }
  .option-card input:checked+span { border-color:#22c55e; background:#f0fdf4; box-shadow:0 0 0 3px rgba(34,197,94,.1); }
  .option-card strong,.option-card small { display:block; }
  .option-card small { margin-top:4px; color:#64748b; font-size:.75rem; }
  .input-with-unit { display:flex; align-items:center; overflow:hidden; border:1px solid #cbd5e1; border-radius:14px; background:#fff; }
  .input-with-unit:focus-within,select:focus { border-color:#22c55e; box-shadow:0 0 0 4px rgba(34,197,94,.11); }
  .input-with-unit input { width:100%; min-width:0; padding:15px 16px; border:0; outline:0; font:inherit; font-weight:700; }
  .input-with-unit span { padding:0 16px; color:#64748b; font-size:.86rem; font-weight:800; }
  select { width:100%; padding:15px 16px; border:1px solid #cbd5e1; border-radius:14px; outline:0; background:#fff; color:#0f172a; font:inherit; font-weight:700; }
  .form-error { margin-bottom:18px; padding:13px 15px; border:1px solid #fecaca; border-radius:12px; background:#fef2f2; color:#b91c1c; font-size:.88rem; font-weight:700; }
  .calculate-button { display:flex; justify-content:space-between; align-items:center; width:100%; min-height:56px; padding:0 20px; border:0; border-radius:14px; background:#22c55e; color:#fff; cursor:pointer; font:inherit; font-weight:800; box-shadow:0 15px 34px rgba(34,197,94,.25); }
  .calculate-button:hover { background:#16a34a; transform:translateY(-2px); }
  .privacy-note { margin:16px 0 0; color:#94a3b8; font-size:.76rem; text-align:center; }
  .info-card { position:sticky; top:100px; padding:30px; color:#fff; background:radial-gradient(circle at top right,rgba(34,197,94,.17),transparent 35%),#0f172a; }
  .info-card .info-label { color:#86efac; }
  .info-card h2 { color:#fff; }
  .info-card>p { margin:15px 0 0; color:#cbd5e1; line-height:1.7; }
  .info-card ul { display:grid; gap:15px; margin:26px 0 0; padding:0; list-style:none; }
  .info-card li { display:flex; gap:11px; color:#e2e8f0; }
  .info-card li span { display:grid; place-items:center; width:22px; height:22px; border-radius:50%; color:#86efac; background:rgba(34,197,94,.18); }
  .warning-box { margin-top:28px; padding:17px; border:1px solid rgba(148,163,184,.22); border-radius:15px; background:rgba(255,255,255,.06); }
  .warning-box p { margin:6px 0 0; color:#cbd5e1; font-size:.82rem; line-height:1.6; }
  .results-section { scroll-margin-top:100px; margin-top:58px; }
  .results-heading { display:flex; justify-content:space-between; align-items:flex-end; gap:22px; margin-bottom:24px; }
  .results-heading h2 { margin:6px 0 0; font-size:clamp(2rem,5vw,3rem); letter-spacing:-.045em; }
  .results-heading p { margin:9px 0 0; color:#64748b; }
  #recalculate-button { padding:11px 15px; border:1px solid #cbd5e1; border-radius:11px; background:#fff; color:#334155; cursor:pointer; font:inherit; font-size:.84rem; font-weight:800; }
  .primary-result { display:grid; grid-template-columns:minmax(0,1.3fr) minmax(240px,.7fr); gap:24px; padding:32px; border-radius:24px; color:#fff; background:radial-gradient(circle at top right,rgba(134,239,172,.17),transparent 35%),#0f172a; box-shadow:0 24px 64px rgba(15,23,42,.16); }
  .primary-result>div>span,.result-side>span { color:#86efac; font-size:.76rem; font-weight:800; letter-spacing:.08em; }
  .result-value { display:flex; align-items:baseline; gap:9px; margin-top:8px; }
  .result-value strong { font-size:clamp(3.3rem,8vw,5.8rem); line-height:1; letter-spacing:-.07em; }
  .result-value small { color:#cbd5e1; font-size:1.25rem; font-weight:700; }
  .primary-result p { margin:14px 0 0; color:#cbd5e1; }
  .result-side { display:flex; flex-direction:column; justify-content:center; padding:24px; border:1px solid rgba(148,163,184,.2); border-radius:18px; background:rgba(255,255,255,.06); }
  .result-side strong { margin-top:10px; font-size:1.35rem; }
  .result-side small { margin-top:8px; color:#94a3b8; }
  .result-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:18px; }
  .result-card { padding:23px; border:1px solid #e2e8f0; border-radius:18px; background:#fff; box-shadow:0 13px 38px rgba(15,23,42,.06); }
  .result-card>span { color:#64748b; font-size:.72rem; font-weight:900; letter-spacing:.08em; }
  .result-card h3 { margin:8px 0 0; font-size:1rem; }
  .result-card h3 strong { font-size:2rem; }
  .result-card p { margin:10px 0 0; color:#64748b; font-size:.82rem; line-height:1.55; }
  .result-warning { margin-top:18px; padding:21px 23px; border:1px solid #fde68a; border-radius:16px; background:#fffbeb; }
  .result-warning strong { color:#92400e; }
  .result-warning p { margin:6px 0 0; color:#78350f; line-height:1.65; }
  .content-section { padding:92px 0; }
  .shaded { background:#f8fafc; }
  .section-heading { max-width:750px; margin:0 auto 42px; text-align:center; }
  .section-heading h2 { margin:10px 0 0; font-size:clamp(2rem,5vw,3.25rem); line-height:1.1; letter-spacing:-.05em; }
