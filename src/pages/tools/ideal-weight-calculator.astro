---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;

const pageTitle =
  "Ideal Weight Calculator | Find a Healthy Weight Range";

const pageDescription =
  "Use our free Ideal Weight Calculator to estimate your ideal body weight using the Devine, Robinson, Miller, and Hamwi formulas.";

const canonicalURL = new URL(
  `${baseURL}tools/ideal-weight-calculator/`,
  Astro.site
).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "Ideal Weight Calculator",
      url: canonicalURL,
      applicationCategory: "HealthApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript",
      description: pageDescription,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "How is ideal body weight calculated?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "This calculator compares four commonly used ideal body weight formulas: Devine, Robinson, Miller, and Hamwi. Each formula uses height and sex to produce an estimate.",
          },
        },
        {
          "@type": "Question",
          name: "Why do the ideal weight formulas give different results?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Each formula was developed using a different method and set of assumptions. The results should therefore be treated as estimates rather than exact targets.",
          },
        },
        {
          "@type": "Question",
          name: "Is ideal weight the same as a healthy weight?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Not necessarily. Health is influenced by body composition, muscle mass, age, medical history, and other factors. The calculator also displays a broader weight range based on a BMI of 18.5 to 24.9.",
          },
        },
        {
          "@type": "Question",
          name: "Can athletes use an ideal weight calculator?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Athletes and people with greater muscle mass may weigh more than these estimates while still being healthy. Body composition can be more informative than body weight alone.",
          },
        },
      ],
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />

  <main class="calculator-page">
    <section class="calculator-hero">
      <div class="page-container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={baseURL}>Home</a>
          <span aria-hidden="true">/</span>
          <a href={`${baseURL}tools/`}>Tools</a>
          <span aria-hidden="true">/</span>
          <span>Ideal Weight Calculator</span>
        </nav>

        <div class="hero-content">
          <span class="eyebrow">FREE HEALTH TOOL</span>

          <h1>Ideal Weight Calculator</h1>

          <p>
            Estimate your ideal body weight using four well-known formulas and
            compare the results with a broader healthy weight range.
          </p>

          <div class="hero-badges" aria-label="Calculator features">
            <span>Four formulas</span>
            <span>Metric and imperial</span>
            <span>Instant results</span>
            <span>100% free</span>
          </div>
        </div>
      </div>
    </section>

    <section class="calculator-section">
      <div class="page-container">
        <div class="calculator-layout">
          <div class="calculator-card">
            <div class="card-heading">
              <div>
                <span class="step-label">STEP 1</span>
                <h2>Enter your information</h2>
              </div>

              <div class="calculator-icon" aria-hidden="true">⚖️</div>
            </div>

            <form id="ideal-weight-form" novalidate>
              <fieldset class="form-group">
                <legend>Unit system</legend>

                <div class="unit-toggle">
                  <label>
                    <input
                      type="radio"
                      name="unit"
                      value="metric"
                      checked
                    />
                    <span>Metric</span>
                  </label>

                  <label>
                    <input
                      type="radio"
                      name="unit"
                      value="imperial"
                    />
                    <span>Imperial</span>
                  </label>
                </div>
              </fieldset>

              <fieldset class="form-group">
                <legend>Sex used by the formulas</legend>

                <div class="sex-options">
                  <label class="option-card">
                    <input
                      type="radio"
                      name="sex"
                      value="male"
                      checked
                    />

                    <span class="option-content">
                      <span class="option-icon" aria-hidden="true">♂</span>

                      <span>
                        <strong>Male</strong>
                        <small>Use male formula values</small>
                      </span>
                    </span>
                  </label>

                  <label class="option-card">
                    <input
                      type="radio"
                      name="sex"
                      value="female"
                    />

                    <span class="option-content">
                      <span class="option-icon" aria-hidden="true">♀</span>

                      <span>
                        <strong>Female</strong>
                        <small>Use female formula values</small>
                      </span>
                    </span>
                  </label>
                </div>
              </fieldset>

              <div id="metric-fields" class="form-group">
                <label for="height-cm">Height</label>

                <div class="input-with-unit">
                  <input
                    id="height-cm"
                    name="heightCm"
                    type="number"
                    min="120"
                    max="230"
                    step="0.1"
                    value="175"
                    inputmode="decimal"
                    aria-describedby="height-metric-hint"
                  />

                  <span>cm</span>
                </div>

                <small id="height-metric-hint" class="field-hint">
                  Enter a height between 120 and 230 cm.
                </small>
              </div>

              <div
                id="imperial-fields"
                class="form-group"
                hidden
              >
                <label>Height</label>

                <div class="imperial-height">
                  <div>
                    <label class="sr-only" for="height-feet">Feet</label>

                    <div class="input-with-unit">
                      <input
                        id="height-feet"
                        name="heightFeet"
                        type="number"
                        min="3"
                        max="7"
                        step="1"
                        value="5"
                        inputmode="numeric"
                      />

                      <span>ft</span>
                    </div>
                  </div>

                  <div>
                    <label class="sr-only" for="height-inches">Inches</label>

                    <div class="input-with-unit">
                      <input
                        id="height-inches"
                        name="heightInches"
                        type="number"
                        min="0"
                        max="11.9"
                        step="0.1"
                        value="9"
                        inputmode="decimal"
                      />

                      <span>in</span>
                    </div>
                  </div>
                </div>

                <small class="field-hint">
                  Enter your height in feet and inches.
                </small>
              </div>

              <div
                id="form-error"
                class="form-error"
                role="alert"
                hidden
              ></div>

              <button class="calculate-button" type="submit">
                <span>Calculate ideal weight</span>
                <span aria-hidden="true">→</span>
              </button>
            </form>

            <p class="privacy-note">
              Your information is processed only in your browser and is not
              stored or sent anywhere.
            </p>
          </div>

          <aside class="info-card">
            <span class="info-label">WHAT YOU WILL GET</span>

            <h2>More than a single number</h2>

            <p>
              There is no perfect weight that applies to everyone. This
              calculator compares several estimates to give you a more useful
              overview.
            </p>

            <ul>
              <li>
                <span aria-hidden="true">✓</span>
                Four ideal body weight formulas
              </li>

              <li>
                <span aria-hidden="true">✓</span>
                Average calculated estimate
              </li>

              <li>
                <span aria-hidden="true">✓</span>
                Lowest and highest formula result
              </li>

              <li>
                <span aria-hidden="true">✓</span>
                Healthy BMI-based weight range
              </li>
            </ul>

            <div class="info-warning">
              <strong>Remember</strong>

              <p>
                These results are general estimates, not medical advice or a
                diagnosis.
              </p>
            </div>
          </aside>
        </div>

        <section
          id="results"
          class="results-section"
          aria-live="polite"
          hidden
        >
          <div class="results-heading">
            <div>
              <span class="step-label">YOUR RESULTS</span>
              <h2>Your estimated ideal weight</h2>

              <p id="results-summary">
                Results based on your height and selected formula values.
              </p>
            </div>

            <button id="recalculate-button" type="button">
              Edit information
            </button>
          </div>

          <div class="main-result-card">
            <div class="main-result-content">
              <span>Average of four formulas</span>

              <div class="main-result-value">
                <strong id="average-weight">—</strong>
                <span id="average-unit">kg</span>
              </div>

              <p>
                This is the average of the Devine, Robinson, Miller, and Hamwi
                estimates.
              </p>
            </div>

            <div class="result-range">
              <span>Formula range</span>

              <strong id="formula-range">—</strong>

              <small>
                From the lowest to the highest formula result
              </small>
            </div>
          </div>

          <div class="formula-grid">
            <article class="formula-card">
              <div class="formula-card-heading">
                <span class="formula-number">01</span>
                <h3>Devine formula</h3>
              </div>

              <strong id="devine-result">—</strong>

              <p>
                One of the most widely recognized ideal body weight formulas.
              </p>
            </article>

            <article class="formula-card">
              <div class="formula-card-heading">
                <span class="formula-number">02</span>
                <h3>Robinson formula</h3>
              </div>

              <strong id="robinson-result">—</strong>

              <p>
                A modified height-based estimate developed after the Devine
                formula.
              </p>
            </article>

            <article class="formula-card">
              <div class="formula-card-heading">
                <span class="formula-number">03</span>
                <h3>Miller formula</h3>
              </div>

              <strong id="miller-result">—</strong>

              <p>
                Another commonly used formula that produces a slightly
                different estimate.
              </p>
            </article>

            <article class="formula-card">
              <div class="formula-card-heading">
                <span class="formula-number">04</span>
                <h3>Hamwi formula</h3>
              </div>

              <strong id="hamwi-result">—</strong>

              <p>
                A traditional formula based on height above or below five feet.
              </p>
            </article>
          </div>

          <article class="healthy-range-card">
            <div class="healthy-range-icon" aria-hidden="true">📏</div>

            <div class="healthy-range-content">
              <span>HEALTHY BMI-BASED RANGE</span>
              <h3 id="healthy-range-result">—</h3>

              <p>
                This broader range is calculated using BMI values from 18.5 to
                24.9. It may be more useful than aiming for one exact number.
              </p>
            </div>
          </article>

          <div class="result-notice">
            <strong>Your healthiest weight may be different.</strong>

            <p>
              Muscle mass, body composition, age, frame size, pregnancy,
              medications, and medical conditions can all influence an
              appropriate weight.
            </p>
          </div>
        </section>
      </div>
    </section>

    <section class="explanation-section">
      <div class="content-container">
        <div class="section-heading">
          <span class="eyebrow">UNDERSTANDING THE RESULTS</span>

          <h2>What does “ideal weight” really mean?</h2>

          <p>
            Ideal weight formulas provide general estimates based mainly on
            height and sex. They cannot measure body composition or determine
            your health.
          </p>
        </div>

        <div class="content-grid">
          <article>
            <div class="content-icon" aria-hidden="true">🧮</div>

            <h3>Why four formulas?</h3>

            <p>
              No single formula is universally accepted as the perfect way to
              calculate ideal weight. Comparing several formulas gives you a
              more balanced estimate.
            </p>
          </article>

          <article>
            <div class="content-icon" aria-hidden="true">📊</div>

            <h3>Why results differ</h3>

            <p>
              Each formula uses different starting weights and adjustments for
              every inch above five feet, so the estimates naturally vary.
            </p>
          </article>

          <article>
            <div class="content-icon" aria-hidden="true">💪</div>

            <h3>Body composition matters</h3>

            <p>
              Two people of the same height and weight may have very different
              amounts of muscle and body fat. Weight alone cannot show that
              difference.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="formula-section">
      <div class="content-container narrow-container">
        <div class="section-heading">
          <span class="eyebrow">CALCULATION METHODS</span>

          <h2>Formulas used by this calculator</h2>

          <p>
            Each method starts with a reference weight at five feet and then
            adjusts the result for every additional inch of height.
          </p>
        </div>

        <div class="formula-table-wrapper">
          <table class="formula-table">
            <thead>
              <tr>
                <th>Formula</th>
                <th>Male calculation</th>
                <th>Female calculation</th>
              </tr>
            </thead>

            <tbody>
              <tr>
                <td><strong>Devine</strong></td>
                <td>50 kg + 2.3 kg per inch</td>
                <td>45.5 kg + 2.3 kg per inch</td>
              </tr>

              <tr>
                <td><strong>Robinson</strong></td>
                <td>52 kg + 1.9 kg per inch</td>
                <td>49 kg + 1.7 kg per inch</td>
              </tr>

              <tr>
                <td><strong>Miller</strong></td>
                <td>56.2 kg + 1.41 kg per inch</td>
                <td>53.1 kg + 1.36 kg per inch</td>
              </tr>

              <tr>
                <td><strong>Hamwi</strong></td>
                <td>48 kg + 2.7 kg per inch</td>
                <td>45.5 kg + 2.2 kg per inch</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="table-note">
          For heights below five feet, this calculator extends the same formula
          downward by subtracting the corresponding amount per inch.
        </p>
      </div>
    </section>

    <section class="related-tools-section">
      <div class="page-container">
        <div class="section-heading">
          <span class="eyebrow">CONTINUE YOUR JOURNEY</span>

          <h2>Explore our other free calculators</h2>

          <p>
            Combine multiple tools to build a clearer picture of your starting
            point and daily needs.
          </p>
        </div>

        <div class="related-tools-grid">
          <a
            class="related-tool-card"
            href={`${baseURL}tools/bmi-calculator/`}
          >
            <span class="related-icon" aria-hidden="true">⚖️</span>

            <div>
              <h3>BMI Calculator</h3>
              <p>
                Calculate your BMI and view a weight range based on your
                height.
              </p>

              <strong>Open calculator →</strong>
            </div>
          </a>

          <a
            class="related-tool-card"
            href={`${baseURL}tools/calorie-calculator/`}
          >
            <span class="related-icon" aria-hidden="true">🔥</span>

            <div>
              <h3>Calorie Calculator</h3>
              <p>
                Estimate your BMR, TDEE, maintenance calories, and goal-based
                targets.
              </p>

              <strong>Open calculator →</strong>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="content-container narrow-container">
        <div class="section-heading">
          <span class="eyebrow">COMMON QUESTIONS</span>

          <h2>Ideal Weight Calculator FAQ</h2>
        </div>

        <div class="faq-list">
          <details>
            <summary>How is ideal body weight calculated?</summary>

            <p>
              This calculator compares the Devine, Robinson, Miller, and Hamwi
              formulas. Each method uses your height and the selected
              sex-specific formula values to estimate body weight.
            </p>
          </details>

          <details>
            <summary>
              Why do the formulas give different results?
            </summary>

            <p>
              Each formula uses different reference weights and height
              adjustments. None of them can perfectly describe every person,
              so small differences between results are expected.
            </p>
          </details>

          <details>
            <summary>
              Is ideal weight the same as a healthy weight?
            </summary>

            <p>
              Not always. A healthy weight depends on more than height alone.
              Muscle mass, body fat, frame size, age, health conditions, and
              lifestyle can all affect what is appropriate for you.
            </p>
          </details>

          <details>
            <summary>
              What is the healthy BMI-based weight range?
            </summary>

            <p>
              The displayed range represents the weights corresponding to BMI
              values from 18.5 to 24.9 for your height. BMI is a screening
              measure and does not directly measure body fat.
            </p>
          </details>

          <details>
            <summary>
              Can athletes use this calculator?
            </summary>

            <p>
              Yes, but the results may be less useful for people with
              significantly above-average muscle mass. Athletes may weigh more
              than the calculated range while still having a healthy body
              composition.
            </p>
          </details>

          <details>
            <summary>
              Should I try to reach the exact average result?
            </summary>

            <p>
              No. The average is only an estimate, not a required target.
              Sustainable habits, health markers, and professional medical
              guidance are more important than reaching one exact number.
            </p>
          </details>
        </div>
      </div>
    </section>

    <section class="ebook-cta">
      <div class="page-container">
        <div class="ebook-cta-card">
          <div>
            <span class="eyebrow">READY FOR THE NEXT STEP?</span>

            <h2>Lose weight without extreme diets or constant hunger</h2>

            <p>
              Get practical, beginner-friendly guidance for building
              sustainable eating and weight-loss habits.
            </p>
          </div>

          <a href={`${baseURL}#purchase`}>
            Discover the ebook
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const form = document.getElementById("ideal-weight-form");
      const metricFields = document.getElementById("metric-fields");
      const imperialFields = document.getElementById("imperial-fields");
      const heightCmInput = document.getElementById("height-cm");
      const heightFeetInput = document.getElementById("height-feet");
      const heightInchesInput = document.getElementById("height-inches");
      const errorBox = document.getElementById("form-error");
      const resultsSection = document.getElementById("results");
      const recalculateButton = document.getElementById(
        "recalculate-button"
      );

      if (
        !form ||
        !metricFields ||
        !imperialFields ||
        !heightCmInput ||
        !heightFeetInput ||
        !heightInchesInput ||
        !errorBox ||
        !resultsSection
      ) {
        return;
      }

      const unitInputs = form.querySelectorAll('input[name="unit"]');

      const getSelectedValue = (name) => {
        const selected = form.querySelector(
          `input[name="${name}"]:checked`
        );

        return selected ? selected.value : "";
      };

      const roundToOne = (value) => {
        return Math.round(value * 10) / 10;
      };

      const kilogramsToPounds = (kilograms) => {
        return kilograms * 2.2046226218;
      };

      const centimetersToInches = (centimeters) => {
        return centimeters / 2.54;
      };

      const inchesToCentimeters = (inches) => {
        return inches * 2.54;
      };

      const formatNumber = (value) => {
        return new Intl.NumberFormat("en-US", {
          minimumFractionDigits: 1,
          maximumFractionDigits: 1,
        }).format(value);
      };

      const showError = (message) => {
        errorBox.textContent = message;
        errorBox.hidden = false;
      };

      const clearError = () => {
        errorBox.textContent = "";
        errorBox.hidden = true;
      };

      const updateUnitFields = () => {
        const unit = getSelectedValue("unit");
        const isMetric = unit === "metric";

        metricFields.hidden = !isMetric;
        imperialFields.hidden = isMetric;

        clearError();
      };

      unitInputs.forEach((input) => {
        input.addEventListener("change", updateUnitFields);
      });

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        clearError();

        const unit = getSelectedValue("unit");
        const sex = getSelectedValue("sex");

        let totalHeightInches;
        let heightCm;

        if (unit === "metric") {
          heightCm = Number.parseFloat(heightCmInput.value);

          if (
            !Number.isFinite(heightCm) ||
            heightCm < 120 ||
            heightCm > 230
          ) {
            showError(
              "Please enter a valid height between 120 and 230 cm."
            );

            heightCmInput.focus();
            return;
          }

          totalHeightInches = centimetersToInches(heightCm);
        } else {
          const feet = Number.parseFloat(heightFeetInput.value);
          const inches = Number.parseFloat(heightInchesInput.value);

          if (
            !Number.isFinite(feet) ||
            feet < 3 ||
            feet > 7 ||
            !Number.isFinite(inches) ||
            inches < 0 ||
            inches >= 12
          ) {
            showError(
              "Please enter a valid height using 3–7 feet and 0–11.9 inches."
            );

            heightFeetInput.focus();
            return;
          }

          totalHeightInches = feet * 12 + inches;
          heightCm = inchesToCentimeters(totalHeightInches);

          if (heightCm < 120 || heightCm > 230) {
            showError(
              "Please enter a total height between approximately 3 ft 11 in and 7 ft 7 in."
            );

            heightFeetInput.focus();
            return;
          }
        }

        const inchesFromFiveFeet = totalHeightInches - 60;

        const formulas =
          sex === "female"
            ? {
                devine: 45.5 + 2.3 * inchesFromFiveFeet,
                robinson: 49 + 1.7 * inchesFromFiveFeet,
                miller: 53.1 + 1.36 * inchesFromFiveFeet,
                hamwi: 45.5 + 2.2 * inchesFromFiveFeet,
              }
            : {
                devine: 50 + 2.3 * inchesFromFiveFeet,
                robinson: 52 + 1.9 * inchesFromFiveFeet,
                miller: 56.2 + 1.41 * inchesFromFiveFeet,
                hamwi: 48 + 2.7 * inchesFromFiveFeet,
              };

        const formulaValues = Object.values(formulas);
        const average =
          formulaValues.reduce((sum, value) => sum + value, 0) /
          formulaValues.length;

        const minimumFormula = Math.min(...formulaValues);
        const maximumFormula = Math.max(...formulaValues);

        const heightMeters = heightCm / 100;
        const healthyMinimum = 18.5 * heightMeters * heightMeters;
        const healthyMaximum = 24.9 * heightMeters * heightMeters;

        const outputUnit = unit === "metric" ? "kg" : "lb";

        const convertOutput = (kilograms) => {
          return unit === "metric"
            ? kilograms
            : kilogramsToPounds(kilograms);
        };

        const formatWeight = (kilograms) => {
          return `${formatNumber(
            roundToOne(convertOutput(kilograms))
          )} ${outputUnit}`;
        };

        document.getElementById("average-weight").textContent =
          formatNumber(roundToOne(convertOutput(average)));

        document.getElementById("average-unit").textContent =
          outputUnit;

        document.getElementById("formula-range").textContent =
          `${formatWeight(minimumFormula)} – ${formatWeight(
            maximumFormula
          )}`;

        document.getElementById("devine-result").textContent =
          formatWeight(formulas.devine);

        document.getElementById("robinson-result").textContent =
          formatWeight(formulas.robinson);

        document.getElementById("miller-result").textContent =
          formatWeight(formulas.miller);

        document.getElementById("hamwi-result").textContent =
          formatWeight(formulas.hamwi);

        document.getElementById(
          "healthy-range-result"
        ).textContent =
          `${formatWeight(healthyMinimum)} – ${formatWeight(
            healthyMaximum
          )}`;

        const displayedHeight =
          unit === "metric"
            ? `${formatNumber(roundToOne(heightCm))} cm`
            : `${heightFeetInput.value} ft ${heightInchesInput.value} in`;

        document.getElementById(
          "results-summary"
        ).textContent =
          `Estimates for a ${displayedHeight} ${
            sex === "female" ? "female" : "male"
          } formula profile.`;

        resultsSection.hidden = false;

        window.requestAnimationFrame(() => {
          resultsSection.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        });
      });

      if (recalculateButton) {
        recalculateButton.addEventListener("click", () => {
          form.scrollIntoView({
            behavior: "smooth",
            block: "center",
          });

          if (getSelectedValue("unit") === "metric") {
            heightCmInput.focus();
          } else {
            heightFeetInput.focus();
          }
        });
      }

      updateUnitFields();
    })();
