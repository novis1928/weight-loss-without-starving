</style>

<script is:inline>
  const form = document.getElementById("bmiForm");
  const heightInput = document.getElementById("height");
  const weightInput = document.getElementById("weight");
  const errorElement = document.getElementById("formError");
  const resultElement = document.getElementById("result");
  const bmiValueElement = document.getElementById("bmiValue");
  const categoryElement = document.getElementById("bmiCategory");
  const pointerElement = document.getElementById("gaugePointer");
  const healthyRangeElement = document.getElementById("healthyRange");
  const currentWeightElement = document.getElementById("currentWeight");
  const recommendationElement = document.getElementById("recommendation");

  const rows = {
    underweight: document.getElementById("row-underweight"),
    healthy: document.getElementById("row-healthy"),
    overweight: document.getElementById("row-overweight"),
    obesity: document.getElementById("row-obesity"),
  };

  const styles = {
    underweight: { label:"Underweight", background:"#dbeafe", color:"#1d4ed8" },
    healthy: { label:"Healthy Weight", background:"#dcfce7", color:"#166534" },
    overweight: { label:"Overweight", background:"#fef9c3", color:"#854d0e" },
    obesity: { label:"Obesity", background:"#fee2e2", color:"#991b1b" },
  };

  function getCategory(bmi) {
    if (bmi < 18.5) return "underweight";
    if (bmi < 25) return "healthy";
    if (bmi < 30) return "overweight";
    return "obesity";
  }

  function updateRows(category) {
    Object.values(rows).forEach((row) => row.classList.remove("active"));
    rows[category].classList.add("active");
  }

  function updatePointer(bmi) {
    const min = 15;
    const max = 40;
    const limited = Math.min(Math.max(bmi, min), max);
    pointerElement.style.left = `${((limited - min) / (max - min)) * 100}%`;
  }

  form.addEventListener("submit", (event) => {
    event.preventDefault();

    const heightCm = Number(heightInput.value);
    const weightKg = Number(weightInput.value);
    errorElement.textContent = "";

    if (!heightCm || !weightKg) {
      errorElement.textContent = "Please enter both your height and weight.";
      resultElement.classList.add("hidden");
      return;
    }

    if (heightCm < 100 || heightCm > 250) {
      errorElement.textContent = "Please enter a height between 100 and 250 cm.";
      resultElement.classList.add("hidden");
      return;
    }

    if (weightKg < 30 || weightKg > 350) {
      errorElement.textContent = "Please enter a weight between 30 and 350 kg.";
      resultElement.classList.add("hidden");
      return;
    }

    const heightM = heightCm / 100;
    const bmi = weightKg / (heightM * heightM);
    const category = getCategory(bmi);
    const style = styles[category];
    const healthyMin = 18.5 * heightM * heightM;
    const healthyMax = 24.9 * heightM * heightM;

    bmiValueElement.textContent = bmi.toFixed(1);
    bmiValueElement.style.color = style.color;

    categoryElement.textContent = style.label;
    categoryElement.style.background = style.background;
    categoryElement.style.color = style.color;

    healthyRangeElement.textContent = `${healthyMin.toFixed(1)}–${healthyMax.toFixed(1)} kg`;
    currentWeightElement.textContent = `${weightKg.toFixed(1)} kg`;

    if (category === "underweight") {
      recommendationElement.innerHTML =
        `Reaching the lower end of the healthy range would mean gaining approximately <strong>${Math.max(healthyMin - weightKg, 0).toFixed(1)} kg</strong>.`;
    } else if (category === "healthy") {
      recommendationElement.textContent =
        "Your result falls within the standard healthy BMI range. Focus on sustainable habits.";
    } else {
      recommendationElement.innerHTML =
        `Reaching the upper end of the healthy range would mean losing approximately <strong>${Math.max(weightKg - healthyMax, 0).toFixed(1)} kg</strong>.`;
    }

    updatePointer(bmi);
    updateRows(category);
    resultElement.classList.remove("hidden");
  });
</script>
