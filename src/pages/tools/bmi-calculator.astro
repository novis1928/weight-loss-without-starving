---
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;
---

<Layout
  title="BMI Calculator | Free Body Mass Index Calculator"
  description="Calculate your BMI instantly, see your BMI category, estimate a healthy weight range, and understand what your result means."
>
  <main>
    <section class="hero">
      <div class="container hero-content">
        <span class="badge">FREE HEALTH TOOL</span>
        <h1>BMI Calculator</h1>
        <p>
          Calculate your Body Mass Index in seconds, see your BMI category,
          and estimate a healthy weight range for your height.
        </p>
      </div>
    </section>

    <section class="calculator-section">
      <div class="container calculator-grid">
        <div class="calculator-card">
          <div class="card-heading">
            <span class="step-number">1</span>
            <div>
              <h2>Calculate Your BMI</h2>
              <p>Enter your height and weight below.</p>
            </div>
          </div>

          <form id="bmiForm" novalidate>
            <div class="input-grid">
              <div class="form-group">
                <label for="height">Height</label>
                <div class="input-wrapper">
                  <input id="height" type="number" inputmode="decimal" min="100" max="250" step="0.1" placeholder="e.g. 175" required />
                  <span>cm</span>
                </div>
              </div>

              <div class="form-group">
                <label for="weight">Weight</label>
                <div class="input-wrapper">
                  <input id="weight" type="number" inputmode="decimal" min="30" max="350" step="0.1" placeholder="e.g. 72" required />
                  <span>kg</span>
                </div>
              </div>
            </div>

            <p id="formError" class="form-error" role="alert"></p>

            <button type="submit" class="calculate-button">
              Calculate My BMI
            </button>
          </form>

          <div id="result" class="result hidden" aria-live="polite">
            <span class="result-label">Your BMI</span>
            <div id="bmiValue" class="bmi-value">0.0</div>
            <div id="bmiCategory" class="category-badge">Healthy Weight</div>

            <div class="bmi-gauge">
              <div class="gauge-labels">
                <span>Underweight</span>
                <span>Healthy</span>
                <span>Overweight</span>
                <span>Obesity</span>
              </div>

              <div class="gauge-bar">
                <div class="gauge-underweight"></div>
                <div class="gauge-healthy"></div>
                <div class="gauge-overweight"></div>
                <div class="gauge-obesity"></div>

                <div id="gaugePointer" class="gauge-pointer">
                  <span></span>
                </div>
              </div>

              <div class="gauge-values">
                <span>15</span>
                <span>18.5</span>
                <span>25</span>
                <span>30</span>
                <span>40+</span>
              </div>
            </div>

            <div class="result-details">
              <article>
                <span>Healthy weight range</span>
                <strong id="healthyRange">—</strong>
              </article>

              <article>
                <span>Your current weight</span>
                <strong id="currentWeight">—</strong>
              </article>
            </div>

            <div id="recommendation" class="recommendation"></div>

            <p class="result-note">
              BMI is a screening estimate and not a medical diagnosis.
            </p>
          </div>
        </div>

        <aside class="info-card">
          <span class="eyebrow">BMI AT A GLANCE</span>
          <h2>Adult BMI categories</h2>

          <div class="category-list">
            <div id="row-underweight" class="category-row">
              <span class="category-dot dot-blue"></span>
              <div><strong>Underweight</strong><span>Below 18.5</span></div>
            </div>

            <div id="row-healthy" class="category-row">
              <span class="category-dot dot-green"></span>
              <div><strong>Healthy weight</strong><span>18.5–24.9</span></div>
            </div>

            <div id="row-overweight" class="category-row">
              <span class="category-dot dot-yellow"></span>
              <div><strong>Overweight</strong><span>25.0–29.9</span></div>
            </div>

            <div id="row-obesity" class="category-row">
              <span class="category-dot dot-red"></span>
              <div><strong>Obesity</strong><span>30.0 and above</span></div>
            </div>
          </div>

          <p class="info-note">
            These categories are commonly used for adults. BMI should be interpreted with other health information.
          </p>
        </aside>
      </div>
    </section>

    <section class="content-section">
      <div class="container content-grid">
        <article class="content-card">
          <span class="eyebrow">UNDERSTAND YOUR RESULT</span>
          <h2>What is BMI?</h2>
          <p>
            Body Mass Index, or BMI, is a simple screening calculation that compares your weight with your height.
          </p>
          <p>
            BMI does not directly measure body fat, muscle mass, bone density, or where fat is stored.
          </p>
        </article>

        <article class="content-card">
          <span class="eyebrow">THE FORMULA</span>
          <h2>How is BMI calculated?</h2>
          <div class="formula-box">BMI = weight (kg) ÷ height² (m)</div>
          <p>
            For example, a person who weighs 72 kg and is 1.75 m tall has a BMI of approximately 23.5.
          </p>
        </article>
      </div>
    </section>

    <section class="limitations-section">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">IMPORTANT CONTEXT</span>
          <h2>Limitations of BMI</h2>
          <p>BMI can be useful, but it does not tell the whole story.</p>
        </div>

        <div class="limitations-grid">
          <article><span>01</span><h3>Muscle mass</h3><p>Muscular people may have a higher BMI without having excess body fat.</p></article>
          <article><span>02</span><h3>Body composition</h3><p>BMI cannot distinguish between fat, muscle, bone, and other body tissues.</p></article>
          <article><span>03</span><h3>Fat distribution</h3><p>It does not show where body fat is stored.</p></article>
          <article><span>04</span><h3>Individual differences</h3><p>Age, sex, ethnicity, pregnancy, and medical conditions may affect interpretation.</p></article>
        </div>
      </div>
    </section>


    <section class="related-tools-section" aria-labelledby="related-tools-title">
      <div class="container">
        <div class="section-heading related-heading">
          <span class="eyebrow">EXPLORE MORE FREE TOOLS</span>
          <h2 id="related-tools-title">Related calculators</h2>
          <p>
            Use these free tools alongside your BMI result to build a clearer
            picture of your weight, energy needs, and body composition.
          </p>
        </div>

        <div class="related-tools-grid">
          <a
            class="related-tool-card"
            href={`${baseURL}tools/calorie-calculator/`}
            aria-label="Open Calorie Calculator"
          >
            <div class="related-tool-top">
              <span class="related-tool-icon" aria-hidden="true">🔥</span>
              <span class="related-tool-status">Free tool</span>
            </div>

            <h3>Calorie Calculator</h3>
            <p>
              Estimate your BMR, TDEE, maintenance calories, and daily calorie
              targets for weight loss or weight gain.
            </p>

            <span class="related-tool-link">
              Open calculator <strong aria-hidden="true">→</strong>
            </span>
          </a>

          <a
            class="related-tool-card"
            href={`${baseURL}tools/ideal-weight-calculator/`}
            aria-label="Open Ideal Weight Calculator"
          >
            <div class="related-tool-top">
              <span class="related-tool-icon" aria-hidden="true">🎯</span>
              <span class="related-tool-status">Free tool</span>
            </div>

            <h3>Ideal Weight Calculator</h3>
            <p>
              Compare four established ideal-weight formulas and view a
              healthy BMI-based weight range for your height.
            </p>

            <span class="related-tool-link">
              Open calculator <strong aria-hidden="true">→</strong>
            </span>
          </a>

          <a
            class="related-tool-card"
            href={`${baseURL}tools/body-fat-calculator/`}
            aria-label="Open Body Fat Calculator"
          >
            <div class="related-tool-top">
              <span class="related-tool-icon" aria-hidden="true">📏</span>
              <span class="related-tool-status">Free tool</span>
            </div>

            <h3>Body Fat Calculator</h3>
            <p>
              Estimate your body fat percentage using simple measurements and
              view your estimated fat mass and lean mass.
            </p>

            <span class="related-tool-link">
              Open calculator <strong aria-hidden="true">→</strong>
            </span>
          </a>

          <a
            class="related-tool-card"
            href={`${baseURL}tools/macro-calculator/`}
            aria-label="Open Macro Calculator"
          >
            <div class="related-tool-top">
              <span class="related-tool-icon" aria-hidden="true">🥗</span>
              <span class="related-tool-status">Free tool</span>
            </div>

            <h3>Macro Calculator</h3>
            <p>
              Calculate your daily calories, protein, carbohydrates, and fat
              for weight loss, maintenance, or muscle gain.
            </p>

            <span class="related-tool-link">
              Open calculator <strong aria-hidden="true">→</strong>
            </span>
          </a>
        </div>

        <div class="all-tools-link">
          <a href={`${baseURL}tools/`}>
            View all free tools <strong aria-hidden="true">→</strong>
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-card">
          <div>
            <span class="eyebrow">READY FOR THE NEXT STEP?</span>
            <h2>Lose weight without starving</h2>
            <p>
              Get practical guidance, simple meal ideas, and sustainable habits in the complete eBook.
            </p>
          </div>
          <a href="https://payhip.com/b/eW3MA" target="_blank" rel="noopener">Get the eBook</a>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <div class="container narrow">
        <div class="section-heading">
          <span class="eyebrow">COMMON QUESTIONS</span>
          <h2>BMI Calculator FAQ</h2>
        </div>

        <details>
          <summary>Is BMI accurate?</summary>
          <p>BMI is useful as a general screening tool, but it is not a direct measurement of body fat or overall health.</p>
        </details>

        <details>
          <summary>Is BMI different for men and women?</summary>
          <p>The standard adult BMI formula and category ranges are the same for men and women.</p>
        </details>

        <details>
          <summary>Can athletes use BMI?</summary>
          <p>Athletes with significant muscle mass may receive an overweight BMI result even when body fat is low.</p>
        </details>

        <details>
          <summary>Can children use this calculator?</summary>
          <p>This calculator is designed for adults. Children need age- and sex-specific growth charts.</p>
        </details>
      </div>
    </section>

    <section class="disclaimer-section">
      <div class="container narrow">
        <p>
          <strong>Medical disclaimer:</strong> This calculator is for general educational purposes only and is not a substitute for medical advice.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  :global(*) { box-sizing: border-box; }

  .container {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .narrow { max-width: 820px; }

  .hero {
    padding: 55px 0;
    background:
      radial-gradient(circle at top left, rgba(34,197,94,.15), transparent 36%),
      linear-gradient(180deg,#f0fdf4 0%,#fff 100%);
    text-align: center;
  }

  .hero-content { max-width: 780px; }

  .badge,.eyebrow {
    display: inline-block;
    color: #15803d;
    font-size: .78rem;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .badge {
    padding: 9px 16px;
    border-radius: 999px;
    background: #dcfce7;
    margin-bottom: 22px;
  }

  .hero h1 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2.6rem,7vw,4.7rem);
    line-height: 1.03;
    letter-spacing: -.055em;
  }

  .hero p {
    max-width: 700px;
    margin: 24px auto 0;
    color: #475569;
    font-size: 1.15rem;
    line-height: 1.75;
  }

  .calculator-section { padding: 72px 0; background: #f8fafc; }

  .calculator-grid {
    display: grid;
    grid-template-columns: minmax(0,1.55fr) minmax(280px,.75fr);
    gap: 28px;
    align-items: start;
  }

  .calculator-card,.info-card,.content-card,.limitations-grid article,details {
    border: 1px solid #e2e8f0;
    background: #fff;
    box-shadow: 0 18px 50px rgba(15,23,42,.07);
  }

  .calculator-card { padding: 38px; border-radius: 26px; }

  .card-heading {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 30px;
  }

  .step-number {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 14px;
    background: #22c55e;
    color: #fff;
    font-weight: 800;
  }

  .card-heading h2,.info-card h2,.content-card h2,.section-heading h2,.cta-card h2 {
    margin: 0;
    color: #0f172a;
    letter-spacing: -.035em;
  }

  .card-heading p,.section-heading p { margin: 7px 0 0; color: #64748b; }

  .input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .form-group label {
    display: block;
    margin-bottom: 9px;
    color: #334155;
    font-weight: 700;
  }

  .input-wrapper { position: relative; }

  .input-wrapper input {
    width: 100%;
    min-height: 58px;
    padding: 0 64px 0 16px;
    border: 1px solid #cbd5e1;
    border-radius: 14px;
    font: inherit;
    font-size: 1.05rem;
    outline: none;
  }

  .input-wrapper input:focus {
    border-color: #22c55e;
    box-shadow: 0 0 0 4px rgba(34,197,94,.14);
  }

  .input-wrapper span {
    position: absolute;
    top: 50%;
    right: 16px;
    color: #64748b;
    font-weight: 700;
    transform: translateY(-50%);
  }

  .form-error {
    min-height: 24px;
    margin: 12px 0 0;
    color: #dc2626;
    font-size: .92rem;
    font-weight: 700;
  }

  .calculate-button {
    width: 100%;
    min-height: 58px;
    border: 0;
    border-radius: 14px;
    background: #22c55e;
    color: #fff;
    font: inherit;
    font-size: 1.05rem;
    font-weight: 800;
    cursor: pointer;
  }

  .calculate-button:hover { background: #16a34a; }

  .result {
    margin-top: 34px;
    padding-top: 32px;
    border-top: 1px solid #e2e8f0;
    text-align: center;
  }

  .hidden { display: none; }

  .result-label {
    color: #64748b;
    font-size: .85rem;
    font-weight: 800;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .bmi-value {
    margin-top: 4px;
    color: #16a34a;
    font-size: clamp(4rem,10vw,6rem);
    font-weight: 900;
    line-height: 1;
  }

  .category-badge {
    display: inline-flex;
    margin-top: 14px;
    padding: 10px 16px;
    border-radius: 999px;
    background: #dcfce7;
    color: #166534;
    font-weight: 800;
  }

  .bmi-gauge { margin-top: 38px; }

  .gauge-labels,.gauge-bar {
    display: grid;
    grid-template-columns: 14% 26% 20% 40%;
  }

  .gauge-labels {
    margin-bottom: 10px;
    color: #64748b;
    font-size: .72rem;
    font-weight: 800;
    text-align: center;
  }

  .gauge-bar {
    position: relative;
    height: 18px;
  }

  .gauge-underweight { background:#60a5fa; border-radius:999px 0 0 999px; }
  .gauge-healthy { background:#22c55e; }
  .gauge-overweight { background:#facc15; }
  .gauge-obesity { background:#ef4444; border-radius:0 999px 999px 0; }

  .gauge-pointer {
    position:absolute;
    top:-12px;
    left:0;
    width:3px;
    height:42px;
    background:#0f172a;
    transform:translateX(-50%);
    transition:left .55s ease;
  }

  .gauge-pointer span {
    position:absolute;
    top:-5px;
    left:50%;
    width:14px;
    height:14px;
    border:3px solid #fff;
    border-radius:50%;
    background:#0f172a;
    transform:translateX(-50%);
  }

  .gauge-values {
    display:flex;
    justify-content:space-between;
    margin-top:12px;
    color:#64748b;
    font-size:.78rem;
  }

  .result-details {
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:14px;
    margin-top:32px;
  }

  .result-details article {
    padding:18px;
    border:1px solid #e2e8f0;
    border-radius:16px;
    background:#f8fafc;
  }

  .result-details span,.result-details strong { display:block; }
  .result-details span { color:#64748b; font-size:.85rem; }
  .result-details strong { margin-top:7px; color:#0f172a; }

  .recommendation {
    margin-top:18px;
    padding:18px;
    border-radius:16px;
    background:#f0fdf4;
    color:#166534;
    line-height:1.65;
    text-align:left;
  }

  .result-note { color:#64748b; font-size:.82rem; }

  .info-card {
    padding:30px;
    border-radius:24px;
    position:sticky;
    top:100px;
  }

  .info-card h2 { margin-top:9px; font-size:1.55rem; }

  .category-list {
    display:grid;
    gap:10px;
    margin-top:24px;
  }

  .category-row {
    display:flex;
    gap:13px;
    align-items:center;
    padding:14px;
    border:1px solid #e2e8f0;
    border-radius:14px;
  }

  .category-row.active {
    border-color:#22c55e;
    background:#f0fdf4;
  }

  .category-dot {
    width:13px;
    height:13px;
    border-radius:50%;
  }

  .dot-blue { background:#60a5fa; }
  .dot-green { background:#22c55e; }
  .dot-yellow { background:#facc15; }
  .dot-red { background:#ef4444; }

  .category-row strong,.category-row span { display:block; }
  .category-row div span { margin-top:2px; color:#64748b; font-size:.82rem; }

  .info-note { color:#64748b; line-height:1.65; }

  .content-section,.faq-section { padding:78px 0; background:#fff; }

  .content-grid {
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:24px;
  }

  .content-card {
    padding:32px;
    border-radius:22px;
  }

  .content-card p {
    color:#475569;
    line-height:1.75;
  }

  .formula-box {
    margin:22px 0;
    padding:20px;
    border-radius:15px;
    background:#0f172a;
    color:#fff;
    font-weight:800;
    text-align:center;
  }

  .limitations-section { padding:78px 0; background:#f8fafc; }

  .section-heading { max-width:720px; margin-bottom:34px; }

  .section-heading h2 {
    margin-top:9px;
    font-size:clamp(2rem,5vw,3rem);
  }

  .limitations-grid {
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:18px;
  }

  .limitations-grid article {
    padding:25px;
    border-radius:19px;
  }

  .limitations-grid article > span {
    color:#22c55e;
    font-weight:900;
  }

  .limitations-grid p {
    color:#64748b;
    line-height:1.65;
  }


  .related-tools-section {
    padding: 78px 0;
    background:
      radial-gradient(circle at top left, rgba(34,197,94,.1), transparent 32%),
      #fff;
  }

  .related-heading {
    margin-bottom: 34px;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .related-tools-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .related-tool-card {
    display: flex;
    min-width: 0;
    min-height: 330px;
    flex-direction: column;
    padding: 28px;
    border: 1px solid #dcfce7;
    border-radius: 22px;
    background:
      radial-gradient(circle at top right, rgba(34,197,94,.11), transparent 34%),
      #fff;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 50px rgba(15,23,42,.07);
    transition:
      transform .2s ease,
      border-color .2s ease,
      box-shadow .2s ease;
  }

  .related-tool-card:hover {
    border-color: #22c55e;
    box-shadow: 0 26px 62px rgba(15,23,42,.12);
    transform: translateY(-4px);
  }

  .related-tool-card:focus-visible,
  .all-tools-link a:focus-visible {
    outline: 3px solid rgba(34,197,94,.35);
    outline-offset: 4px;
  }

  .related-tool-top {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
  }

  .related-tool-icon {
    display: grid;
    width: 58px;
    height: 58px;
    flex-shrink: 0;
    place-items: center;
    border-radius: 17px;
    background: #dcfce7;
    font-size: 1.7rem;
  }

  .related-tool-status {
    display: inline-flex;
    align-items: center;
    min-height: 29px;
    padding: 0 11px;
    border-radius: 999px;
    background: #f0fdf4;
    color: #166534;
    font-size: .69rem;
    font-weight: 800;
    letter-spacing: .05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .related-tool-card h3 {
    margin: 22px 0 0;
    color: #0f172a;
    font-size: 1.4rem;
    line-height: 1.2;
    letter-spacing: -.03em;
  }

  .related-tool-card p {
    margin: 13px 0 0;
    color: #64748b;
    line-height: 1.7;
  }

  .related-tool-link {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    margin-top: auto;
    padding-top: 24px;
    color: #15803d;
    font-weight: 800;
  }

  .related-tool-link strong {
    font-size: 1.2rem;
    transition: transform .2s ease;
  }

  .related-tool-card:hover .related-tool-link strong {
    transform: translateX(4px);
  }

  .all-tools-link {
    display: flex;
    justify-content: center;
    margin-top: 30px;
  }

  .all-tools-link a {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 14px 20px;
    border-radius: 13px;
    background: #22c55e;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 14px 30px rgba(34,197,94,.23);
    transition:
      transform .2s ease,
      background .2s ease,
      box-shadow .2s ease;
  }

  .all-tools-link a:hover {
    background: #16a34a;
    box-shadow: 0 18px 36px rgba(34,197,94,.3);
    transform: translateY(-2px);
  }

  .cta-section { padding:24px 0 78px; }

