---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;

const pageTitle = "BMI Calculator | Free Body Mass Index Calculator";
const pageDescription =
  "Calculate your BMI instantly, view your adult BMI category, estimate a healthy weight range, and understand the limitations of BMI.";

const canonicalURL = Astro.site
  ? new URL(`${baseURL}tools/bmi-calculator/`, Astro.site).toString()
  : `${baseURL}tools/bmi-calculator/`;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "BMI Calculator",
      url: canonicalURL,
      applicationCategory: "HealthApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript",
      description: pageDescription,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "Is BMI accurate?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "BMI is useful as a general screening estimate, but it does not directly measure body fat, muscle mass, fat distribution, or overall health.",
          },
        },
        {
          "@type": "Question",
          name: "Is BMI different for men and women?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "The standard adult BMI formula and category ranges are the same for men and women, although interpretation may differ between individuals.",
          },
        },
        {
          "@type": "Question",
          name: "Can athletes use BMI?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Athletes with substantial muscle mass may receive a high BMI result even when their body-fat level is not high.",
          },
        },
        {
          "@type": "Question",
          name: "Can children use this calculator?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No. This calculator is designed for adults. Children and teenagers require age-specific and sex-specific growth charts.",
          },
        },
      ],
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />

  <main class="calculator-page">
    <section class="hero">
      <div class="page-container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={baseURL}>Home</a>
          <span aria-hidden="true">/</span>
          <a href={`${baseURL}tools/`}>Tools</a>
          <span aria-hidden="true">/</span>
          <span>BMI Calculator</span>
        </nav>

        <div class="hero-content">
          <span class="eyebrow">FREE HEALTH TOOL</span>
          <h1>BMI Calculator</h1>
          <p>
            Calculate your Body Mass Index, view your adult BMI category, and
            estimate a healthy BMI-based weight range for your height.
          </p>

          <div class="badges" aria-label="Calculator features">
            <span>Instant result</span>
            <span>Healthy weight range</span>
            <span>Visual BMI scale</span>
            <span>No signup</span>
          </div>
        </div>
      </div>
    </section>

    <section class="calculator-section">
      <div class="page-container">
        <div class="calculator-layout">
          <div class="calculator-card">
            <div class="card-heading">
              <div>
                <span class="eyebrow">STEP 1</span>
                <h2>Enter your measurements</h2>
              </div>
              <div class="calculator-icon" aria-hidden="true">⚖️</div>
            </div>

            <form id="bmi-form" novalidate>
              <fieldset class="form-group">
                <legend>Unit system</legend>

                <div class="toggle-grid">
                  <label>
                    <input
                      type="radio"
                      name="unit"
                      value="metric"
                      checked
                    />
                    <span>Metric</span>
                  </label>

                  <label>
                    <input type="radio" name="unit" value="imperial" />
                    <span>Imperial</span>
                  </label>
                </div>
              </fieldset>

              <div id="metric-fields" class="field-grid">
                <div class="form-group">
                  <label for="height-cm">Height</label>
                  <div class="input-with-unit">
                    <input
                      id="height-cm"
                      type="number"
                      inputmode="decimal"
                      min="100"
                      max="250"
                      step="0.1"
                      value="175"
                    />
                    <span>cm</span>
                  </div>
                </div>

                <div class="form-group">
                  <label for="weight-kg">Weight</label>
                  <div class="input-with-unit">
                    <input
                      id="weight-kg"
                      type="number"
                      inputmode="decimal"
                      min="30"
                      max="350"
                      step="0.1"
                      value="72"
                    />
                    <span>kg</span>
                  </div>
                </div>
              </div>

              <div id="imperial-fields" hidden>
                <div class="field-grid imperial-height-grid">
                  <div class="form-group">
                    <label for="height-feet">Height</label>
                    <div class="input-with-unit">
                      <input
                        id="height-feet"
                        type="number"
                        inputmode="numeric"
                        min="3"
                        max="8"
                        step="1"
                        value="5"
                      />
                      <span>ft</span>
                    </div>
                  </div>

                  <div class="form-group inches-field">
                    <label for="height-inches">Inches</label>
                    <div class="input-with-unit">
                      <input
                        id="height-inches"
                        type="number"
                        inputmode="decimal"
                        min="0"
                        max="11.9"
                        step="0.1"
                        value="9"
                      />
                      <span>in</span>
                    </div>
                  </div>

                  <div class="form-group">
                    <label for="weight-lb">Weight</label>
                    <div class="input-with-unit">
                      <input
                        id="weight-lb"
                        type="number"
                        inputmode="decimal"
                        min="66"
                        max="772"
                        step="0.1"
                        value="159"
                      />
                      <span>lb</span>
                    </div>
                  </div>
                </div>
              </div>

              <div
                id="form-error"
                class="form-error"
                role="alert"
                hidden
              ></div>

              <button class="calculate-button" type="submit">
                <span>Calculate my BMI</span>
                <span aria-hidden="true">→</span>
              </button>
            </form>

            <p class="privacy-note">
              Your information is processed only in your browser and is not
              stored.
            </p>
          </div>

          <aside class="info-card">
            <span class="info-label">ADULT BMI CATEGORIES</span>
            <h2>Understand the scale</h2>
            <p>
              Standard adult BMI categories provide a quick screening estimate,
              but they do not describe body composition or overall health.
            </p>

            <div class="category-list">
              <div id="row-underweight" class="category-row">
                <span class="category-dot dot-blue"></span>
                <div>
                  <strong>Underweight</strong>
                  <span>Below 18.5</span>
                </div>
              </div>

              <div id="row-healthy" class="category-row">
                <span class="category-dot dot-green"></span>
                <div>
                  <strong>Healthy weight</strong>
                  <span>18.5–24.9</span>
                </div>
              </div>

              <div id="row-overweight" class="category-row">
                <span class="category-dot dot-yellow"></span>
                <div>
                  <strong>Overweight</strong>
                  <span>25.0–29.9</span>
                </div>
              </div>

              <div id="row-obesity" class="category-row">
                <span class="category-dot dot-red"></span>
                <div>
                  <strong>Obesity</strong>
                  <span>30.0 and above</span>
                </div>
              </div>
            </div>

            <div class="warning-box">
              <strong>Important</strong>
              <p>
                This calculator is intended for adults and does not replace
                individual medical assessment.
              </p>
            </div>
          </aside>
        </div>

        <section
          id="results"
          class="results-section"
          aria-live="polite"
          hidden
        >
          <div class="results-heading">
            <div>
              <span class="eyebrow">YOUR RESULT</span>
              <h2>Your estimated BMI</h2>
              <p id="results-summary">
                Based on the measurements you entered.
              </p>
            </div>

            <button id="recalculate-button" type="button">
              Edit measurements
            </button>
          </div>

          <div class="primary-result">
            <div>
              <span>BODY MASS INDEX</span>
              <div class="result-value">
                <strong id="bmi-result">—</strong>
              </div>
              <div id="category-badge" class="category-badge">
                BMI category
              </div>
            </div>

            <div class="result-side">
              <span>HEALTHY WEIGHT RANGE</span>
              <strong id="healthy-range">—</strong>
              <small>BMI range of 18.5–24.9</small>
            </div>
          </div>

          <div class="gauge-card">
            <div class="gauge-labels">
              <span>Underweight</span>
              <span>Healthy</span>
              <span>Overweight</span>
              <span>Obesity</span>
            </div>

            <div class="gauge-bar">
              <div class="gauge-underweight"></div>
              <div class="gauge-healthy"></div>
              <div class="gauge-overweight"></div>
              <div class="gauge-obesity"></div>

              <div id="gauge-pointer" class="gauge-pointer">
                <span></span>
              </div>
            </div>

            <div class="gauge-values">
              <span>15</span>
              <span>18.5</span>
              <span>25</span>
              <span>30</span>
              <span>40+</span>
            </div>
          </div>

          <div class="result-grid">
            <article class="result-card">
              <span>CURRENT WEIGHT</span>
              <h3 id="current-weight">—</h3>
              <p>The weight used in this calculation.</p>
            </article>

            <article class="result-card">
              <span>CATEGORY</span>
              <h3 id="category-result">—</h3>
              <p>Your position within the standard adult BMI categories.</p>
            </article>

            <article class="result-card">
              <span>WEIGHT DIFFERENCE</span>
              <h3 id="weight-difference">—</h3>
              <p id="difference-description">
                Comparison with the BMI-based healthy range.
              </p>
            </article>
          </div>

          <div id="recommendation" class="recommendation"></div>

          <div class="result-warning">
            <strong>BMI is only a screening estimate.</strong>
            <p>
              It does not directly measure body fat, muscle mass, bone density,
              health status, or where body fat is stored.
            </p>
          </div>
        </section>
      </div>
    </section>

    <section class="content-section shaded">
      <div class="content-container">
        <div class="section-heading">
          <span class="eyebrow">BMI BASICS</span>
          <h2>What does BMI tell you?</h2>
        </div>

        <div class="content-grid">
          <article>
            <div aria-hidden="true">📐</div>
            <h3>Height-to-weight comparison</h3>
            <p>
              BMI compares your weight with the square of your height to create
              a simple numerical screening estimate.
            </p>
          </article>

          <article>
            <div aria-hidden="true">📊</div>
            <h3>Adult category estimate</h3>
            <p>
              The result is compared with commonly used adult BMI categories.
            </p>
          </article>

          <article>
            <div aria-hidden="true">🧩</div>
            <h3>Only one part of the picture</h3>
            <p>
              Waist size, fitness, medical history, body composition, and other
              factors may provide important additional context.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="content-container narrow">
        <div class="section-heading">
          <span class="eyebrow">HOW IT WORKS</span>
          <h2>How this calculator determines BMI</h2>
        </div>

        <div class="steps">
          <article>
            <span>01</span>
            <div>
              <h3>Read your measurements</h3>
              <p>
                Metric entries use kilograms and centimeters. Imperial entries
                are converted to kilograms and meters.
              </p>
            </div>
          </article>

          <article>
            <span>02</span>
            <div>
              <h3>Apply the BMI formula</h3>
              <p>
                BMI equals body weight in kilograms divided by height in meters
                squared.
              </p>
            </div>
          </article>

          <article>
            <span>03</span>
            <div>
              <h3>Estimate a healthy range</h3>
              <p>
                The calculator determines the weights corresponding to BMI
                values of 18.5 and 24.9 for your height.
              </p>
            </div>
          </article>

          <article>
            <span>04</span>
            <div>
              <h3>Add context</h3>
              <p>
                Your result is shown with category information and a reminder
                that BMI is not a diagnosis.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="content-section shaded">
      <div class="content-container">
        <div class="section-heading">
          <span class="eyebrow">IMPORTANT CONTEXT</span>
          <h2>Limitations of BMI</h2>
        </div>

        <div class="content-grid limitations-grid">
          <article>
            <div aria-hidden="true">💪</div>
            <h3>Muscle mass</h3>
            <p>
              A muscular person may have a higher BMI without having high body
              fat.
            </p>
          </article>

          <article>
            <div aria-hidden="true">🧬</div>
            <h3>Body composition</h3>
            <p>
              BMI cannot distinguish fat, muscle, bone, and other body tissues.
            </p>
          </article>

          <article>
            <div aria-hidden="true">📍</div>
            <h3>Fat distribution</h3>
            <p>
              BMI does not show where body fat is stored or measure waist size.
            </p>
          </article>

          <article>
            <div aria-hidden="true">👤</div>
            <h3>Individual differences</h3>
            <p>
              Age, pregnancy, medical conditions, ethnicity, and other factors
              can affect interpretation.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="page-container">
        <div class="section-heading">
          <span class="eyebrow">RELATED TOOLS</span>
          <h2>Explore our other free calculators</h2>
          <p>
            Combine your BMI result with other estimates for a broader view of
            body composition, calorie needs, nutrition, and hydration.
          </p>
        </div>

        <div class="related-grid">
          <a href={`${baseURL}tools/calorie-calculator/`}>
            <span aria-hidden="true">🔥</span>
            <div>
              <h3>Calorie Calculator</h3>
              <p>
                Estimate maintenance calories and practical weight-change
                targets.
              </p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/ideal-weight-calculator/`}>
            <span aria-hidden="true">🎯</span>
            <div>
              <h3>Ideal Weight Calculator</h3>
              <p>
                Compare four common ideal-weight formulas and a BMI-based range.
              </p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/body-fat-calculator/`}>
            <span aria-hidden="true">📏</span>
            <div>
              <h3>Body Fat Calculator</h3>
              <p>
                Estimate body-fat percentage, fat mass, and lean mass.
              </p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/macro-calculator/`}>
            <span aria-hidden="true">🥗</span>
            <div>
              <h3>Macro Calculator</h3>
              <p>
                Estimate protein, carbohydrate, fat, and calorie targets.
              </p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/bmr-calculator/`}>
            <span aria-hidden="true">⚡</span>
            <div>
              <h3>BMR Calculator</h3>
              <p>
                Estimate the calories your body uses at complete rest.
              </p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/tdee-calculator/`}>
            <span aria-hidden="true">📊</span>
            <div>
              <h3>TDEE Calculator</h3>
              <p>
                Estimate total daily calorie expenditure based on activity.
              </p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/water-intake-calculator/`}>
            <span aria-hidden="true">💧</span>
            <div>
              <h3>Water Intake Calculator</h3>
              <p>
                Estimate a practical daily hydration starting point.
              </p>
              <strong>Open calculator →</strong>
            </div>
          </a>
        </div>

        <div class="all-tools-link">
          <a href={`${baseURL}tools/`}>
            View all free tools <strong aria-hidden="true">→</strong>
          </a>
        </div>
      </div>
    </section>

    <section class="content-section shaded">
      <div class="content-container narrow">
        <div class="section-heading">
          <span class="eyebrow">COMMON QUESTIONS</span>
          <h2>BMI Calculator FAQ</h2>
        </div>

        <div class="faq-list">
          <details>
            <summary>Is BMI accurate?</summary>
            <p>
              BMI is useful as a broad screening estimate, but it is not a
              direct measurement of body fat or overall health.
            </p>
          </details>

          <details>
            <summary>Is BMI different for men and women?</summary>
            <p>
              The standard adult BMI formula and category ranges are the same
              for men and women, although individual interpretation can differ.
            </p>
          </details>

          <details>
            <summary>Can athletes use BMI?</summary>
            <p>
              Athletes with substantial muscle mass may receive an overweight
              BMI result even when their body-fat level is relatively low.
            </p>
          </details>

          <details>
            <summary>Can children use this calculator?</summary>
            <p>
              No. Children and teenagers require age-specific and sex-specific
              growth charts rather than adult BMI categories.
            </p>
          </details>

          <details>
            <summary>Does a healthy BMI guarantee good health?</summary>
            <p>
              No. A BMI within the standard healthy range does not assess
              fitness, diet quality, blood pressure, cholesterol, or medical
              conditions.
            </p>
          </details>
        </div>
      </div>
    </section>

    <section class="ebook-cta">
      <div class="page-container">
        <div class="ebook-card">
          <div>
            <span class="eyebrow">READY FOR THE NEXT STEP?</span>
            <h2>Build sustainable habits beyond the numbers</h2>
            <p>
              Get practical weight-loss guidance, simple recipes, and realistic
              strategies without extreme dieting.
            </p>
          </div>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the eBook →
          </a>
        </div>
      </div>
    </section>

    <section class="disclaimer-section">
      <div class="content-container narrow">
        <p>
          <strong>Medical disclaimer:</strong> This calculator provides general
          educational estimates only. It is not a diagnosis and does not
          replace advice from a qualified healthcare professional.
        </p>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const form = document.getElementById("bmi-form");
      const metricFields = document.getElementById("metric-fields");
      const imperialFields = document.getElementById("imperial-fields");
      const errorBox = document.getElementById("form-error");
      const results = document.getElementById("results");
      const categoryBadge = document.getElementById("category-badge");
      const pointer = document.getElementById("gauge-pointer");
      const recommendation = document.getElementById("recommendation");

      if (
        !form ||
        !metricFields ||
        !imperialFields ||
        !errorBox ||
        !results ||
        !categoryBadge ||
        !pointer ||
        !recommendation
      ) {
        return;
      }

      const rows = {
        underweight: document.getElementById("row-underweight"),
        healthy: document.getElementById("row-healthy"),
        overweight: document.getElementById("row-overweight"),
        obesity: document.getElementById("row-obesity"),
      };

      const styles = {
        underweight: {
          label: "Underweight",
          background: "#dbeafe",
          color: "#1d4ed8",
        },
        healthy: {
          label: "Healthy weight",
          background: "#dcfce7",
          color: "#166534",
        },
        overweight: {
          label: "Overweight",
          background: "#fef9c3",
          color: "#854d0e",
        },
        obesity: {
          label: "Obesity",
          background: "#fee2e2",
          color: "#991b1b",
        },
      };

      const getSelectedValue = (name) =>
        form.querySelector(`input[name="${name}"]:checked`)?.value || "";

      const getNumber = (id) =>
        Number.parseFloat(document.getElementById(id)?.value || "");

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      const showError = (message) => {
        errorBox.textContent = message;
        errorBox.hidden = false;
      };

      const clearError = () => {
        errorBox.textContent = "";
        errorBox.hidden = true;
      };

      const getCategory = (bmi) => {
        if (bmi < 18.5) return "underweight";
        if (bmi < 25) return "healthy";
        if (bmi < 30) return "overweight";
        return "obesity";
      };

      const updateRows = (category) => {
        Object.values(rows).forEach((row) => row?.classList.remove("active"));
        rows[category]?.classList.add("active");
      };

      const updatePointer = (bmi) => {
        const minimum = 15;
        const maximum = 40;
        const limitedBMI = Math.min(Math.max(bmi, minimum), maximum);
        const position =
          ((limitedBMI - minimum) / (maximum - minimum)) * 100;

        pointer.style.left = `${position}%`;
      };

      const updateUnits = () => {
        const metric = getSelectedValue("unit") === "metric";
        metricFields.hidden = !metric;
        imperialFields.hidden = metric;
        clearError();
      };

      form
        .querySelectorAll('input[name="unit"]')
        .forEach((input) => input.addEventListener("change", updateUnits));

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        clearError();

        const unit = getSelectedValue("unit");
        let heightMeters;
        let weightKg;
        let currentWeightDisplay;

        if (unit === "metric") {
          const heightCm = getNumber("height-cm");
          weightKg = getNumber("weight-kg");

          if (
            !Number.isFinite(heightCm) ||
            heightCm < 100 ||
            heightCm > 250
          ) {
            showError("Please enter a height between 100 and 250 cm.");
            results.hidden = true;
            return;
          }

          if (
            !Number.isFinite(weightKg) ||
            weightKg < 30 ||
            weightKg > 350
          ) {
            showError("Please enter a weight between 30 and 350 kg.");
            results.hidden = true;
            return;
          }

          heightMeters = heightCm / 100;
          currentWeightDisplay = `${weightKg.toFixed(1)} kg`;
        } else {
          const feet = getNumber("height-feet");
          const inches = getNumber("height-inches");
          const weightLb = getNumber("weight-lb");

          if (
            !Number.isFinite(feet) ||
            feet < 3 ||
            feet > 8 ||
            !Number.isFinite(inches) ||
            inches < 0 ||
            inches >= 12
          ) {
            showError("Please enter a valid height in feet and inches.");
            results.hidden = true;
            return;
          }

          if (
            !Number.isFinite(weightLb) ||
            weightLb < 66 ||
            weightLb > 772
          ) {
            showError("Please enter a weight between 66 and 772 lb.");
            results.hidden = true;
            return;
          }

          heightMeters = (feet * 12 + inches) * 0.0254;
          weightKg = weightLb * 0.45359237;
          currentWeightDisplay = `${weightLb.toFixed(1)} lb`;
        }

        const bmi = weightKg / (heightMeters * heightMeters);
        const category = getCategory(bmi);
        const categoryStyle = styles[category];
        const healthyMinimumKg = 18.5 * heightMeters * heightMeters;
        const healthyMaximumKg = 24.9 * heightMeters * heightMeters;

        let healthyRangeDisplay;
        let differenceDisplay;
        let differenceDescription;

        if (unit === "metric") {
          healthyRangeDisplay =
            `${healthyMinimumKg.toFixed(1)}–${healthyMaximumKg.toFixed(1)} kg`;

          if (category === "underweight") {
            differenceDisplay =
              `+${Math.max(healthyMinimumKg - weightKg, 0).toFixed(1)} kg`;
            differenceDescription =
              "Approximate gain needed to reach BMI 18.5.";
          } else if (category === "healthy") {
            differenceDisplay = "Within range";
            differenceDescription =
              "Your weight falls within the BMI-based healthy range.";
          } else {
            differenceDisplay =
              `−${Math.max(weightKg - healthyMaximumKg, 0).toFixed(1)} kg`;
            differenceDescription =
              "Approximate loss needed to reach BMI 24.9.";
          }
        } else {
          const healthyMinimumLb = healthyMinimumKg / 0.45359237;
          const healthyMaximumLb = healthyMaximumKg / 0.45359237;
          const weightLb = weightKg / 0.45359237;

          healthyRangeDisplay =
            `${healthyMinimumLb.toFixed(1)}–${healthyMaximumLb.toFixed(1)} lb`;

          if (category === "underweight") {
            differenceDisplay =
              `+${Math.max(healthyMinimumLb - weightLb, 0).toFixed(1)} lb`;
            differenceDescription =
              "Approximate gain needed to reach BMI 18.5.";
          } else if (category === "healthy") {
            differenceDisplay = "Within range";
            differenceDescription =
              "Your weight falls within the BMI-based healthy range.";
          } else {
            differenceDisplay =
              `−${Math.max(weightLb - healthyMaximumLb, 0).toFixed(1)} lb`;
            differenceDescription =
              "Approximate loss needed to reach BMI 24.9.";
          }
        }

        setText("bmi-result", bmi.toFixed(1));
        setText("healthy-range", healthyRangeDisplay);
        setText("current-weight", currentWeightDisplay);
        setText("category-result", categoryStyle.label);
        setText("weight-difference", differenceDisplay);
        setText("difference-description", differenceDescription);
        setText(
          "results-summary",
          `Your result falls within the ${categoryStyle.label.toLowerCase()} category.`
        );

        categoryBadge.textContent = categoryStyle.label;
        categoryBadge.style.background = categoryStyle.background;
        categoryBadge.style.color = categoryStyle.color;

        if (category === "underweight") {
          recommendation.innerHTML =
            "Your BMI is below the standard healthy range. Consider discussing unexplained low weight or weight loss with a qualified healthcare professional.";
        } else if (category === "healthy") {
          recommendation.innerHTML =
            "Your BMI falls within the standard healthy range. Continue focusing on sustainable nutrition, movement, sleep, and overall health.";
        } else if (category === "overweight") {
          recommendation.innerHTML =
            "Your BMI falls within the overweight category. BMI alone cannot determine health, so consider waist size, fitness, medical history, and professional guidance.";
        } else {
          recommendation.innerHTML =
            "Your BMI falls within the obesity category. A qualified healthcare professional can help interpret this result and discuss appropriate next steps.";
        }

        updateRows(category);
        updatePointer(bmi);

        results.hidden = false;
        results.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      document
        .getElementById("recalculate-button")
        ?.addEventListener("click", () => {
          form.scrollIntoView({ behavior: "smooth", block: "start" });
        });

      updateUnits();
    })();
  </script>

