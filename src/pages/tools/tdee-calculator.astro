---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";

const rawBaseURL = import.meta.env.BASE_URL;
const baseURL = rawBaseURL.endsWith("/") ? rawBaseURL : `${rawBaseURL}/`;

const pageTitle = 'TDEE Calculator | Estimate Daily Calorie Needs';
const pageDescription = 'Use our free TDEE Calculator to estimate total daily energy expenditure, maintenance calories, and practical weight-change targets.';
const canonicalURL = new URL(`${baseURL}tools/tdee-calculator/`, Astro.site).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: 'TDEE Calculator',
      url: canonicalURL,
      applicationCategory: "HealthApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript",
      description: pageDescription,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: 'What is TDEE?',
          acceptedAnswer: { "@type": "Answer", text: 'Total daily energy expenditure is the estimated energy you use across a full day, including resting metabolism and activity.' },
        },
        {
          "@type": "Question",
          name: 'How is TDEE calculated?',
          acceptedAnswer: { "@type": "Answer", text: 'This calculator estimates BMR with the Mifflin-St Jeor equation and multiplies it by an activity factor.' },
        },
        {
          "@type": "Question",
          name: 'Is TDEE exact?',
          acceptedAnswer: { "@type": "Answer", text: 'No. It is a starting estimate and actual needs can differ.' },
        }
      ],
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <main class="calculator-page">
    <section class="hero"><div class="page-container"><nav class="breadcrumbs" aria-label="Breadcrumb"><a href={baseURL}>Home</a><span>/</span><a href={`${baseURL}tools/`}>Tools</a><span>/</span><span>TDEE Calculator</span></nav><div class="hero-content"><span class="eyebrow">FREE CALORIE TOOL</span><h1>TDEE Calculator</h1><p>Estimate how many calories you use in a typical day based on your body measurements and activity level.</p><div class="badges"><span>BMR and TDEE</span><span>Activity adjustment</span><span>Goal estimates</span><span>Metric and imperial</span></div></div></div></section>

    <section class="calculator-section"><div class="page-container"><div class="calculator-layout">
      <div class="calculator-card"><div class="card-heading"><div><span class="eyebrow">STEP 1</span><h2>Enter your information</h2></div><div class="calculator-icon">📊</div></div>
        <form id="tdee-form" novalidate>
          <fieldset class="form-group"><legend>Unit system</legend><div class="toggle-grid"><label><input type="radio" name="unit" value="metric" checked /><span>Metric</span></label><label><input type="radio" name="unit" value="imperial" /><span>Imperial</span></label></div></fieldset>
          <fieldset class="form-group"><legend>Sex used by the formula</legend><div class="option-grid two-columns"><label class="option-card"><input type="radio" name="sex" value="male" checked /><span><strong>Male</strong><small>Male equation constant</small></span></label><label class="option-card"><input type="radio" name="sex" value="female" /><span><strong>Female</strong><small>Female equation constant</small></span></label></div></fieldset>
          <div class="field-grid"><div class="form-group"><label for="age">Age</label><div class="input-with-unit"><input id="age" type="number" min="18" max="100" value="30" /><span>years</span></div></div><div id="metric-weight" class="form-group"><label for="weight-kg">Weight</label><div class="input-with-unit"><input id="weight-kg" type="number" min="35" max="300" step="0.1" value="75" /><span>kg</span></div></div><div id="imperial-weight" class="form-group" hidden><label for="weight-lb">Weight</label><div class="input-with-unit"><input id="weight-lb" type="number" min="77" max="661" step="0.1" value="165" /><span>lb</span></div></div></div>
          <div id="metric-height" class="form-group"><label for="height-cm">Height</label><div class="input-with-unit"><input id="height-cm" type="number" min="120" max="230" step="0.1" value="175" /><span>cm</span></div></div>
          <div id="imperial-height" class="form-group" hidden><label>Height</label><div class="field-grid"><div class="input-with-unit"><input id="height-feet" type="number" min="3" max="7" value="5" /><span>ft</span></div><div class="input-with-unit"><input id="height-inches" type="number" min="0" max="11.9" step="0.1" value="9" /><span>in</span></div></div></div>
          <div class="form-group"><label for="activity">Activity level</label><select id="activity"><option value="1.2">Sedentary — little or no exercise</option><option value="1.375">Lightly active — 1–3 days/week</option><option value="1.55" selected>Moderately active — 3–5 days/week</option><option value="1.725">Very active — 6–7 days/week</option><option value="1.9">Extra active — hard training or physical job</option></select></div>
          <div id="form-error" class="form-error" role="alert" hidden></div><button class="calculate-button" type="submit"><span>Calculate my TDEE</span><span>→</span></button>
        </form><p class="privacy-note">Your information is processed only in your browser and is not stored.</p>
      </div>
      <aside class="info-card"><span class="info-label">WHAT YOU WILL GET</span><h2>Your estimated daily energy use</h2><p>TDEE combines estimated resting energy with a broad activity multiplier.</p><ul><li><span>✓</span> Estimated BMR</li><li><span>✓</span> Maintenance calories</li><li><span>✓</span> Moderate deficit estimate</li><li><span>✓</span> Small surplus estimate</li></ul><div class="warning-box"><strong>Important</strong><p>Activity categories are broad. Compare the estimate with real weight trends over several weeks.</p></div></aside>
    </div>

    <section id="results" class="results-section" aria-live="polite" hidden><div class="results-heading"><div><span class="eyebrow">YOUR RESULTS</span><h2>Estimated daily calorie needs</h2><p id="results-summary">Based on your information and activity selection.</p></div><button id="recalculate-button" type="button">Edit information</button></div>
      <div class="primary-result"><div><span>ESTIMATED TDEE</span><div class="result-value"><strong id="tdee-result">—</strong><small>kcal/day</small></div><p>Estimated calories for maintaining your current weight.</p></div><div class="result-side"><span>ESTIMATED BMR</span><strong id="bmr-result">— kcal</strong><small>Before activity adjustment</small></div></div>
      <div class="result-grid"><article class="result-card"><span>GENTLE LOSS</span><h3><strong id="gentle-loss">—</strong> kcal</h3><p>Approximately 10% below maintenance.</p></article><article class="result-card"><span>MODERATE LOSS</span><h3><strong id="moderate-loss">—</strong> kcal</h3><p>Approximately 20% below maintenance.</p></article><article class="result-card"><span>SMALL SURPLUS</span><h3><strong id="small-surplus">—</strong> kcal</h3><p>Approximately 10% above maintenance.</p></article></div>
      <div id="low-calorie-warning" class="result-warning" hidden><strong>One or more weight-loss estimates are relatively low.</strong><p>A calculator cannot determine whether a low-calorie intake is safe for you. Consider guidance from a qualified healthcare professional.</p></div>
    </section></div></section>

    <section class="content-section shaded"><div class="content-container"><div class="section-heading"><span class="eyebrow">TDEE BASICS</span><h2>What contributes to daily energy use?</h2></div><div class="content-grid"><article><div>⚡</div><h3>Resting metabolism</h3><p>BMR is usually the largest part of daily energy expenditure.</p></article><article><div>🚶</div><h3>Daily movement</h3><p>Work, walking, chores, training, and fidgeting all use energy.</p></article><article><div>🍽️</div><h3>Food processing</h3><p>Digestion and nutrient processing also require energy.</p></article></div></div></section>

    <section class="content-section"><div class="content-container narrow"><div class="section-heading"><span class="eyebrow">HOW IT WORKS</span><h2>How the TDEE estimate is calculated</h2></div><div class="steps"><article><span>01</span><div><h3>Estimate BMR</h3><p>The Mifflin-St Jeor equation estimates resting energy expenditure.</p></div></article><article><span>02</span><div><h3>Apply activity factor</h3><p>BMR is multiplied by the selected activity category.</p></div></article><article><span>03</span><div><h3>Create goal comparisons</h3><p>The calculator shows maintenance, two deficit options, and a small surplus.</p></div></article><article><span>04</span><div><h3>Check real-world progress</h3><p>Track average body weight and adjust gradually if your trend differs from the estimate.</p></div></article></div></div></section>

    <section class="content-section shaded">
      <div class="page-container">
        <div class="section-heading">
          <span class="eyebrow">RELATED TOOLS</span>
          <h2>Explore our other free calculators</h2>
        </div>

        <div class="related-grid">
          <a href={`${baseURL}tools/bmi-calculator/`}>
            <span>⚖️</span>
            <div>
              <h3>BMI Calculator</h3>
              <p>Calculate BMI and view a healthy weight range.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/calorie-calculator/`}>
            <span>🔥</span>
            <div>
              <h3>Calorie Calculator</h3>
              <p>Estimate daily calories for maintenance or weight change.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/macro-calculator/`}>
            <span>🥗</span>
            <div>
              <h3>Macro Calculator</h3>
              <p>Estimate protein, carbohydrate, and fat targets.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/body-fat-calculator/`}>
            <span>📏</span>
            <div>
              <h3>Body Fat Calculator</h3>
              <p>Estimate body fat using circumference measurements.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/ideal-weight-calculator/`}>
            <span>🎯</span>
            <div>
              <h3>Ideal Weight Calculator</h3>
              <p>Compare four commonly used ideal-weight formulas.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/bmr-calculator/`}>
            <span>⚡</span>
            <div>
              <h3>BMR Calculator</h3>
              <p>Estimate the energy your body uses at rest.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>

          <a href={`${baseURL}tools/water-intake-calculator/`}>
            <span>💧</span>
            <div>
              <h3>Water Intake Calculator</h3>
              <p>Estimate a practical daily hydration target.</p>
              <strong>Open calculator →</strong>
            </div>
          </a>
        </div>

        <div class="related-actions">
          <a class="all-tools-button" href={`${baseURL}tools/`}>
            View all free tools →
          </a>
        </div>
      </div>
    </section>

    <section class="content-section"><div class="content-container narrow"><div class="section-heading"><span class="eyebrow">COMMON QUESTIONS</span><h2>TDEE Calculator FAQ</h2></div><div class="faq-list"><details><summary>What is TDEE?</summary><p>TDEE is your estimated total daily energy expenditure, including resting metabolism and activity.</p></details><details><summary>How accurate are activity multipliers?</summary><p>They are broad estimates. Jobs, training, movement habits, and individual biology vary considerably.</p></details><details><summary>Should I change calories immediately if my weight does not move?</summary><p>Daily weight fluctuates. Review a multi-week average before making a small adjustment.</p></details><details><summary>Is the moderate deficit right for everyone?</summary><p>No. Medical conditions, pregnancy, eating-disorder history, age, and other factors require individual advice.</p></details></div></div></section>

    <section class="ebook-cta">
      <div class="page-container">
        <div class="ebook-card">
          <div>
            <span class="eyebrow">READY FOR THE NEXT STEP?</span>
            <h2>Build a weight-loss plan you can actually sustain</h2>
            <p>Use your estimate as a starting point and focus on practical daily habits.</p>
          </div>

          <a
            href="https://payhip.com/b/eW3MA"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the ebook on Payhip →
          </a>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const form = document.getElementById("tdee-form"), metricWeight = document.getElementById("metric-weight"), imperialWeight = document.getElementById("imperial-weight"), metricHeight = document.getElementById("metric-height"), imperialHeight = document.getElementById("imperial-height"), errorBox = document.getElementById("form-error"), results = document.getElementById("results"), warning = document.getElementById("low-calorie-warning");
      if (!form || !metricWeight || !imperialWeight || !metricHeight || !imperialHeight || !errorBox || !results) return;
      const selected = (name) => form.querySelector(`input[name="${name}"]:checked`)?.value || "";
      const num = (id) => Number.parseFloat(document.getElementById(id)?.value || "");
      const text = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value; };
      const format = (value) => new Intl.NumberFormat("en-US", { maximumFractionDigits:0 }).format(Math.round(value));
      const showError = (message) => { errorBox.textContent = message; errorBox.hidden = false; };
      const clearError = () => { errorBox.textContent = ""; errorBox.hidden = true; };
      const updateUnits = () => { const metric = selected("unit") === "metric"; metricWeight.hidden = !metric; imperialWeight.hidden = metric; metricHeight.hidden = !metric; imperialHeight.hidden = metric; clearError(); };
      form.querySelectorAll('input[name="unit"]').forEach((input) => input.addEventListener("change", updateUnits));
      form.addEventListener("submit", (event) => {
        event.preventDefault(); clearError();
        const unit = selected("unit"), sex = selected("sex"), age = num("age"), activity = num("activity");
        if (!Number.isFinite(age) || age < 18 || age > 100) return showError("Please enter an age between 18 and 100.");
        if (!Number.isFinite(activity)) return showError("Please choose an activity level.");
        let weightKg, heightCm;
        if (unit === "metric") { weightKg = num("weight-kg"); heightCm = num("height-cm"); if (!Number.isFinite(weightKg) || weightKg < 35 || weightKg > 300) return showError("Please enter a weight between 35 and 300 kg."); if (!Number.isFinite(heightCm) || heightCm < 120 || heightCm > 230) return showError("Please enter a height between 120 and 230 cm."); }
        else { const pounds = num("weight-lb"), feet = num("height-feet"), inches = num("height-inches"); if (!Number.isFinite(pounds) || pounds < 77 || pounds > 661) return showError("Please enter a weight between 77 and 661 lb."); if (!Number.isFinite(feet) || feet < 3 || feet > 7 || !Number.isFinite(inches) || inches < 0 || inches >= 12) return showError("Please enter a valid height in feet and inches."); weightKg = pounds * .45359237; heightCm = (feet * 12 + inches) * 2.54; }
        const bmr = 10 * weightKg + 6.25 * heightCm - 5 * age + (sex === "male" ? 5 : -161), tdee = bmr * activity, gentle = tdee * .9, moderate = tdee * .8, surplus = tdee * 1.1;
        text("tdee-result", format(tdee)); text("bmr-result", `${format(bmr)} kcal`); text("gentle-loss", format(gentle)); text("moderate-loss", format(moderate)); text("small-surplus", format(surplus)); text("results-summary", `Estimate using an activity multiplier of ${activity}.`);
        if (warning) warning.hidden = Math.min(gentle, moderate) >= (sex === "male" ? 1500 : 1200);
        results.hidden = false; results.scrollIntoView({ behavior:"smooth", block:"start" });
      });
      document.getElementById("recalculate-button")?.addEventListener("click", () => form.scrollIntoView({ behavior:"smooth", block:"start" }));
      updateUnits();
    })();
  </script>

<style>
  :global(*) { box-sizing:border-box; }
  :global(html) { scroll-behavior:smooth; }
  .calculator-page { color:#0f172a; background:#fff; }
  .page-container { width:min(100% - 40px,1160px); margin:0 auto; }
  .content-container { width:min(100% - 40px,1040px); margin:0 auto; }
  .content-container.narrow { max-width:820px; }
  .hero { padding:34px 0 82px; background:radial-gradient(circle at 15% 20%,rgba(34,197,94,.12),transparent 28%),linear-gradient(135deg,#f0fdf4 0%,#f8fafc 60%,#eff6ff 100%); }
  .breadcrumbs { display:flex; flex-wrap:wrap; gap:8px; color:#64748b; font-size:.82rem; }
  .breadcrumbs a { color:#475569; text-decoration:none; }
  .breadcrumbs a:hover { color:#15803d; }
  .hero-content { max-width:810px; margin:62px auto 0; text-align:center; }
  .eyebrow,.info-label { color:#15803d; font-size:.74rem; font-weight:900; letter-spacing:.12em; }
  .hero h1 { margin:13px 0 0; font-size:clamp(3rem,8vw,5.4rem); line-height:.98; letter-spacing:-.065em; }
  .hero-content>p { max-width:700px; margin:22px auto 0; color:#475569; font-size:1.06rem; line-height:1.75; }
  .badges { display:flex; flex-wrap:wrap; justify-content:center; gap:9px; margin-top:25px; }
  .badges span { padding:8px 11px; border:1px solid #bbf7d0; border-radius:999px; color:#166534; background:rgba(255,255,255,.78); font-size:.76rem; font-weight:800; }
  .calculator-section { padding:88px 0 96px; }
  .calculator-layout { display:grid; grid-template-columns:minmax(0,1.5fr) minmax(300px,.75fr); gap:28px; align-items:start; }
  .calculator-card,.info-card { border-radius:26px; box-shadow:0 24px 70px rgba(15,23,42,.1); }
  .calculator-card { padding:34px; border:1px solid #e2e8f0; background:#fff; }
  .card-heading { display:flex; justify-content:space-between; align-items:center; gap:20px; margin-bottom:32px; }
  .card-heading h2,.info-card h2 { margin:8px 0 0; font-size:clamp(1.65rem,4vw,2.25rem); line-height:1.15; letter-spacing:-.04em; }
  .calculator-icon { display:grid; place-items:center; width:64px; height:64px; flex-shrink:0; border-radius:18px; background:#dcfce7; font-size:1.9rem; }
  .form-group { min-width:0; margin:0 0 24px; padding:0; border:0; }
  .form-group>label,.form-group>legend { display:block; margin-bottom:10px; color:#1e293b; font-size:.92rem; font-weight:800; }
  .toggle-grid,.option-grid,.field-grid { display:grid; gap:12px; }
  .toggle-grid,.two-columns,.field-grid { grid-template-columns:repeat(2,1fr); }
  .toggle-grid { padding:5px; border-radius:14px; background:#f1f5f9; }
  .toggle-grid input,.option-card input { position:absolute; opacity:0; pointer-events:none; }
  .toggle-grid span { display:grid; min-height:46px; place-items:center; border-radius:10px; color:#64748b; font-weight:800; cursor:pointer; }
  .toggle-grid input:checked+span { color:#15803d; background:#fff; box-shadow:0 5px 16px rgba(15,23,42,.09); }
  .option-card { cursor:pointer; }
  .option-card>span { display:block; min-height:78px; padding:15px; border:1px solid #e2e8f0; border-radius:15px; }
  .option-card input:checked+span { border-color:#22c55e; background:#f0fdf4; box-shadow:0 0 0 3px rgba(34,197,94,.1); }
  .option-card strong,.option-card small { display:block; }
  .option-card small { margin-top:4px; color:#64748b; font-size:.75rem; }
  .input-with-unit { display:flex; align-items:center; overflow:hidden; border:1px solid #cbd5e1; border-radius:14px; background:#fff; }
  .input-with-unit:focus-within,select:focus { border-color:#22c55e; box-shadow:0 0 0 4px rgba(34,197,94,.11); }
  .input-with-unit input { width:100%; min-width:0; padding:15px 16px; border:0; outline:0; font:inherit; font-weight:700; }
  .input-with-unit span { padding:0 16px; color:#64748b; font-size:.86rem; font-weight:800; }
  select { width:100%; padding:15px 16px; border:1px solid #cbd5e1; border-radius:14px; outline:0; background:#fff; color:#0f172a; font:inherit; font-weight:700; }
  .form-error { margin-bottom:18px; padding:13px 15px; border:1px solid #fecaca; border-radius:12px; background:#fef2f2; color:#b91c1c; font-size:.88rem; font-weight:700; }
  .calculate-button { display:flex; justify-content:space-between; align-items:center; width:100%; min-height:56px; padding:0 20px; border:0; border-radius:14px; background:#22c55e; color:#fff; cursor:pointer; font:inherit; font-weight:800; box-shadow:0 15px 34px rgba(34,197,94,.25); }
  .calculate-button:hover { background:#16a34a; transform:translateY(-2px); }
  .privacy-note { margin:16px 0 0; color:#94a3b8; font-size:.76rem; text-align:center; }
  .info-card { position:sticky; top:100px; padding:30px; color:#fff; background:radial-gradient(circle at top right,rgba(34,197,94,.17),transparent 35%),#0f172a; }
  .info-card .info-label { color:#86efac; }
  .info-card h2 { color:#fff; }
  .info-card>p { margin:15px 0 0; color:#cbd5e1; line-height:1.7; }
  .info-card ul { display:grid; gap:15px; margin:26px 0 0; padding:0; list-style:none; }
  .info-card li { display:flex; gap:11px; color:#e2e8f0; }
  .info-card li span { display:grid; place-items:center; width:22px; height:22px; border-radius:50%; color:#86efac; background:rgba(34,197,94,.18); }
  .warning-box { margin-top:28px; padding:17px; border:1px solid rgba(148,163,184,.22); border-radius:15px; background:rgba(255,255,255,.06); }
  .warning-box p { margin:6px 0 0; color:#cbd5e1; font-size:.82rem; line-height:1.6; }
  .results-section { scroll-margin-top:100px; margin-top:58px; }
  .results-heading { display:flex; justify-content:space-between; align-items:flex-end; gap:22px; margin-bottom:24px; }
  .results-heading h2 { margin:6px 0 0; font-size:clamp(2rem,5vw,3rem); letter-spacing:-.045em; }
  .results-heading p { margin:9px 0 0; color:#64748b; }
  #recalculate-button { padding:11px 15px; border:1px solid #cbd5e1; border-radius:11px; background:#fff; color:#334155; cursor:pointer; font:inherit; font-size:.84rem; font-weight:800; }
  .primary-result { display:grid; grid-template-columns:minmax(0,1.3fr) minmax(240px,.7fr); gap:24px; padding:32px; border-radius:24px; color:#fff; background:radial-gradient(circle at top right,rgba(134,239,172,.17),transparent 35%),#0f172a; box-shadow:0 24px 64px rgba(15,23,42,.16); }
  .primary-result>div>span,.result-side>span { color:#86efac; font-size:.76rem; font-weight:800; letter-spacing:.08em; }
  .result-value { display:flex; align-items:baseline; gap:9px; margin-top:8px; }
  .result-value strong { font-size:clamp(3.3rem,8vw,5.8rem); line-height:1; letter-spacing:-.07em; }
  .result-value small { color:#cbd5e1; font-size:1.25rem; font-weight:700; }
  .primary-result p { margin:14px 0 0; color:#cbd5e1; }
  .result-side { display:flex; flex-direction:column; justify-content:center; padding:24px; border:1px solid rgba(148,163,184,.2); border-radius:18px; background:rgba(255,255,255,.06); }
  .result-side strong { margin-top:10px; font-size:1.35rem; }
  .result-side small { margin-top:8px; color:#94a3b8; }
  .result-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:18px; }
  .result-card { padding:23px; border:1px solid #e2e8f0; border-radius:18px; background:#fff; box-shadow:0 13px 38px rgba(15,23,42,.06); }
  .result-card>span { color:#64748b; font-size:.72rem; font-weight:900; letter-spacing:.08em; }
  .result-card h3 { margin:8px 0 0; font-size:1rem; }
  .result-card h3 strong { font-size:2rem; }
  .result-card p { margin:10px 0 0; color:#64748b; font-size:.82rem; line-height:1.55; }
  .result-warning { margin-top:18px; padding:21px 23px; border:1px solid #fde68a; border-radius:16px; background:#fffbeb; }
  .result-warning strong { color:#92400e; }
  .result-warning p { margin:6px 0 0; color:#78350f; line-height:1.65; }
  .content-section { padding:92px 0; }
  .shaded { background:#f8fafc; }
