---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const siteName = "Weight Loss Without Starving";
const authorName = "George Novák";

const baseURL = import.meta.env.BASE_URL;

const asset = (path: string) =>
  `${baseURL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const socialImageURL = new URL(
  asset("ebook-cover.png"),
  Astro.site
);

const sitemapURL = new URL(
  asset("sitemap-index.xml"),
  Astro.site
);

const bookSchema = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: "Weight Loss Without Starving",
  alternateName: "Weight Loss Without Starving: A Practical Guide to Healthy and Sustainable Weight Loss",
  description,
  url: canonicalURL.href,
  image: socialImageURL.href,

  author: {
    "@type": "Person",
    name: authorName,
  },

  bookFormat: "https://schema.org/EBook",
  inLanguage: "en",
  numberOfPages: 68,

  genre: [
    "Health",
    "Nutrition",
    "Weight Loss",
    "Healthy Lifestyle",
  ],

  offers: {
    "@type": "Offer",
    price: "19.99",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: "https://payhip.com/b/eW3MA",
  },

  publisher: {
    "@type": "Person",
    name: authorName,
  },
};
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    <meta
      name="description"
      content={description}
    />

    <meta
      name="author"
      content={authorName}
    />

    <meta
      name="robots"
      content="index, follow, max-image-preview:large"
    />

    <meta
      name="googlebot"
      content="index, follow, max-image-preview:large"
    />

    <meta
      name="theme-color"
      content="#16a34a"
    />

    <meta
      name="color-scheme"
      content="light"
    />

    <link
      rel="canonical"
      href={canonicalURL.href}
    />

    <link
      rel="sitemap"
      type="application/xml"
      href={sitemapURL.href}
    />

    <link
      rel="icon"
      type="image/svg+xml"
      href={asset("favicon.svg")}
    />

    <link
      rel="apple-touch-icon"
      href={asset("favicon.svg")}
    />

    <!-- Open Graph -->

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:site_name"
      content={siteName}
    />

    <meta
      property="og:title"
      content={title}
    />

    <meta
      property="og:description"
      content={description}
    />

    <meta
      property="og:url"
      content={canonicalURL.href}
    />

    <meta
      property="og:image"
      content={socialImageURL.href}
    />

    <meta
      property="og:image:secure_url"
      content={socialImageURL.href}
    />

    <meta
      property="og:image:alt"
      content="Weight Loss Without Starving ebook cover"
    />

    <meta
      property="og:locale"
      content="en_US"
    />

    <!-- Twitter / X -->

    <meta
      name="twitter:card"
      content="summary_large_image"
    />

    <meta
      name="twitter:title"
      content={title}
    />

    <meta
      name="twitter:description"
      content={description}
    />

    <meta
      name="twitter:image"
      content={socialImageURL.href}
    />

    <meta
      name="twitter:image:alt"
      content="Weight Loss Without Starving ebook cover"
    />

    <!-- Structured data -->

    <script
      type="application/ld+json"
      set:html={JSON.stringify(bookSchema)}
    />
  </head>

  <body>
    <slot />
  </body>
</html>