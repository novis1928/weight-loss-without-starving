---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const siteName = "Weight Loss Without Starving";
const authorName = "George Novák";

const rawBaseURL = import.meta.env.BASE_URL;

const baseURL = rawBaseURL.endsWith("/")
  ? rawBaseURL
  : `${rawBaseURL}/`;

const asset = (path: string) =>
  `${baseURL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;

const siteOrigin = Astro.site ?? new URL(Astro.url.origin);

const canonicalURL = new URL(
  Astro.url.pathname,
  siteOrigin
);

const siteURL = new URL(
  baseURL,
  siteOrigin
);

const socialImageURL = new URL(
  asset("ebook-cover.png"),
  siteOrigin
);

const sitemapURL = new URL(
  asset("sitemap-index.xml"),
  siteOrigin
);

/*
 * Stable identifiers connect related schema objects together.
 */
const websiteId = `${siteURL.href}#website`;
const organizationId = `${siteURL.href}#organization`;
const bookId = `${siteURL.href}#book`;

/*
 * Check whether the current page is the homepage.
 * This ensures that Book schema is not added to blog pages,
 * category pages or tag pages.
 */
const normalizedCurrentPath =
  Astro.url.pathname.replace(/\/+$/, "");

const normalizedHomepagePath =
  baseURL.replace(/\/+$/, "");

const isHomepage =
  normalizedCurrentPath === normalizedHomepagePath;

/*
 * Global website schema.
 */
const websiteSchema = {
  "@type": "WebSite",
  "@id": websiteId,
  url: siteURL.href,
  name: siteName,
  description:
    "Practical guidance for healthy and sustainable weight loss without extreme diets or unnecessary starvation.",
  inLanguage: "en-US",

  publisher: {
    "@id": organizationId,
  },
};

/*
 * Global publisher / brand schema.
 */
const organizationSchema = {
  "@type": "Organization",
  "@id": organizationId,
  name: siteName,
  url: siteURL.href,

  logo: {
    "@type": "ImageObject",
    url: socialImageURL.href,
  },

  founder: {
    "@type": "Person",
    name: authorName,
  },
};

/*
 * Ebook schema appears only on the homepage.
 */
const bookSchema = {
  "@type": "Book",
  "@id": bookId,

  name: "Weight Loss Without Starving",

  alternateName:
    "Weight Loss Without Starving: A Practical Guide to Healthy and Sustainable Weight Loss",

  description,

  url: siteURL.href,
  image: socialImageURL.href,

  mainEntityOfPage: {
    "@id": siteURL.href,
  },

  author: {
    "@type": "Person",
    name: authorName,
  },

  publisher: {
    "@id": organizationId,
  },

  bookFormat: "https://schema.org/EBook",
  inLanguage: "en-US",
  numberOfPages: 68,

  genre: [
    "Health",
    "Nutrition",
    "Weight Loss",
    "Healthy Lifestyle",
  ],

  offers: {
    "@type": "Offer",
    price: "19.99",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: "https://payhip.com/b/eW3MA",
  },
};

/*
 * One JSON-LD graph containing all schema objects
 * relevant to the current page.
 */
const structuredData = {
  "@context": "https://schema.org",

  "@graph": [
    websiteSchema,
    organizationSchema,
    ...(isHomepage ? [bookSchema] : []),
  ],
};
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="p:domain_verify" content="0ae9b29cc48a065647b79a85339aa587" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <meta
      name="application-name"
      content={siteName}
    />

    <meta
      name="apple-mobile-web-app-title"
      content={siteName}
    />

    <meta
      name="mobile-web-app-capable"
      content="yes"
    />

    <!-- Google Search Console verification -->

    <meta
      name="google-site-verification"
      content="ONRkREvpa8xmu_-HhWrl9bV-qz0TwGubZj-E1D17Wtw"
    />

    <!-- Google Analytics 4 -->

    <link
      rel="preconnect"
      href="https://www.googletagmanager.com"
    />

    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-P69VD544HB"
    ></script>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        window.dataLayer.push(arguments);
      }

      gtag("js", new Date());

      gtag("config", "G-P69VD544HB", {
        anonymize_ip: true,
      });
    </script>

    <!-- Basic SEO -->

    <title>{title}</title>

    <meta
      name="description"
      content={description}
    />

    <meta
      name="author"
      content={authorName}
    />

    <meta
      name="robots"
      content="index, follow, max-image-preview:large"
    />

    <meta
      name="googlebot"
      content="index, follow, max-image-preview:large"
    />

    <meta
      name="theme-color"
      content="#16a34a"
    />

    <meta
      name="color-scheme"
      content="light"
    />

    <!-- Canonical URL -->

    <link
      rel="canonical"
      href={canonicalURL.href}
    />

    <!-- Sitemap -->

    <link
      rel="sitemap"
      type="application/xml"
      href={sitemapURL.href}
    />

    <!-- Web App Manifest -->

    <link
      rel="manifest"
      href={asset("manifest.webmanifest")}
    />

    <!-- Icons -->

    <link
      rel="icon"
      type="image/svg+xml"
      href={asset("favicon.svg")}
    />

    <link
      rel="apple-touch-icon"
      href={asset("favicon.svg")}
    />

    <!-- Open Graph -->

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:site_name"
      content={siteName}
    />

    <meta
      property="og:title"
      content={title}
    />

    <meta
      property="og:description"
      content={description}
    />

    <meta
      property="og:url"
      content={canonicalURL.href}
    />

    <meta
      property="og:image"
      content={socialImageURL.href}
    />

    <meta
      property="og:image:secure_url"
      content={socialImageURL.href}
    />

    <meta
      property="og:image:type"
      content="image/png"
    />

    <meta
      property="og:image:width"
      content="1200"
    />

    <meta
      property="og:image:height"
      content="630"
    />

    <meta
      property="og:image:alt"
      content="Weight Loss Without Starving ebook cover"
    />

    <meta
      property="og:locale"
      content="en_US"
    />

    <!-- Twitter / X -->

    <meta
      name="twitter:card"
      content="summary_large_image"
    />

    <meta
      name="twitter:title"
      content={title}
    />

    <meta
      name="twitter:description"
      content={description}
    />

    <meta
      name="twitter:image"
      content={socialImageURL.href}
    />

    <meta
      name="twitter:image:alt"
      content="Weight Loss Without Starving ebook cover"
    />

    <!-- Structured data -->

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </head>

  <body>
    <Header />

    <slot />

    <Footer />
  </body>
</html>
