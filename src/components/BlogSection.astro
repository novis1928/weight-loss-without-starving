---
import { getCollection } from "astro:content";
import { slugify } from "../utils/slugify";

const baseURL = import.meta.env.BASE_URL;

const slugify = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const posts = (
  await getCollection("blog", ({ data }) => !data.draft)
)
  .sort(
    (a, b) =>
      b.data.publishDate.getTime() -
      a.data.publishDate.getTime()
  )
  .slice(0, 3);

const formattedDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<section class="blog-section" id="blog">
  <div class="blog-container">
    <div class="blog-heading">
      <span class="blog-label">LATEST ARTICLES</span>

      <h2>
        Practical Weight Loss
        <span>Advice for Everyday Life</span>
      </h2>

      <p>
        Explore realistic guidance about nutrition, healthy
        habits, motivation, and sustainable weight loss.
      </p>
    </div>

    {
      posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post, index) => (
            <article class="blog-card">
              <div class="blog-card-top">
                <a
                  class="blog-category"
                  href={`${baseURL}category/${slugify(
                    post.data.category
                  )}/`}
                >
                  {post.data.category}
                </a>

                <span class="blog-number">
                  {String(index + 1).padStart(2, "0")}
                </span>
              </div>

              <h3>
                <a href={`${baseURL}blog/${post.id}/`}>
                  {post.data.title}
                </a>
              </h3>

              <p>{post.data.description}</p>

              <div class="blog-card-footer">
                <div class="blog-meta">
                  <span>
                    {formattedDate(post.data.publishDate)}
                  </span>

                  <span aria-hidden="true">•</span>

                  <span>{post.data.readingTime}</span>
                </div>

                <a
                  class="read-article"
                  href={`${baseURL}blog/${post.id}/`}
                  aria-label={`Read ${post.data.title}`}
                >
                  Read article
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-blog">
          <h3>New articles are coming soon</h3>

          <p>
            Practical weight loss guides will be published
            here gradually.
          </p>
        </div>
      )
    }

    <div class="blog-bottom">
      <p>New practical articles are added regularly.</p>

      <a href={`${baseURL}blog/`}>
        View all articles
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .blog-section {
    padding: 110px 0;
    background:
      radial-gradient(
        circle at top left,
        rgba(34, 197, 94, 0.09),
        transparent 34%
      ),
      #ffffff;
  }

  .blog-container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .blog-heading {
    max-width: 720px;
    margin: 0 auto 54px;
    text-align: center;
  }

  .blog-label {
    display: inline-block;
    margin-bottom: 18px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.1);
    color: #16a34a;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .blog-heading h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(36px, 5vw, 58px);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .blog-heading h2 span {
    display: block;
    color: #22c55e;
  }

  .blog-heading p {
    max-width: 640px;
    margin: 22px auto 0;
    color: #64748b;
    font-size: 18px;
    line-height: 1.75;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .blog-card {
    position: relative;
    display: flex;
    min-height: 390px;
    padding: 30px;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 22px 50px rgba(15, 23, 42, 0.07);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .blog-card::before {
    content: "";
    position: absolute;
    right: -55px;
    top: -55px;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.08);
  }

  .blog-card:hover {
    transform: translateY(-8px);
    border-color: rgba(34, 197, 94, 0.32);
    box-shadow: 0 28px 64px rgba(15, 23, 42, 0.12);
  }

  .blog-card-top {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .blog-category {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    padding: 0 11px;
    border-radius: 999px;
    background: #ecfdf3;
    color: #15803d;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .blog-category:hover {
    background: #22c55e;
    color: #ffffff;
  }

  .blog-number {
    color: rgba(15, 23, 42, 0.14);
    font-size: 42px;
    font-weight: 900;
    line-height: 1;
  }

  .blog-card h3 {
    position: relative;
    z-index: 1;
    margin: 38px 0 18px;
    font-size: 25px;
    line-height: 1.3;
    letter-spacing: -0.025em;
  }

  .blog-card h3 a {
    color: #0f172a;
    text-decoration: none;
  }

  .blog-card h3 a:hover {
    color: #16a34a;
  }

  .blog-card > p {
    position: relative;
    z-index: 1;
    margin: 0;
    color: #64748b;
    font-size: 16px;
    line-height: 1.7;
  }

  .blog-card-footer {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 15px;
    margin-top: auto;
    padding-top: 30px;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
    color: #94a3b8;
    font-size: 13px;
    font-weight: 700;
  }

  .read-article {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 9px;
    color: #16a34a;
    font-size: 14px;
    font-weight: 900;
    text-decoration: none;
  }

  .read-article:hover {
    text-decoration: underline;
  }

  .empty-blog {
    max-width: 680px;
    margin: 0 auto;
    padding: 42px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    background: #ffffff;
    text-align: center;
    box-shadow: 0 22px 50px rgba(15, 23, 42, 0.07);
  }

  .empty-blog h3 {
    margin: 0 0 10px;
    color: #0f172a;
    font-size: 26px;
  }

  .empty-blog p {
    margin: 0;
    color: #64748b;
  }

  .blog-bottom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 22px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .blog-bottom p {
    margin: 0;
    color: #64748b;
  }

  .blog-bottom a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #16a34a;
    font-weight: 800;
    text-decoration: none;
  }

  .blog-bottom a:hover {
    text-decoration: underline;
  }

  @media (max-width: 940px) {
    .blog-grid {
      grid-template-columns: 1fr;
      max-width: 720px;
      margin: 0 auto;
    }

    .blog-card {
      min-height: 320px;
    }
  }

  @media (max-width: 620px) {
    .blog-section {
      padding: 82px 0;
    }

    .blog-container {
      width: min(100% - 24px, 1180px);
    }

    .blog-heading {
      margin-bottom: 38px;
    }

    .blog-heading p {
      font-size: 16px;
    }

    .blog-card {
      min-height: 350px;
      padding: 24px;
      border-radius: 20px;
    }

    .blog-card h3 {
      margin-top: 28px;
      font-size: 22px;
    }
  }
</style>