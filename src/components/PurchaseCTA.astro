---
const baseURL = import.meta.env.BASE_URL;
---

<section class="purchase-section" id="buy">
  <div class="purchase-container">

    <div class="purchase-content">

      <span class="purchase-label">START TODAY</span>

      <h2>
        Ready to Lose Weight
        <span>Without Starving?</span>
      </h2>

      <p class="purchase-description">
        Get a practical, beginner-friendly guide that will help you understand
        healthy weight loss and build habits that fit your everyday life.
      </p>

      <ul class="purchase-benefits">
        <li>
          <span>✓</span>
          Instant PDF download
        </li>

        <li>
          <span>✓</span>
          68 practical pages
        </li>

        <li>
          <span>✓</span>
          15 easy-to-understand chapters
        </li>

        <li>
          <span>✓</span>
          Simple recipes and everyday tips
        </li>

        <li>
          <span>✓</span>
          Beginner-friendly guidance
        </li>

        <li>
          <span>✓</span>
          Read on your phone, tablet, or computer
        </li>
      </ul>

    </div>

    <div class="purchase-card">

      <div class="purchase-badge">
        DIGITAL EBOOK
      </div>

      <img
        src={`${baseURL}ebook-cover.png`}
        alt="Weight Loss Without Starving ebook cover"
        class="purchase-cover"
        loading="lazy"
        width="520"
        height="700"
      />

      <div class="purchase-price">
        <span class="purchase-price-label">Get instant access for</span>

        <div class="purchase-price-value">
          <span class="purchase-currency">$</span>
          <strong>19.99</strong>
        </div>

        <p>One-time payment. No subscription.</p>
      </div>

      <div class="purchase-buttons">

        <a
          href="https://payhip.com/b/eW3MA"
          class="purchase-button purchase-button-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Buy on Payhip
          <span>→</span>
        </a>

        <a
          href="https://novis4.gumroad.com/l/lcuop"
          class="purchase-button purchase-button-secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Buy on Gumroad
          <span>→</span>
        </a>

      </div>

      <div class="purchase-security">
        <span>🔒</span>

        <p>
          Secure checkout and immediate access after purchase
        </p>
      </div>

    </div>

  </div>
</section>