---
const asset = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path.replace(/^\//, "")}`;
---

<section class="hero" id="home">

  <div class="hero-text">

    <span class="badge">
      ✔ No Crash Diets<br />
      ✔ Science-Based<br />
      ✔ Sustainable Results
    </span>

    <h1>
      Weight Loss
      <span>Without Starving</span>
    </h1>

    <p>
      Learn how to lose weight in a healthy, sustainable way.
      No crash diets. No unrealistic promises.
      Just practical habits that actually work.
    </p>

    <div class="buttons">

      <a
        class="btn primary"
        href="https://payhip.com/b/eW3MA"
        target="_blank"
        rel="noopener noreferrer"
      >
        Buy on Payhip
      </a>

      <a
        class="btn secondary"
        href="https://novis4.gumroad.com/l/lcuop"
        target="_blank"
        rel="noopener noreferrer"
      >
        Buy on Gumroad
      </a>

    </div>

    <div class="stats">

      <div>
        <strong>68+</strong>
        <span>Pages</span>
      </div>

      <div>
        <strong>100%</strong>
        <span>Practical</span>
      </div>

      <div>
        <strong>Science</strong>
        <span>Based</span>
      </div>

    </div>

    <div class="trust">
      <p>
        ✓ Practical advice &nbsp;&nbsp; • &nbsp;&nbsp;
        ✓ Sustainable approach &nbsp;&nbsp; • &nbsp;&nbsp;
        ✓ Beginner-friendly
      </p>
    </div>

  </div>

  <div class="hero-image">

    <img
      src={asset("ebook-cover.png")}
      alt="Weight Loss Without Starving ebook cover"
      width="520"
      height="700"
      loading="eager"
      fetchpriority="high"
    />

  </div>

</section>