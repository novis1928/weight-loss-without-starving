<section class="contact-section" id="contact">
  <div class="contact-container">
    <div class="contact-content">
      <span class="contact-label">CONTACT</span>

      <h2>
        Have a Question?
        <span>Get in Touch</span>
      </h2>

      <p class="contact-intro">
        Do you have a question about the ebook, the purchase process, or your
        download? Send a message and I will reply as soon as possible.
      </p>

      <div class="contact-list">
        <div class="contact-item">
          <div class="contact-icon" aria-hidden="true">✉</div>

          <div>
            <span>Email</span>

            <a href="mailto:novis1928@gmail.com">
              novis1928@gmail.com
            </a>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon" aria-hidden="true">⏱</div>

          <div>
            <span>Response time</span>

            <p>Usually within 1–2 business days</p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon" aria-hidden="true">🔒</div>

          <div>
            <span>Secure purchase</span>

            <p>Checkout and delivery are handled by Payhip and Gumroad</p>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-card">
      <span class="contact-card-label">CONTACT SUPPORT</span>

      <h3>Send Us a Message</h3>

      <p class="contact-card-intro">
        Fill out the form below and we will reply as soon as possible.
      </p>

      <form
        class="contact-form"
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
      >
        <input
          type="hidden"
          name="access_key"
          value="8fd99bb5-6ff0-4b90-9c49-0b88d6892add"
        />

        <input
          type="hidden"
          name="from_name"
          value="Weight Loss Without Starving"
        />

        <input
          type="hidden"
          name="subject"
          value="New message from Weight Loss Without Starving"
        />

        <div class="form-field">
          <label for="contact-name">Name</label>

          <input
            id="contact-name"
            type="text"
            name="name"
            placeholder="Your name"
            autocomplete="name"
            required
          />
        </div>

        <div class="form-field">
          <label for="contact-email">Email</label>

          <input
            id="contact-email"
            type="email"
            name="email"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
        </div>

        <div class="form-field">
          <label for="contact-subject">Subject</label>

          <input
            id="contact-subject"
            type="text"
            name="message_subject"
            placeholder="How can we help?"
            required
          />
        </div>

        <div class="form-field">
          <label for="contact-message">Message</label>

          <textarea
            id="contact-message"
            name="message"
            rows="5"
            placeholder="Write your message here..."
            required
          ></textarea>
        </div>

        <div class="form-honeypot" aria-hidden="true">
          <label for="contact-botcheck">Leave this field empty</label>

          <input
            id="contact-botcheck"
            type="checkbox"
            name="botcheck"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <button class="contact-button" id="contact-submit" type="submit">
          <span class="button-text">Send Message</span>
          <span class="button-arrow" aria-hidden="true">→</span>
        </button>

        <div
          class="form-status"
          id="contact-status"
          role="status"
          aria-live="polite"
          hidden
        ></div>
      </form>

      <div class="contact-divider"></div>

      <div class="faq-heading">
        <span>FREQUENTLY ASKED QUESTIONS</span>
        <p>Quick answers to common purchase and download questions.</p>
      </div>

      <div class="contact-help">
        <details>
          <summary>How do I download the ebook?</summary>

          <p>
            After your purchase, you will receive an email containing your
            download link. Please also check your spam or promotions folder.
          </p>
        </details>

        <details>
          <summary>I didn't receive my PDF.</summary>

          <p>
            If the email has not arrived within 15 minutes, contact support and
            include the email address used for your purchase.
          </p>
        </details>

        <details>
          <summary>Which payment methods are accepted?</summary>

          <p>
            Payments are securely processed through Payhip. Depending on your
            country, you can usually pay with a credit or debit card or PayPal.
          </p>
        </details>

        <details>
          <summary>Can I get a refund?</summary>

          <p>
            If you experience a technical problem with your purchase, contact
            us first. We will do our best to resolve the issue quickly. Refund
            requests are handled according to the store policy and applicable
            consumer protection laws.
          </p>
        </details>

        <details>
          <summary>Is this ebook suitable for beginners?</summary>

          <p>
            Yes. The ebook is written for beginners and focuses on healthy,
            sustainable weight loss without extreme diets.
          </p>
        </details>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById("contact-form");
    const submitButton = document.getElementById("contact-submit");
    const buttonText = submitButton?.querySelector(".button-text");
    const buttonArrow = submitButton?.querySelector(".button-arrow");
    const statusBox = document.getElementById("contact-status");

    if (
      !(form instanceof HTMLFormElement) ||
      !(submitButton instanceof HTMLButtonElement) ||
      !(buttonText instanceof HTMLElement) ||
      !(buttonArrow instanceof HTMLElement) ||
      !(statusBox instanceof HTMLElement) ||
      form.dataset.ajaxReady === "true"
    ) {
      return;
    }

    form.dataset.ajaxReady = "true";

    const showStatus = (type, title, message) => {
      statusBox.className = `form-status form-status--${type}`;
      statusBox.innerHTML = `
        <span class="form-status-icon" aria-hidden="true">
          ${type === "success" ? "✓" : "!"}
        </span>
        <span>
          <strong>${title}</strong>
          <span>${message}</span>
        </span>
      `;
      statusBox.hidden = false;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        return;
      }

      submitButton.disabled = true;
      submitButton.setAttribute("aria-busy", "true");
      buttonText.textContent = "Sending...";
      buttonArrow.textContent = "…";
      statusBox.hidden = true;

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: {
            Accept: "application/json",
          },
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.message || "The message could not be sent.");
        }

        form.reset();

        showStatus(
          "success",
          "Thank you!",
          "Your message has been sent successfully. We'll get back to you within 1–2 business days."
        );
      } catch (error) {
        showStatus(
          "error",
          "Something went wrong.",
          "Your message could not be sent. Please try again or email us directly."
        );

        console.error("Contact form error:", error);
      } finally {
        submitButton.disabled = false;
        submitButton.removeAttribute("aria-busy");
        buttonText.textContent = "Send Message";
        buttonArrow.textContent = "→";
      }
    });
  })();
</script>

