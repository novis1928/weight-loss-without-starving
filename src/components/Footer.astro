---
const rawBaseURL = import.meta.env.BASE_URL;

const baseURL = rawBaseURL.endsWith("/")
  ? rawBaseURL
  : `${rawBaseURL}/`;
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <h2>
        Weight Loss
        <span>Without Starving</span>
      </h2>

      <p>
        A practical beginner-friendly ebook that teaches healthy,
        sustainable weight loss without crash diets or unrealistic promises.
      </p>

      <div class="footer-buttons">
        <a
          href="https://payhip.com/b/eW3MA"
          target="_blank"
          rel="noopener"
        >
          Buy on Payhip
        </a>

        <a
          href="https://novis4.gumroad.com/l/lcuop"
          target="_blank"
          rel="noopener"
        >
          Buy on Gumroad
        </a>
      </div>
    </div>

    <nav class="footer-column" aria-label="Footer navigation">
      <h3>Navigation</h3>

      <a href={`${baseURL}#home`}>Home</a>
      <a href={`${baseURL}tools/`}>Tools</a>
      <a href={`${baseURL}#preview`}>Preview</a>
      <a href={`${baseURL}blog/`}>Blog</a>
      <a href={`${baseURL}#about`}>About</a>
      <a href={`${baseURL}#contact`}>Contact</a>
    </nav>

    <nav class="footer-column" aria-label="Footer resources">
      <h3>Resources</h3>

      <a href={`${baseURL}tools/`}>Free Calculators</a>
      <a href={`${baseURL}#faq`}>FAQ</a>
      <a href="mailto:novis1928@gmail.com">Email</a>
    </nav>

    <div class="footer-column">
      <h3>Why this ebook?</h3>

      <ul>
        <li>✓ 68 practical pages</li>
        <li>✓ 15 easy chapters</li>
        <li>✓ Beginner friendly</li>
        <li>✓ Instant PDF download</li>
        <li>✓ Healthy recipes included</li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>
      © 2026 George Novák. All rights reserved.
    </p>

    <p>
      Educational content only. Results vary from person to person.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: #081b11;
    color: #ffffff;
    padding: 80px 0 30px;
  }

  .footer-container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.2fr;
    gap: 50px;
  }

  .footer h2 {
    margin: 0 0 20px;
    font-size: 34px;
    line-height: 1.05;
  }

  .footer h2 span {
    display: block;
    color: #22c55e;
  }

  .footer p {
    color: #b8c8bf;
    line-height: 1.8;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
  }

  .footer-column h3 {
    margin: 0 0 18px;
    font-size: 18px;
  }

  .footer-column a {
    width: fit-content;
    margin-bottom: 12px;
    color: #d7e4db;
    text-decoration: none;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .footer-column a:hover {
    color: #22c55e;
    transform: translateX(3px);
  }

  .footer-column a:focus-visible,
  .footer-buttons a:focus-visible {
    outline: 3px solid rgba(34, 197, 94, 0.45);
    outline-offset: 4px;
  }

  .footer-column ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-column li {
    margin-bottom: 12px;
    color: #d7e4db;
  }

  .footer-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .footer-buttons a {
    padding: 14px 22px;
    border-radius: 12px;
    background: #22c55e;
    color: #ffffff;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .footer-buttons a:hover {
    background: #16a34a;
    box-shadow: 0 12px 28px rgba(34, 197, 94, 0.2);
    transform: translateY(-2px);
  }

  .footer-bottom {
    width: min(1180px, calc(100% - 40px));
    margin: 70px auto 0;
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 20px;
  }

  .footer-bottom p {
    margin: 0;
    color: #9bb1a4;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .footer {
      padding-top: 64px;
    }

    .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 42px 32px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      margin-top: 55px;
    }
  }

  @media (max-width: 620px) {
    .footer-container,
    .footer-bottom {
      width: min(100% - 24px, 1180px);
    }

    .footer-container {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: auto;
    }

    .footer h2 {
      font-size: 30px;
    }

    .footer-buttons {
      flex-direction: column;
    }

    .footer-buttons a {
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-column a,
    .footer-buttons a {
      transition: none;
    }

    .footer-column a:hover,
    .footer-buttons a:hover {
      transform: none;
    }
  }
</style>
