---
const baseURL = import.meta.env.BASE_URL;
---

<footer class="footer">

  <div class="footer-container">

    <div class="footer-brand">

      <h2>
        Weight Loss
        <span>Without Starving</span>
      </h2>

      <p>
        A practical beginner-friendly ebook that teaches healthy,
        sustainable weight loss without crash diets or unrealistic promises.
      </p>

      <div class="footer-buttons">

        <a
          href="https://payhip.com/b/eW3MA"
          target="_blank"
          rel="noopener"
        >
          Buy on Payhip
        </a>

        <a
          href="https://novis4.gumroad.com/l/lcuop"
          target="_blank"
          rel="noopener"
        >
          Buy on Gumroad
        </a>

      </div>

    </div>

    <div class="footer-column">

      <h3>Navigation</h3>

      <a href={`${baseURL}#home`}>Home</a>
      <a href={`${baseURL}#preview`}>Preview</a>
      <a href={`${baseURL}#blog`}>Blog</a>
      <a href={`${baseURL}#about`}>About</a>
      <a href={`${baseURL}#contact`}>Contact</a>

    </div>

    <div class="footer-column">

      <h3>Resources</h3>

      <a href={`${baseURL}#faq`}>FAQ</a>
      <a href="mailto:novis1928@gmail.com">Email</a>

    </div>

    <div class="footer-column">

      <h3>Why this ebook?</h3>

      <ul>
        <li>✓ 68 practical pages</li>
        <li>✓ 15 easy chapters</li>
        <li>✓ Beginner friendly</li>
        <li>✓ Instant PDF download</li>
        <li>✓ Healthy recipes included</li>
      </ul>

    </div>

  </div>

  <div class="footer-bottom">

    <p>
      © 2026 George Novák. All rights reserved.
    </p>

    <p>
      Educational content only. Results vary from person to person.
    </p>

  </div>

</footer>

<style>

.footer{
background:#081b11;
color:white;
padding:80px 0 30px;
}

.footer-container{
width:min(1180px,calc(100% - 40px));
margin:auto;
display:grid;
grid-template-columns:2fr 1fr 1fr 1.2fr;
gap:50px;
}

.footer h2{
font-size:34px;
line-height:1.05;
margin:0 0 20px;
}

.footer h2 span{
display:block;
color:#22c55e;
}

.footer p{
color:#b8c8bf;
line-height:1.8;
}

.footer-column h3{
margin-bottom:18px;
font-size:18px;
}

.footer-column{
display:flex;
flex-direction:column;
}

.footer-column a{
color:#d7e4db;
text-decoration:none;
margin-bottom:12px;
transition:.2s;
}

.footer-column a:hover{
color:#22c55e;
}

.footer-column ul{
list-style:none;
padding:0;
margin:0;
}

.footer-column li{
margin-bottom:12px;
color:#d7e4db;
}

.footer-buttons{
margin-top:30px;
display:flex;
gap:14px;
flex-wrap:wrap;
}

.footer-buttons a{
padding:14px 22px;
background:#22c55e;
color:white;
text-decoration:none;
font-weight:700;
border-radius:12px;
transition:.2s;
}

.footer-buttons a:hover{
transform:translateY(-2px);
background:#16a34a;
}

.footer-bottom{
margin-top:70px;
padding-top:30px;
border-top:1px solid rgba(255,255,255,.08);
display:flex;
justify-content:space-between;
gap:20px;
flex-wrap:wrap;
width:min(1180px,calc(100% - 40px));
margin-left:auto;
margin-right:auto;
}

.footer-bottom p{
margin:0;
font-size:14px;
color:#9bb1a4;
}

@media(max-width:900px){

.footer-container{
grid-template-columns:1fr;
}

.footer-bottom{
flex-direction:column;
}

}

</style>