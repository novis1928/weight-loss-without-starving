---
const baseURL = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="header-container">

    <a class="site-logo" href={`${baseURL}#home`} aria-label="Go to homepage">
      <span class="logo-mark">◆</span>

      <span class="logo-copy">
        <strong>Weight Loss</strong>
        <span>Without Starving</span>
      </span>
    </a>

    <nav class="main-navigation" aria-label="Main navigation">
      <a href={`${baseURL}#home`}>Home</a>
      <a href={`${baseURL}#blog`}>Blog</a>
      <a href={`${baseURL}#preview`}>E-book</a>
      <a href={`${baseURL}#about`}>About</a>
      <a href={`${baseURL}#contact`}>Contact</a>
    </nav>

    <a
      class="header-cta"
      href="https://payhip.com/b/eW3MA"
      target="_blank"
      rel="noopener noreferrer"
    >
      Get the Ebook
    </a>

  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.05);
  }

  .header-container {
    width: min(1180px, calc(100% - 40px));
    min-height: 76px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    color: #0f172a;
    text-decoration: none;
  }

  .logo-mark {
    color: #22c55e;
    font-size: 24px;
    line-height: 1;
  }

  .logo-copy {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .logo-copy strong {
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .logo-copy span {
    margin-top: 3px;
    color: #22c55e;
    font-size: 14px;
    font-weight: 700;
  }

  .main-navigation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    margin-left: auto;
  }

  .main-navigation a {
    position: relative;
    color: #334155;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .main-navigation a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: #22c55e;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .main-navigation a:hover {
    color: #16a34a;
    transform: translateY(-1px);
  }

  .main-navigation a:hover::after {
    transform: scaleX(1);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 20px;
    flex-shrink: 0;
    border-radius: 12px;
    background: #22c55e;
    color: #ffffff;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(34, 197, 94, 0.24);
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .header-cta:hover {
    background: #16a34a;
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(34, 197, 94, 0.3);
  }

  @media (max-width: 900px) {
    .header-container {
      min-height: auto;
      padding: 16px 0;
      flex-wrap: wrap;
    }

    .main-navigation {
      order: 3;
      width: 100%;
      margin-left: 0;
      justify-content: flex-start;
      gap: 22px;
      overflow-x: auto;
      padding-bottom: 3px;
      scrollbar-width: none;
    }

    .main-navigation::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .header-container {
      width: min(100% - 24px, 1180px);
      gap: 14px;
    }

    .logo-copy strong {
      font-size: 15px;
    }

    .logo-copy span {
      font-size: 12px;
    }

    .header-cta {
      min-height: 40px;
      padding: 0 14px;
      font-size: 13px;
    }

    .main-navigation {
      gap: 18px;
    }

    .main-navigation a {
      font-size: 14px;
      white-space: nowrap;
    }
  }

  @media (max-width: 430px) {
    .header-cta {
      display: none;
    }

    .site-logo {
      margin: 0 auto;
    }

    .main-navigation {
      justify-content: center;
    }
  }
</style>