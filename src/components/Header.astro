---
const rawBaseURL = import.meta.env.BASE_URL;

const baseURL = rawBaseURL.endsWith("/")
  ? rawBaseURL
  : `${rawBaseURL}/`;
---

<header class="site-header">
  <div class="header-container">
    <a
      class="site-logo"
      href={baseURL}
      aria-label="Go to homepage"
    >
      <span class="logo-mark" aria-hidden="true">◆</span>

      <span class="logo-copy">
        <strong>Weight Loss</strong>
        <span>Without Starving</span>
      </span>
    </a>

    <nav
      class="main-navigation"
      aria-label="Main navigation"
    >
      <a href={baseURL}>Home</a>

      <a href={`${baseURL}blog/`}>
        Blog
      </a>

      <a href={`${baseURL}tools/`}>
        Tools
      </a>

      <a href={`${baseURL}#about`}>
        About
      </a>

      <a href={`${baseURL}#contact`}>
        Contact
      </a>
    </nav>

    <a
      class="header-cta"
      href="https://payhip.com/b/eW3MA"
      target="_blank"
      rel="noopener noreferrer"
    >
      Get the eBook
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.05);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .header-container {
    display: flex;
    width: min(1240px, calc(100% - 40px));
    min-height: 76px;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    margin: 0 auto;
  }

  .site-logo {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    gap: 10px;
    color: #0f172a;
    text-decoration: none;
  }

  .logo-mark {
    color: #22c55e;
    font-size: 24px;
    line-height: 1;
  }

  .logo-copy {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .logo-copy strong {
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .logo-copy span {
    margin-top: 3px;
    color: #22c55e;
    font-size: 14px;
    font-weight: 700;
  }

  .main-navigation {
    display: flex;
    min-width: 0;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-left: auto;
  }

  .main-navigation a {
    position: relative;
    flex-shrink: 0;
    color: #334155;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .main-navigation a::after {
    content: "";
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: #22c55e;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .main-navigation a:hover,
  .main-navigation a:focus-visible {
    color: #16a34a;
    transform: translateY(-1px);
  }

  .main-navigation a:hover::after,
  .main-navigation a:focus-visible::after {
    transform: scaleX(1);
  }

  .header-cta {
    display: inline-flex;
    min-height: 44px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 12px;
    background: #22c55e;
    color: #ffffff;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(34, 197, 94, 0.24);
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .header-cta:hover,
  .header-cta:focus-visible {
    background: #16a34a;
    box-shadow: 0 14px 30px rgba(34, 197, 94, 0.3);
    transform: translateY(-2px);
  }

  @media (max-width: 1060px) {
    .header-container {
      min-height: auto;
      padding: 15px 0;
      flex-wrap: wrap;
    }

    .main-navigation {
      order: 3;
      width: 100%;
      justify-content: flex-start;
      gap: 22px;
      margin-left: 0;
      padding: 3px 0 5px;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .main-navigation::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .header-container {
      width: min(100% - 24px, 1240px);
      gap: 14px;
    }

    .logo-copy strong {
      font-size: 15px;
    }

    .logo-copy span {
      font-size: 12px;
    }

    .header-cta {
      min-height: 40px;
      padding: 0 14px;
      font-size: 13px;
    }

    .main-navigation {
      gap: 18px;
    }

    .main-navigation a {
      font-size: 14px;
    }
  }

  @media (max-width: 430px) {
    .header-cta {
      display: none;
    }

    .site-logo {
      margin: 0 auto;
    }

    .main-navigation {
      justify-content: flex-start;
    }
  }
</style>